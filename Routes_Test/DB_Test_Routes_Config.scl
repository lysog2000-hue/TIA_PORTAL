// ==============================================================================
// DB_Test_Routes_Config - Конфігурація тестів маршрутів
// ==============================================================================
// Версія: 2.0.0 (оновлено для FSM v2.0)
// Дата: 2026-02-01
// ==============================================================================
// Зміни v2.0:
//   ✅ Адаптовано під об'єднаний DB_Plc_RouteFsm (без Work)
//   ✅ Додано тести для StartParam/StopParam
//   ✅ Оновлено очікувані переходи станів
// ==============================================================================

DATA_BLOCK "DB_Test_Routes_Config"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.0
NON_RETAIN

VAR
    // === Керування тестами ===
    TestEnabled         : BOOL := FALSE;   // Головний вимикач
    TestScenario        : USINT := 0;      // 0=вимкнено, 1..20=сценарії
    TestStep            : USINT := 0;      // Поточний крок сценарію
    TestTimer           : DINT := 0;       // Таймер для затримок
    
    // === Налаштування ===
    RouteId             : USINT := 1;      // Який маршрут тестуємо (1..12)
    StepDelayMs         : DINT := 2000;    // Затримка між кроками (2с)
    
    // === Діагностика ===
    LastState           : UINT := 0;       // Останній State для детекту змін
    LastResultCode      : UINT := 0;       // Останній ResultCode
    TransitionCount     : UDINT := 0;      // Лічильник переходів
    
    // === Snapshot для аналізу ===
    Snapshot_State      : UINT;
    Snapshot_ResultCode : UINT;
    Snapshot_ActiveStep : USINT;
    Snapshot_StepSts    : USINT;
    Snapshot_Timestamp  : DINT;
    
    // === Стан тесту ===
    TestPassed          : BOOL := FALSE;   // Тест пройдено успішно
    TestFailed          : BOOL := FALSE;   // Тест провалено
    FailReason          : STRING[200];     // Причина провалу
    
END_VAR

BEGIN
END_DATA_BLOCK
