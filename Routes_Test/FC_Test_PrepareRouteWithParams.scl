// ==============================================================================
// FC_Test_PrepareRouteWithParams - Підготовка маршруту з StartParam/StopParam
// ==============================================================================
// Версія: 2.0.0
// Дата: 2026-02-01
// ==============================================================================
// Призначення:
//   Тест багатопозиційної засувки в маршруті
//   Демонструє використання RS_StartParam та RS_StopParam
// ==============================================================================

FUNCTION "FC_Test_PrepareRouteWithParams" : VOID
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.0

VAR_INPUT
    RouteId         : USINT;   // 1..12
    GateSlot        : UINT;    // Slot засувки (100..149)
    GateOpenParam   : INT;     // CMD_GATE_OPEN
    GateCloseParam  : INT;     // CMD_GATE_CLOSED
END_VAR

VAR_TEMP
    bufIdx : USINT;
END_VAR

BEGIN
    // Вибір неактивного буфера
    bufIdx := "DB_ScadaToPlc_RouteCmd".HDR_ActiveBuf;
    IF bufIdx = 0 THEN
        bufIdx := 1;
    ELSE
        bufIdx := 0;
    END_IF;
    
    // Заповнення маршруту
    IF bufIdx = 0 THEN
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Cmd := "RT_CMD_NONE";
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_StepCount := 2;
        
        // ✅ Крок 0: Відкрити засувку (з параметром)
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[0].RS_Slot := GateSlot;
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[0].RS_Action := "RS_ACT_START";
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[0].RS_StartParam := GateOpenParam;  // 🆕
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[0].RS_StopParam := GateCloseParam;  // 🆕 автозакриття
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[0].RS_Wait := "RS_WAIT_RUNNING";
        
        // ✅ Крок 1: Закрити засувку (інший параметр)
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[1].RS_Slot := GateSlot;
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[1].RS_Action := "RS_ACT_START";
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[1].RS_StartParam := GateCloseParam;  // 🆕
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[1].RS_StopParam := 0;  // стандартна зупинка
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes[RouteId].RC_Steps[1].RS_Wait := "RS_WAIT_STOPPED";
    ELSE
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Cmd := "RT_CMD_NONE";
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_StepCount := 2;
        
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[0].RS_Slot := GateSlot;
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[0].RS_Action := "RS_ACT_START";
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[0].RS_StartParam := GateOpenParam;
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[0].RS_StopParam := GateCloseParam;
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[0].RS_Wait := "RS_WAIT_RUNNING";
        
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[1].RS_Slot := GateSlot;
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[1].RS_Action := "RS_ACT_START";
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[1].RS_StartParam := GateCloseParam;
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[1].RS_StopParam := 0;
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes[RouteId].RC_Steps[1].RS_Wait := "RS_WAIT_STOPPED";
    END_IF;
    
END_FUNCTION
