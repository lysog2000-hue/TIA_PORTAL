DATA_BLOCK "DB_TestResults_Supervisor"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
NON_RETAIN
   STRUCT
      // Загальна інформація про тести
      TotalTests : USInt := 15;      // Кількість тестів
      PassedTests : USInt := 0;       // Скільки пройшло
      FailedTests : USInt := 0;       // Скільки провалено
      CurrentTest : USInt := 0;       // Номер поточного тесту
      AllTestsRun : Bool := FALSE;    // Всі тести виконані
      
      // Результати кожного тесту
      Results : Array[1..5] of Struct
         TestNumber : USInt;
         TestName : String[80];
         Passed : Bool;
         ErrorCode : UInt;            // Код помилки (якщо є)
      END_STRUCT;
      
      // Статистика продуктивності
      // ПРИМІТКА: Вимірювання часу недоступне в SCL S7-1500
      // Використовуйте зовнішній таймер якщо потрібно
      
      // Тестові сценарії для перевірки
      Scenarios : Struct
         // Scenario 1: Послідовний запуск 3 маршрутів
         Seq3Routes : Struct
            Route1_StartTime : Time;
            Route1_AckTime : Time;
            Route2_StartTime : Time;
            Route2_AckTime : Time;
            Route3_StartTime : Time;
            Route3_AckTime : Time;
            Success : Bool;
         END_STRUCT;
         
         // Scenario 2: Дублікат START
         DuplicateStart : Struct
            FirstStart_Accepted : Bool;
            SecondStart_Rejected : Bool;
            Warning_Set : Bool;
            Success : Bool;
         END_STRUCT;
         
         // Scenario 3: STOP_OP для активного маршруту
         StopActive : Struct
            Route_WasRunning : Bool;
            StopOp_Accepted : Bool;
            Route_InStopping : Bool;
            Success : Bool;
         END_STRUCT;
      END_STRUCT;
   END_STRUCT;

BEGIN
   // Ініціалізація тестів
   TotalTests := 5;
   
   // Імена тестів (для документації)
   Results[1].TestName := 'Basic START command acceptance';
   Results[2].TestName := 'Duplicate START rejection';
   Results[3].TestName := 'STOP_OP for active route';
   Results[4].TestName := 'Invalid RouteId validation';
   Results[5].TestName := 'START after ABORTED state';


END_DATA_BLOCK
