FUNCTION_BLOCK "FB_Test_Routes"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

VAR
    // Edge detection
    lastEnabled : BOOL;
    lastScenario : USINT;
    
    // Timing
    lastTick : DINT;
END_VAR

VAR_TEMP
    nowTick : DINT;
    elapsed : DINT;
    stateChanged : BOOL;
END_VAR

BEGIN
    
    // =========================================================
    // Перевірка змін стану маршруту (діагностика)
    // =========================================================
    stateChanged := ("DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_State 
                     <> "DB_Test_Routes_Config".LastState);
    
    IF stateChanged THEN
        "DB_Test_Routes_Config".TransitionCount := "DB_Test_Routes_Config".TransitionCount + 1;
        
        // Snapshot
        "DB_Test_Routes_Config".Snapshot_State := 
            "DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_State;
        "DB_Test_Routes_Config".Snapshot_ResultCode := 
            "DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_ResultCode;
        "DB_Test_Routes_Config".Snapshot_ActiveStep := 
            "DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_ActiveStep;
        "DB_Test_Routes_Config".Snapshot_StepSts := 
            "DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_StepSts;
        "DB_Test_Routes_Config".Snapshot_Timestamp := TIME_TCK();
        
        "DB_Test_Routes_Config".LastState := 
            "DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_State;
        "DB_Test_Routes_Config".LastResultCode := 
            "DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_ResultCode;
    END_IF;
    
    // =========================================================
    // Скидання при зміні сценарію
    // =========================================================
    IF "DB_Test_Routes_Config".TestScenario <> lastScenario THEN
        "DB_Test_Routes_Config".TestStep := 0;
        "DB_Test_Routes_Config".TestTimer := 0;
        "DB_Test_Routes_Config".TransitionCount := 0;
        lastTick := TIME_TCK();
    END_IF;
    
    lastScenario := "DB_Test_Routes_Config".TestScenario;
    
    // =========================================================
    // Якщо тести вимкнені - очистити команди
    // =========================================================
    IF NOT "DB_Test_Routes_Config".TestEnabled THEN
        "DB_ScadaToPlc_RouteCmd".BUF0_Routes["DB_Test_Routes_Config".RouteId].RC_Cmd := RT_CMD_NONE;
        "DB_ScadaToPlc_RouteCmd".BUF1_Routes["DB_Test_Routes_Config".RouteId].RC_Cmd := RT_CMD_NONE;
        "DB_Test_Routes_Config".TestStep := 0;
        RETURN;
    END_IF;
    
    // =========================================================
    // Таймер
    // =========================================================
    nowTick := TIME_TCK();
    IF nowTick >= lastTick THEN
        elapsed := nowTick - lastTick;
    ELSE
        elapsed := (2147483647 - lastTick) + nowTick + 1;
    END_IF;
    
    "DB_Test_Routes_Config".TestTimer := "DB_Test_Routes_Config".TestTimer + elapsed;
    lastTick := nowTick;
    
    // =========================================================
    // Виконання сценаріїв
    // =========================================================
    
    CASE "DB_Test_Routes_Config".TestScenario OF
        
        // ============================================================
        // Сценарій 1: Простий START → DONE (2 редлери)
        // ============================================================
        1:
            CASE "DB_Test_Routes_Config".TestStep OF
                
                0:  // Підготовка маршруту
                    "FC_Test_PrepareSimpleRoute"(
                        RouteId := "DB_Test_Routes_Config".RouteId,
                        Slot1 := 0,  // Редлер 0
                        Slot2 := 1   // Редлер 1
                    );
                    "DB_Test_Routes_Config".TestStep := 1;
                    "DB_Test_Routes_Config".TestTimer := 0;
                
                1:  // Затримка перед START
                    IF "DB_Test_Routes_Config".TestTimer >= 500 THEN
                        "DB_Test_Routes_Config".TestStep := 2;
                        "DB_Test_Routes_Config".TestTimer := 0;
                    END_IF;
                
                2:  // Відправка START
                    "FC_Test_SendRouteCommand"(
                        RouteId := "DB_Test_Routes_Config".RouteId,
                        Cmd := RT_CMD_START
                    );
                    "DB_Test_Routes_Config".TestStep := 3;
                    "DB_Test_Routes_Config".TestTimer := 0;
                
                3:  // Чекаємо DONE або ABORT
                    IF ("DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_State = ROUTE_STS_DONE)
                       OR ("DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_State = ROUTE_STS_ABORTED)
                       OR ("DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_State = ROUTE_STS_REJECTED) THEN
                        "DB_Test_Routes_Config".TestStep := 4;
                        "DB_Test_Routes_Config".TestTimer := 0;
                    END_IF;
                
                4:  // Затримка перед очищенням
                    IF "DB_Test_Routes_Config".TestTimer >= 2000 THEN
                        "DB_Test_Routes_Config".TestStep := 5;
                    END_IF;
                
                5:  // Очищення команди (RT_CMD_NONE)
                    "FC_Test_SendRouteCommand"(
                        RouteId := "DB_Test_Routes_Config".RouteId,
                        Cmd := RT_CMD_NONE
                    );
                    "DB_Test_Routes_Config".TestStep := 99;  // Завершено
                
            END_CASE;
        
        // ============================================================
        // Сценарій 2: START → STOP_OP → ABORTED
        // ============================================================
        2:
            CASE "DB_Test_Routes_Config".TestStep OF
                
                0:  // Підготовка
                    "FC_Test_PrepareSimpleRoute"(
                        RouteId := "DB_Test_Routes_Config".RouteId,
                        Slot1 := 0,
                        Slot2 := 1
                    );
                    "DB_Test_Routes_Config".TestStep := 1;
                    "DB_Test_Routes_Config".TestTimer := 0;
                
                1:  // START
                    IF "DB_Test_Routes_Config".TestTimer >= 500 THEN
                        "FC_Test_SendRouteCommand"(
                            RouteId := "DB_Test_Routes_Config".RouteId,
                            Cmd := RT_CMD_START
                        );
                        "DB_Test_Routes_Config".TestStep := 2;
                        "DB_Test_Routes_Config".TestTimer := 0;
                    END_IF;
                
                2:  // Чекаємо RUNNING
                    IF "DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_State = ROUTE_STS_RUNNING THEN
                        "DB_Test_Routes_Config".TestStep := 3;
                        "DB_Test_Routes_Config".TestTimer := 0;
                    END_IF;
                
                3:  // Затримка в RUNNING
                    IF "DB_Test_Routes_Config".TestTimer >= 3000 THEN
                        "DB_Test_Routes_Config".TestStep := 4;
                    END_IF;
                
                4:  // Відправка STOP_OP
                    "FC_Test_SendRouteCommand"(
                        RouteId := "DB_Test_Routes_Config".RouteId,
                        Cmd := RT_CMD_STOP_OP
                    );
                    "DB_Test_Routes_Config".TestStep := 5;
                    "DB_Test_Routes_Config".TestTimer := 0;
                
                5:  // Чекаємо ABORTED
                    IF "DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_State = ROUTE_STS_ABORTED THEN
                        "DB_Test_Routes_Config".TestStep := 6;
                        "DB_Test_Routes_Config".TestTimer := 0;
                    END_IF;
                
                6:  // Затримка
                    IF "DB_Test_Routes_Config".TestTimer >= 2000 THEN
                        "DB_Test_Routes_Config".TestStep := 7;
                    END_IF;
                
                7:  // Очищення
                    "FC_Test_SendRouteCommand"(
                        RouteId := "DB_Test_Routes_Config".RouteId,
                        Cmd := RT_CMD_NONE
                    );
                    "DB_Test_Routes_Config".TestStep := 99;
                
            END_CASE;
        
        // ============================================================
        // Сценарій 3: REJECT_BY_OWNER (механізм зайнятий)
        // ============================================================
        3:
            CASE "DB_Test_Routes_Config".TestStep OF
                
                0:  // Захватити механізм вручну (SCADA)
                    "DB_Mechs".Mechs[0].OwnerCur := OWNER_SCADA;
                    "DB_Mechs".Mechs[0].OwnerCurId := 0;
                    "DB_Test_Routes_Config".TestStep := 1;
                    "DB_Test_Routes_Config".TestTimer := 0;
                
                1:  // Підготувати маршрут (що включає slot 0)
                    "FC_Test_PrepareSimpleRoute"(
                        RouteId := "DB_Test_Routes_Config".RouteId,
                        Slot1 := 0,
                        Slot2 := 1
                    );
                    "DB_Test_Routes_Config".TestStep := 2;
                
                2:  // Затримка
                    IF "DB_Test_Routes_Config".TestTimer >= 500 THEN
                        "DB_Test_Routes_Config".TestStep := 3;
                    END_IF;
                
                3:  // START (має бути REJECT_BY_OWNER)
                    "FC_Test_SendRouteCommand"(
                        RouteId := "DB_Test_Routes_Config".RouteId,
                        Cmd := RT_CMD_START
                    );
                    "DB_Test_Routes_Config".TestStep := 4;
                    "DB_Test_Routes_Config".TestTimer := 0;
                
                4:  // Чекаємо REJECTED
                    IF "DB_PlcToScada_RouteStatus".RoutesSts["DB_Test_Routes_Config".RouteId].RS_State = ROUTE_STS_REJECTED THEN
                        "DB_Test_Routes_Config".TestStep := 5;
                        "DB_Test_Routes_Config".TestTimer := 0;
                    END_IF;
                
                5:  // Затримка
                    IF "DB_Test_Routes_Config".TestTimer >= 2000 THEN
                        "DB_Test_Routes_Config".TestStep := 6;
                    END_IF;
                
                6:  // Очищення owner + команда
                    "DB_Mechs".Mechs[0].OwnerCur := OWNER_NONE;
                    "DB_Mechs".Mechs[0].OwnerCurId := 0;
                    "FC_Test_SendRouteCommand"(
                        RouteId := "DB_Test_Routes_Config".RouteId,
                        Cmd := RT_CMD_NONE
                    );
                    "DB_Test_Routes_Config".TestStep := 99;
                
            END_CASE;
        
        ELSE
            // Невідомий сценарій - нічого не робимо
            ;
            
    END_CASE;
    
END_FUNCTION_BLOCK