// ==============================================================================
// DB_ScadaToPlc_RouteCmd - Mailbox для команд маршрутів (v2.0)
// ==============================================================================
// Версія: 2.0.1 (Mailbox Pattern)
// Дата: 2026-02-02
// ==============================================================================
// АРХІТЕКТУРА MAILBOX:
// 
// Замість масиву команд для 12 маршрутів використовується ЄДИНИЙ СЛОТ (mailbox).
// SCADA записує команду для конкретного маршруту у mailbox, PLC обробляє її
// та підтверджує через ACK, після чого mailbox звільняється для нового запиту.
//
// ПРОТОКОЛ:
// 1. SCADA перевіряє: HDR_Commit == ACK_CommitApplied (mailbox вільний)
// 2. SCADA записує: HDR_RouteId + CMD_Route + інкрементує HDR_Commit
// 3. PLC детектує: HDR_Commit != ACK_CommitApplied (нова команда)
// 4. PLC обробляє команду та інкрементує ACK_CommitApplied
// 5. SCADA бачить ACK та може надіслати нову команду
//
// ПЕРЕВАГИ:
// - Пам'ять: 15KB → 1.3KB (92% економії)
// - Простота: послідовна обробка команд
// - Природність: маршрути запускаються з інтервалами (хвилини)
//
// ЗАХИСТ:
// - Mailbox mutex: commitIn != commitAck = зайнято
// - Timeout 1s для SCADA (якщо ACK не прийшов - retry/error)
// - Активні маршрути відхиляють нові START (тільки STOP_OP дозволено)
// ==============================================================================

DATA_BLOCK "DB_ScadaToPlc_RouteCmd"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.0
NON_RETAIN

VAR
  // === HEADER: Mailbox Control ===
  HDR_Commit    : UDINT;  // Лічильник команд (SCADA інкрементує після запису)
  HDR_RouteId   : USINT;  // Цільовий маршрут 1..12 (0 = невалідний)
  
  // === PAYLOAD: Command Data ===
  CMD_Route     : "UDT_RouteCmd";  // Структура команди маршруту
END_VAR

BEGIN
  // === СИМУЛЯЦІЯ: Послідовний запуск 3-х норій (слоти 0..2) ===
  // Маршрут 1, команда RT_CMD_START (1), 3 кроки
  // Кожен крок: RS_Action=RS_ACT_START(1), RS_Wait=RS_WAIT_RUNNING(1)
  // HDR_Commit=1, ACK_CommitApplied=0 → PLC детектує нову команду при старті
  HDR_RouteId := 1;

  CMD_Route.RC_Cmd       := 1;  // RT_CMD_START
  CMD_Route.RC_StepCount := 3;

  // Крок 0 — Норія у слоті 0
  CMD_Route.RC_Steps[0].RS_Slot   := 0;
  CMD_Route.RC_Steps[0].RS_Action := 1;  // RS_ACT_START
  CMD_Route.RC_Steps[0].RS_Wait   := 1;  // RS_WAIT_RUNNING

  // Крок 1 — Норія у слоті 1
  CMD_Route.RC_Steps[1].RS_Slot   := 1;
  CMD_Route.RC_Steps[1].RS_Action := 1;
  CMD_Route.RC_Steps[1].RS_Wait   := 1;

  // Крок 2 — Норія у слоті 2
  CMD_Route.RC_Steps[2].RS_Slot   := 2;
  CMD_Route.RC_Steps[2].RS_Action := 1;
  CMD_Route.RC_Steps[2].RS_Wait   := 1;

  HDR_Commit := 1;  // Тригер mailbox (ACK_CommitApplied=0 після старту → нова команда)
END_DATA_BLOCK
