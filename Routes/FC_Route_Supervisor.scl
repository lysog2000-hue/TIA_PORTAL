// ==============================================================================
// FC_Route_Supervisor - Супервізор маршрутів (Mailbox Pattern v3.0)
// ==============================================================================
// Версія: 3.0.0
// Дата: 2026-02-24
// ==============================================================================
// ЗМІНИ v3.0.0:
//   [FIX-1] VAR_INPUT: GlobalSafetyStop, LocalManualGlobal (раніше завжди FALSE)
//           FC_RouteFSM тепер отримує реальні сигнали безпеки
//   [FIX-2] Невалідний RouteId → ACK + RETURN (раніше RETURN без ACK)
//           Mailbox більше не блокується назавжди
//   [FIX-3] REJECTED додано до Cleanup (раніше маршрут застрягав у REJECTED)
//           FSM може вийти з REJECTED → IDLE через RT_CMD_NONE
//   [FIX-4] STOP_OP для неактивного маршруту → RS_WARNING_IGNORED_CMD
//           (раніше "завжди дозволено" → сміття у RouteExecutor для REJECTED)
//
// v2.0.4:
//   FC_RouteFSM затирає RS_Warning кожного циклу для ВСІХ маршрутів
//   Рішення: Зберігати RS_Warning перед FSM і відновлювати після FSM
// ==============================================================================

FUNCTION "FC_Route_Supervisor" : VOID
{ S7_Optimized_Access := 'TRUE' }
VERSION : 3.0



VAR_TEMP
  i                : INT;
  commitIn         : UDINT;
  commitAck        : UDINT;
  routeId          : USINT;
  currentState     : UINT;
  isActive         : BOOL;
  cmdAllowed       : BOOL;
  processedRouteId : USINT;
  pendingWarning   : USINT;
  savedWarnings    : ARRAY[1..12] OF USINT;  // ✅ Зберегти RS_Warning
END_VAR

BEGIN
    
    // Ініціалізація
    processedRouteId := 0;
    pendingWarning := RS_WARNING_OK;
    
    // =========================================================
    // 1. ЗБЕРЕГТИ RS_Warning перед FSM
    // =========================================================
    // ✅ КРИТИЧНО: FSM затирає RS_Warning кожного циклу
    FOR i := 1 TO 12 DO
        savedWarnings[i] := "DB_PlcToScada_RouteStatus".RoutesSts[i].RS_Warning;
    END_FOR;
    
    // =========================================================
    // 2. MAILBOX: Детект нової команди
    // =========================================================
    commitIn  := "DB_ScadaToPlc_RouteCmd".HDR_Commit;
    commitAck := "DB_PlcToScada_RouteStatus".ACK_CommitApplied;
    
    IF commitIn <> commitAck THEN
        
        // =========================================================
        // 3. MAILBOX: Валідація RouteId
        // =========================================================
        routeId := "DB_ScadaToPlc_RouteCmd".HDR_RouteId;
        
        // Невалідний RouteId → ACK (mailbox не блокується) + RETURN
        IF (routeId < 1) OR (routeId > 12) THEN
            "DB_PlcToScada_RouteStatus".ACK_CommitApplied := commitIn;
            "DB_PlcToScada_RouteStatus".ACK_RouteId := 0;
            RETURN;
        END_IF;
        
        // =========================================================
        // 4. MAILBOX: Перевірка стану маршруту
        // =========================================================
        currentState := "DB_PlcToScada_RouteStatus".RoutesSts[routeId].RS_State;
        
        isActive := (currentState = ROUTE_STS_VALIDATING) OR
                    (currentState = ROUTE_STS_STARTING) OR
                    (currentState = ROUTE_STS_RUNNING) OR
                    (currentState = ROUTE_STS_STOPPING);
        
        cmdAllowed := FALSE;
        
        // Перевірка дозволеності команди
        IF "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd = RT_CMD_START THEN
            IF isActive THEN
                // START для активного → ігнорувати з попередженням
                pendingWarning := RS_WARNING_IGNORED_CMD;
                cmdAllowed := FALSE;
            ELSE
                // START для неактивного → дозволено
                pendingWarning := RS_WARNING_OK;
                cmdAllowed := TRUE;
            END_IF;
            
        ELSIF "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd = RT_CMD_STOP_OP THEN
            IF isActive THEN
                // STOP_OP для активного маршруту — дозволено
                pendingWarning := RS_WARNING_OK;
                cmdAllowed := TRUE;
            ELSE
                // STOP_OP для неактивного (IDLE/REJECTED/ABORTED) — ігнорувати з попередженням
                pendingWarning := RS_WARNING_IGNORED_CMD;
                cmdAllowed := FALSE;
            END_IF;
            
        ELSE
            // RT_CMD_NONE або невідома команда
            cmdAllowed := FALSE;
        END_IF;
        
        // =========================================================
        // 5. MAILBOX: Копіювання команди у RouteExecutor
        // =========================================================
        IF cmdAllowed THEN
            "DB_Plc_RouteExecutor".Routes[routeId] := "DB_ScadaToPlc_RouteCmd".CMD_Route;
        END_IF;
        
        // =========================================================
        // 6. MAILBOX: Підтвердження (ACK)
        // =========================================================
        "DB_PlcToScada_RouteStatus".ACK_CommitApplied := commitIn;
        "DB_PlcToScada_RouteStatus".ACK_RouteId := routeId;
        
        // Запам'ятати який маршрут обробили
        processedRouteId := routeId;
        
    END_IF;
    
    // =========================================================
    // 7. FSM: Виконання всіх маршрутів
    // =========================================================
    FOR i := 1 TO 12 DO
        
        "FC_RouteFSM"(
            RouteIdx          := INT_TO_USINT(i),
            Cmd               := "DB_Plc_RouteExecutor".Routes[i],
            Mechs             := "DB_Mechs".Mechs,
            Fsm               := "DB_Plc_RouteFsm".RoutesFsm[i],
            Sts               => "DB_PlcToScada_RouteStatus".RoutesSts[i]
        );
        
    END_FOR;
    
    // =========================================================
    // 8. ✅ ВІДНОВИТИ RS_Warning після FSM
    // =========================================================
    FOR i := 1 TO 12 DO
        IF i = processedRouteId THEN
            // Для обробленого маршруту → встановити новий Warning
            "DB_PlcToScada_RouteStatus".RoutesSts[i].RS_Warning := pendingWarning;
        ELSE
            // Для інших маршрутів → відновити збережений Warning
            "DB_PlcToScada_RouteStatus".RoutesSts[i].RS_Warning := savedWarnings[i];
        END_IF;
    END_FOR;
    
    // =========================================================
    // 9. CLEANUP: Очищення RouteExecutor після завершення
    // =========================================================
    FOR i := 1 TO 12 DO
        // Пропустити маршрут, який щойно отримав нову команду
        IF i = processedRouteId THEN
            CONTINUE;
        END_IF;
        
        currentState := "DB_PlcToScada_RouteStatus".RoutesSts[i].RS_State;
        
        // Очищати маршрути у фінальних станах (REJECTED включено — без цього FSM застряє)
        IF (currentState = ROUTE_STS_ABORTED) OR (currentState = ROUTE_STS_IDLE)
        OR (currentState = ROUTE_STS_REJECTED) THEN
            "DB_Plc_RouteExecutor".Routes[i].RC_Cmd := RT_CMD_NONE;
            "DB_Plc_RouteExecutor".Routes[i].RC_StepCount := 0;
        END_IF;
    END_FOR;
    
END_FUNCTION
