// ==============================================================================
// Версія: 2.0.2
// Дата: 2026-03-01
// ==============================================================================
// Зміни v2.0.2:
//   - RoutesFsm: ARRAY[1.."ROUTES_COUNT"] - винесено магічне число 12
//   - NON-RETAIN: маршрути не відновлюються після рестарту
//   - Спрощена структура без дублювання
// ==============================================================================

DATA_BLOCK "DB_Plc_RouteFsm"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.0
NON_RETAIN

VAR
  // Стани FSM для маршрутів (включає persistent + work variables)
  RoutesFsm : ARRAY[1.."ROUTES_COUNT"] OF "UDT_RouteFsm";
END_VAR

BEGIN
END_DATA_BLOCK
