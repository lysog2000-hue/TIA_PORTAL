FUNCTION "FC_Test_RouteSupervisor" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0
   VAR_INPUT 
      TestNumber : USInt;   // Номер тесту для виконання
   END_VAR

   VAR_TEMP 
      i : Int;
      testPassed : Bool;
      testName : String[80];
      savedCommit : UDInt;
   END_VAR

BEGIN
   // =================================================================
   // TEST SUITE для FC_Route_Supervisor v2.0
   // =================================================================
   // Версія: 1.0 - Повний набір (25 тестів)
   // Дата: 2026-02-03
   // 
   // ПОКРИТТЯ:
   // - Mailbox Protocol (тести 1-8)
   // - Команди для різних станів (тести 9-13)
   // - Множинні маршрути (тести 14-15)
   // - Невалідні команди (тести 16-18)
   // - RS_Warning збереження (тести 19-20)
   // - Cleanup логіка (тести 21-23)
   // - StepCount обробка (тести 24-25)
   // =================================================================
   
   CASE #TestNumber OF
      
      // ============================================================
      // TEST 1: Базовий прийом команди START
      // ============================================================
      1:
         #testName := 'TEST 1: Basic START command acceptance';
         
         // ARRANGE: Mailbox вільний, Route #1 у стані IDLE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 100;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 100;
         "DB_PlcToScada_RouteStatus".RoutesSts[1].RS_State := ROUTE_STS_IDLE;
         "DB_PlcToScada_RouteStatus".RoutesSts[1].RS_Warning := RS_WARNING_OK;
         
         // ACT: SCADA відправляє START для Route #1
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 1;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 3;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 101;
         
         "FC_Route_Supervisor"();
         
         // ASSERT
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 101 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".ACK_RouteId <> 1 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[1].RC_Cmd <> RT_CMD_START THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[1].RC_StepCount <> 3 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[1].RS_Warning <> RS_WARNING_OK THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[1].TestNumber := 1;
         "DB_TestResults_Supervisor".Results[1].Passed := #testPassed;
         
      
      // ============================================================
      // TEST 2: Відхилення дубліката START для RUNNING
      // ============================================================
      2:
         #testName := 'TEST 2: Duplicate START rejection';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 200;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 200;
         "DB_PlcToScada_RouteStatus".RoutesSts[2].RS_State := ROUTE_STS_RUNNING;
         "DB_PlcToScada_RouteStatus".RoutesSts[2].RS_Warning := RS_WARNING_OK;
         "DB_Plc_RouteFsm".RoutesFsm[2].RF_State := ROUTE_STS_RUNNING;
         "DB_Plc_RouteExecutor".Routes[2].RC_Cmd := RT_CMD_NONE;
         "DB_Plc_RouteExecutor".Routes[2].RC_StepCount := 5;
         
         // ACT
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 2;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 7;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 201;
         
         "FC_Route_Supervisor"();
         
         // ASSERT
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 201 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[2].RS_Warning <> RS_WARNING_IGNORED_CMD THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[2].RC_StepCount <> 5 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[2].TestNumber := 2;
         "DB_TestResults_Supervisor".Results[2].Passed := #testPassed;


      // ============================================================
      // TEST 3: STOP_OP для активного маршруту
      // ============================================================
      3:
         #testName := 'TEST 3: STOP_OP for active route';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 300;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 300;
         "DB_PlcToScada_RouteStatus".RoutesSts[3].RS_State := ROUTE_STS_RUNNING;
         "DB_PlcToScada_RouteStatus".RoutesSts[3].RS_Warning := RS_WARNING_OK;
         "DB_Plc_RouteFsm".RoutesFsm[3].RF_State := ROUTE_STS_RUNNING;
         "DB_Plc_RouteExecutor".Routes[3].RC_Cmd := RT_CMD_START;
         
         // ACT
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 3;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_STOP_OP;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 301;
         
         "FC_Route_Supervisor"();
         
         // ASSERT
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 301 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[3].RC_Cmd <> RT_CMD_STOP_OP THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[3].RS_Warning <> RS_WARNING_OK THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[3].TestNumber := 3;
         "DB_TestResults_Supervisor".Results[3].Passed := #testPassed;


      // ============================================================
      // TEST 4: Валідація невалідного RouteId
      // ============================================================
      4:
         #testName := 'TEST 4: Invalid RouteId validation';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 400;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 400;
         
         // ACT 1: RouteId = 0
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 0;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 401;
         
         "FC_Route_Supervisor"();
         
         // ASSERT 1: Відхилено
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 400 THEN
             #testPassed := FALSE;
         END_IF;
         
         // ACT 2: RouteId = 13
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 13;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 402;
         
         "FC_Route_Supervisor"();
         
         // ASSERT 2
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 400 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[4].TestNumber := 4;
         "DB_TestResults_Supervisor".Results[4].Passed := #testPassed;
         
      
      // ============================================================
      // TEST 5: START після ABORTED
      // ============================================================
      5:
         #testName := 'TEST 5: START after ABORTED state';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 500;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 500;
         "DB_PlcToScada_RouteStatus".RoutesSts[4].RS_State := ROUTE_STS_ABORTED;
         "DB_PlcToScada_RouteStatus".RoutesSts[4].RS_ResultCode := ROUTE_ABRT_BY_OPERATOR;
         "DB_Plc_RouteExecutor".Routes[4].RC_Cmd := RT_CMD_NONE;
         
         // ACT
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 4;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 2;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 501;
         
         "FC_Route_Supervisor"();
         
         // ASSERT
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 501 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[4].RC_Cmd <> RT_CMD_START THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[4].RS_Warning <> RS_WARNING_OK THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[5].TestNumber := 5;
         "DB_TestResults_Supervisor".Results[5].Passed := #testPassed;
         

      // ============================================================
      // TEST 6: Commit wraparound (переповнення UDINT)
      // ============================================================
      6:
         #testName := 'TEST 6: Commit wraparound';
         
         // ARRANGE: Commit на максимумі UDINT
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 16#FFFFFFFF;  // MAX UDINT
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 16#FFFFFFFF;
         "DB_PlcToScada_RouteStatus".RoutesSts[5].RS_State := ROUTE_STS_IDLE;
         
         // ACT: Commit обнуляється (wraparound)
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 5;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 2;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 0;  // Wraparound
         
         "FC_Route_Supervisor"();
         
         // ASSERT: Команда має бути оброблена (0 <> MAX)
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 0 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[5].RC_Cmd <> RT_CMD_START THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[6].TestNumber := 6;
         "DB_TestResults_Supervisor".Results[6].Passed := #testPassed;


      // ============================================================
      // TEST 7: Одночасні команди (ВИПРАВЛЕНИЙ)
      // ============================================================
      7:
         #testName := 'TEST 7: Mailbox overwrite behavior';
         
         // ARRANGE: Mailbox містить команду з Commit=700
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 700;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 699;
         "DB_PlcToScada_RouteStatus".RoutesSts[6].RS_State := ROUTE_STS_IDLE;
         
         // ACT: SCADA перезаписує команду новою (Commit=701) без очікування ACK
         // Це симулює "швидке оновлення" або помилку SCADA
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 6;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 3;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 701;  // Перезаписано
         
         "FC_Route_Supervisor"();
         
         // ASSERT: Supervisor обробляє ПОТОЧНУ команду з mailbox (701)
         // Попередня команда (700) втрачена - це поведінка mailbox без черги
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 701 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[6].RC_Cmd <> RT_CMD_START THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[7].TestNumber := 7;
         "DB_TestResults_Supervisor".Results[7].Passed := #testPassed;



      // ============================================================
      // TEST 8: Повтор команди з тим же Commit (retry)
      // ============================================================
      8:
         #testName := 'TEST 8: Same Commit retry';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 800;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 799;
         "DB_PlcToScada_RouteStatus".RoutesSts[7].RS_State := ROUTE_STS_IDLE;
         
         // ACT 1: Перша обробка
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 7;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 4;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 800;
         
         "FC_Route_Supervisor"();
         
         // ACT 2: Повторний виклик з тим же Commit
         "FC_Route_Supervisor"();
         
         // ASSERT: Команда НЕ обробляється повторно
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 800 THEN
             #testPassed := FALSE;
         END_IF;
         // RouteExecutor має бути встановлено лише раз
         IF "DB_Plc_RouteExecutor".Routes[7].RC_StepCount <> 4 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[8].TestNumber := 8;
         "DB_TestResults_Supervisor".Results[8].Passed := #testPassed;


      // ============================================================
      // TEST 9: START для маршруту у стані VALIDATING
      // ============================================================
      9:
         #testName := 'TEST 9: START for VALIDATING route';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 900;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 900;
         "DB_PlcToScada_RouteStatus".RoutesSts[8].RS_State := ROUTE_STS_VALIDATING;
         "DB_PlcToScada_RouteStatus".RoutesSts[8].RS_Warning := RS_WARNING_OK;
         "DB_Plc_RouteExecutor".Routes[8].RC_Cmd := RT_CMD_START;
         "DB_Plc_RouteExecutor".Routes[8].RC_StepCount := 3;
         
         // ACT: Дублікат START
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 8;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 5;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 901;
         
         "FC_Route_Supervisor"();
         
         // ASSERT: Команда відхилена
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 901 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[8].RS_Warning <> RS_WARNING_IGNORED_CMD THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[8].RC_StepCount <> 3 THEN  // Не змінено
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[9].TestNumber := 9;
         "DB_TestResults_Supervisor".Results[9].Passed := #testPassed;


      // ============================================================
      // TEST 10: START для маршруту у стані STARTING
      // ============================================================
      10:
         #testName := 'TEST 10: START for STARTING route';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1000;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1000;
         "DB_PlcToScada_RouteStatus".RoutesSts[9].RS_State := ROUTE_STS_STARTING;
         "DB_PlcToScada_RouteStatus".RoutesSts[9].RS_Warning := RS_WARNING_OK;
         "DB_Plc_RouteExecutor".Routes[9].RC_Cmd := RT_CMD_START;
         "DB_Plc_RouteExecutor".Routes[9].RC_StepCount := 2;
         
         // ACT
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 9;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 6;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1001;
         
         "FC_Route_Supervisor"();
         
         // ASSERT
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1001 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[9].RS_Warning <> RS_WARNING_IGNORED_CMD THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[9].RC_StepCount <> 2 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[10].TestNumber := 10;
         "DB_TestResults_Supervisor".Results[10].Passed := #testPassed;


      // ============================================================
      // TEST 11: START для маршруту у стані STOPPING
      // ============================================================
      11:
         #testName := 'TEST 11: START for STOPPING route';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1100;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1100;
         "DB_PlcToScada_RouteStatus".RoutesSts[10].RS_State := ROUTE_STS_STOPPING;
         "DB_PlcToScada_RouteStatus".RoutesSts[10].RS_Warning := RS_WARNING_OK;
         "DB_Plc_RouteExecutor".Routes[10].RC_Cmd := RT_CMD_STOP_OP;
         
         // ACT
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 10;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 4;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1101;
         
         "FC_Route_Supervisor"();
         
         // ASSERT
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1101 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[10].RS_Warning <> RS_WARNING_IGNORED_CMD THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[10].RC_Cmd <> RT_CMD_STOP_OP THEN  // Не змінено
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[11].TestNumber := 11;
         "DB_TestResults_Supervisor".Results[11].Passed := #testPassed;


      // ============================================================
      // TEST 12: STOP_OP для маршруту у стані IDLE
      // ============================================================
      12:
         #testName := 'TEST 12: STOP_OP for IDLE route';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1200;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1200;
         "DB_PlcToScada_RouteStatus".RoutesSts[11].RS_State := ROUTE_STS_IDLE;
         "DB_PlcToScada_RouteStatus".RoutesSts[11].RS_Warning := RS_WARNING_OK;
         "DB_Plc_RouteExecutor".Routes[11].RC_Cmd := RT_CMD_NONE;
         
         // ACT
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 11;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_STOP_OP;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1201;
         
         "FC_Route_Supervisor"();
         
         // ASSERT: Команда приймається навіть для IDLE
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1201 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[11].RC_Cmd <> RT_CMD_STOP_OP THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[11].RS_Warning <> RS_WARNING_OK THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[12].TestNumber := 12;
         "DB_TestResults_Supervisor".Results[12].Passed := #testPassed;


      // ============================================================
      // TEST 13: STOP_OP для маршруту у стані ABORTED
      // ============================================================
      13:
         #testName := 'TEST 13: STOP_OP for ABORTED route';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1300;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1300;
         "DB_PlcToScada_RouteStatus".RoutesSts[12].RS_State := ROUTE_STS_ABORTED;
         "DB_PlcToScada_RouteStatus".RoutesSts[12].RS_Warning := RS_WARNING_OK;
         "DB_Plc_RouteExecutor".Routes[12].RC_Cmd := RT_CMD_NONE;
         
         // ACT
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 12;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_STOP_OP;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1301;
         
         "FC_Route_Supervisor"();
         
         // ASSERT
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1301 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[12].RC_Cmd <> RT_CMD_STOP_OP THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[12].RS_Warning <> RS_WARNING_OK THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[13].TestNumber := 13;
         "DB_TestResults_Supervisor".Results[13].Passed := #testPassed;


      // ============================================================
      // TEST 14: Послідовні команди різним маршрутам
      // ============================================================
      14:
         #testName := 'TEST 14: Sequential commands to different routes';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1400;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1400;
         "DB_PlcToScada_RouteStatus".RoutesSts[1].RS_State := ROUTE_STS_IDLE;
         "DB_PlcToScada_RouteStatus".RoutesSts[2].RS_State := ROUTE_STS_IDLE;
         
         // ACT 1: Команда для Route #1
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 1;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 3;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1401;
         
         "FC_Route_Supervisor"();
         
         // ASSERT 1
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1401 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[1].RC_StepCount <> 3 THEN
             #testPassed := FALSE;
         END_IF;
         
         // ACT 2: Команда для Route #2
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 2;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 5;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1402;
         
         "FC_Route_Supervisor"();
         
         // ASSERT 2
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1402 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[2].RC_StepCount <> 5 THEN
             #testPassed := FALSE;
         END_IF;
         // Route #1 має залишитись без змін
         IF "DB_Plc_RouteExecutor".Routes[1].RC_StepCount <> 3 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[14].TestNumber := 14;
         "DB_TestResults_Supervisor".Results[14].Passed := #testPassed;


      // ============================================================
      // TEST 15: Запуск декількох маршрутів
      // ============================================================
      15:
         #testName := 'TEST 15: START multiple routes';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1500;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1500;
         "DB_PlcToScada_RouteStatus".RoutesSts[3].RS_State := ROUTE_STS_IDLE;
         "DB_PlcToScada_RouteStatus".RoutesSts[4].RS_State := ROUTE_STS_IDLE;
         "DB_PlcToScada_RouteStatus".RoutesSts[5].RS_State := ROUTE_STS_IDLE;
         
         // ACT: Запуск 3 маршрутів по черзі
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 3;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 2;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1501;
         "FC_Route_Supervisor"();
         
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 4;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 3;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1502;
         "FC_Route_Supervisor"();
         
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 5;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 4;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1503;
         "FC_Route_Supervisor"();
         
         // ASSERT: Всі 3 маршрути отримали команди
         #testPassed := TRUE;
         IF "DB_Plc_RouteExecutor".Routes[3].RC_StepCount <> 2 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[4].RC_StepCount <> 3 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[5].RC_StepCount <> 4 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1503 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[15].TestNumber := 15;
         "DB_TestResults_Supervisor".Results[15].Passed := #testPassed;


      // ============================================================
      // TEST 16: Невідомий код команди
      // ============================================================
      16:
         #testName := 'TEST 16: Unknown command code';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1600;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1600;
         "DB_PlcToScada_RouteStatus".RoutesSts[6].RS_State := ROUTE_STS_IDLE;
         "DB_Plc_RouteExecutor".Routes[6].RC_Cmd := RT_CMD_NONE;
         "DB_Plc_RouteExecutor".Routes[6].RC_StepCount := 0;
         
         // ACT: Невідома команда (99)
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 6;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := 99;  // Невідома
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 5;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1601;
         
         "FC_Route_Supervisor"();
         
         // ASSERT: ACK надіслано, але команда не скопійована
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1601 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[6].RC_Cmd <> RT_CMD_NONE THEN  // Не змінено
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[6].RC_StepCount <> 0 THEN  // Не змінено
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[16].TestNumber := 16;
         "DB_TestResults_Supervisor".Results[16].Passed := #testPassed;


      // ============================================================
      // TEST 17: RouteId = 0 (нижня межа)
      // ============================================================
      17:
         #testName := 'TEST 17: RouteId boundary test (0)';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1700;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1700;
         
         // ACT
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 0;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1701;
         
         "FC_Route_Supervisor"();
         
         // ASSERT: ACK не надіслано
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1700 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[17].TestNumber := 17;
         "DB_TestResults_Supervisor".Results[17].Passed := #testPassed;


      // ============================================================
      // TEST 18: RouteId = 13 (верхня межа + 1)
      // ============================================================
      18:
         #testName := 'TEST 18: RouteId boundary test (13)';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1800;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1800;
         
         // ACT
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 13;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1801;
         
         "FC_Route_Supervisor"();
         
         // ASSERT
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".ACK_CommitApplied <> 1800 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[18].TestNumber := 18;
         "DB_TestResults_Supervisor".Results[18].Passed := #testPassed;


      // ============================================================
      // TEST 19: RS_Warning збереження між циклами
      // ============================================================
      19:
         #testName := 'TEST 19: RS_Warning persistence';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1900;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 1900;
         "DB_PlcToScada_RouteStatus".RoutesSts[7].RS_State := ROUTE_STS_RUNNING;
         "DB_PlcToScada_RouteStatus".RoutesSts[7].RS_Warning := RS_WARNING_OK;
         "DB_Plc_RouteFsm".RoutesFsm[7].RF_State := ROUTE_STS_RUNNING;
         "DB_Plc_RouteExecutor".Routes[7].RC_Cmd := RT_CMD_NONE;
         
         // ACT 1: Дублікат START → встановлює Warning
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 7;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 3;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 1901;
         
         "FC_Route_Supervisor"();
         
         // ACT 2: Наступний цикл без нової команди
         "FC_Route_Supervisor"();
         
         // ASSERT: Warning зберігся
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[7].RS_Warning <> RS_WARNING_IGNORED_CMD THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[19].TestNumber := 19;
         "DB_TestResults_Supervisor".Results[19].Passed := #testPassed;


      // ============================================================
      // TEST 20: RS_Warning скидається для нової команди
      // ============================================================
      20:
         #testName := 'TEST 20: RS_Warning cleared on new command';
         
         // ARRANGE: Warning встановлено з попереднього разу
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 2000;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 2000;
         "DB_PlcToScada_RouteStatus".RoutesSts[8].RS_State := ROUTE_STS_IDLE;
         "DB_PlcToScada_RouteStatus".RoutesSts[8].RS_Warning := RS_WARNING_IGNORED_CMD;  // Старий
         "DB_Plc_RouteExecutor".Routes[8].RC_Cmd := RT_CMD_NONE;
         
         // ACT: Валідна команда START
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 8;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 2;
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 2001;
         
         "FC_Route_Supervisor"();
         
         // ASSERT: Warning скинуто
         #testPassed := TRUE;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[8].RS_Warning <> RS_WARNING_OK THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[8].RC_Cmd <> RT_CMD_START THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[20].TestNumber := 20;
         "DB_TestResults_Supervisor".Results[20].Passed := #testPassed;


       // ============================================================
      // TEST 21: Cleanup StepCount після IDLE (ВИПРАВЛЕНИЙ)
      // ============================================================
      21:
         #testName := 'TEST 21: Cleanup StepCount after IDLE';
         
         // ARRANGE: Маршрут у IDLE, команда вже очищена (RC_Cmd=NONE)
         // але StepCount залишився з попереднього виконання
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 2100;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 2100;
         "DB_PlcToScada_RouteStatus".RoutesSts[9].RS_State := ROUTE_STS_IDLE;
         "DB_Plc_RouteFsm".RoutesFsm[9].RF_State := ROUTE_STS_IDLE;
         
         // ✅ Команда вже очищена (з попереднього циклу cleanup)
         "DB_Plc_RouteExecutor".Routes[9].RC_Cmd := RT_CMD_NONE;
         "DB_Plc_RouteExecutor".Routes[9].RC_StepCount := 5;  // Залишки
         
         // ACT: Supervisor виконується (без нової команди)
         "FC_Route_Supervisor"();
         
         // ASSERT: StepCount має бути очищено
         #testPassed := TRUE;
         IF "DB_Plc_RouteExecutor".Routes[9].RC_Cmd <> RT_CMD_NONE THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[9].RC_StepCount <> 0 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[21].TestNumber := 21;
         "DB_TestResults_Supervisor".Results[21].Passed := #testPassed;


      // ============================================================
      // TEST 22: Cleanup StepCount після ABORTED (ВИПРАВЛЕНИЙ)
      // ============================================================
      22:
         #testName := 'TEST 22: Cleanup StepCount after ABORTED';
         
         // ARRANGE: Маршрут у ABORTED, команда вже очищена
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 2200;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 2200;
         "DB_PlcToScada_RouteStatus".RoutesSts[10].RS_State := ROUTE_STS_ABORTED;
         "DB_Plc_RouteFsm".RoutesFsm[10].RF_State := ROUTE_STS_ABORTED;
         
         // ✅ Команда вже очищена
         "DB_Plc_RouteExecutor".Routes[10].RC_Cmd := RT_CMD_NONE;
         "DB_Plc_RouteExecutor".Routes[10].RC_StepCount := 4;  // Залишки
         
         // ACT
         "FC_Route_Supervisor"();
         
         // ASSERT
         #testPassed := TRUE;
         IF "DB_Plc_RouteExecutor".Routes[10].RC_Cmd <> RT_CMD_NONE THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[10].RC_StepCount <> 0 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[22].TestNumber := 22;
         "DB_TestResults_Supervisor".Results[22].Passed := #testPassed;


      // ============================================================
      // TEST 23: Без cleanup для активних маршрутів
      // ============================================================
      23:
         #testName := 'TEST 23: No cleanup for active routes';
         
         // ARRANGE: Маршрут RUNNING
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 2300;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 2300;
         "DB_PlcToScada_RouteStatus".RoutesSts[11].RS_State := ROUTE_STS_RUNNING;
         "DB_Plc_RouteFsm".RoutesFsm[11].RF_State := ROUTE_STS_RUNNING;
         "DB_Plc_RouteExecutor".Routes[11].RC_Cmd := RT_CMD_START;
         "DB_Plc_RouteExecutor".Routes[11].RC_StepCount := 3;
         
         // ACT: Supervisor виконується без нової команди
         "FC_Route_Supervisor"();
         
         // ASSERT: Команда НЕ очищена
         #testPassed := TRUE;
         IF "DB_Plc_RouteExecutor".Routes[11].RC_Cmd <> RT_CMD_START THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[11].RC_StepCount <> 3 THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[23].TestNumber := 23;
         "DB_TestResults_Supervisor".Results[23].Passed := #testPassed;


      // ============================================================
      // TEST 24: StepCount оновлюється при START
      // ============================================================
      24:
         #testName := 'TEST 24: StepCount update on START';
         
         // ARRANGE
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 2400;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 2400;
         "DB_PlcToScada_RouteStatus".RoutesSts[12].RS_State := ROUTE_STS_IDLE;
         "DB_Plc_RouteExecutor".Routes[12].RC_Cmd := RT_CMD_NONE;
         "DB_Plc_RouteExecutor".Routes[12].RC_StepCount := 3;  // Старе значення
         
         // ACT: START з новим StepCount
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 12;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 7;  // Новий
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 2401;
         
         "FC_Route_Supervisor"();
         
         // ASSERT: StepCount оновлено
         #testPassed := TRUE;
         IF "DB_Plc_RouteExecutor".Routes[12].RC_StepCount <> 7 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_Plc_RouteExecutor".Routes[12].RC_Cmd <> RT_CMD_START THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[24].TestNumber := 24;
         "DB_TestResults_Supervisor".Results[24].Passed := #testPassed;


      // ============================================================
      // TEST 25: StepCount зберігається при відхиленні START
      // ============================================================
      25:
         #testName := 'TEST 25: StepCount preserved on rejected START';
         
         // ARRANGE: Маршрут RUNNING
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 2500;
         "DB_PlcToScada_RouteStatus".ACK_CommitApplied := 2500;
         "DB_PlcToScada_RouteStatus".RoutesSts[1].RS_State := ROUTE_STS_RUNNING;
         "DB_PlcToScada_RouteStatus".RoutesSts[1].RS_Warning := RS_WARNING_OK;
         "DB_Plc_RouteFsm".RoutesFsm[1].RF_State := ROUTE_STS_RUNNING;
         "DB_Plc_RouteExecutor".Routes[1].RC_Cmd := RT_CMD_NONE;
         "DB_Plc_RouteExecutor".Routes[1].RC_StepCount := 5;  // Поточний
         
         // ACT: Дублікат START з новим StepCount
         "DB_ScadaToPlc_RouteCmd".HDR_RouteId := 1;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_Cmd := RT_CMD_START;
         "DB_ScadaToPlc_RouteCmd".CMD_Route.RC_StepCount := 10;  // Не має копіюватись
         "DB_ScadaToPlc_RouteCmd".HDR_Commit := 2501;
         
         "FC_Route_Supervisor"();
         
         // ASSERT: StepCount НЕ змінено
         #testPassed := TRUE;
         IF "DB_Plc_RouteExecutor".Routes[1].RC_StepCount <> 5 THEN
             #testPassed := FALSE;
         END_IF;
         IF "DB_PlcToScada_RouteStatus".RoutesSts[1].RS_Warning <> RS_WARNING_IGNORED_CMD THEN
             #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_Supervisor".Results[25].TestNumber := 25;
         "DB_TestResults_Supervisor".Results[25].Passed := #testPassed;

         
      ELSE
         #testName := 'UNKNOWN TEST';
         #testPassed := FALSE;
   END_CASE;
   
END_FUNCTION
