FUNCTION_BLOCK "FB_TestRunner_Supervisor"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.2
   VAR_INPUT 
      Start : Bool;              // Запустити всі тести
      RunSingleTest : Bool;      // Запустити один тест
      TestNumber : USInt;        // Номер тесту для одиночного запуску
      Reset : Bool;              // Скинути результати
   END_VAR

   VAR_OUTPUT 
      Running : Bool;            // Тести виконуються
      Done : Bool;               // Всі тести завершені
      AllPassed : Bool;          // Всі тести пройшли
      CurrentTestNum : USInt;    // Поточний тест
   END_VAR

   VAR 
      // Внутрішній стан
      state : Int := 0;
      currentTest : USInt := 0;
      
      // Edge detection
      startTrig : Bool := FALSE;
      singleTestTrig : Bool := FALSE;
      resetTrig : Bool := FALSE;
   END_VAR

   VAR_TEMP 
      i : Int;
   END_VAR

BEGIN
   // =================================================================
   // TEST RUNNER для автоматичного виконання всіх тестів Supervisor
   // Version 0.2: ВИПРАВЛЕНО - додано скидання лічильників
   // =================================================================
   
   // Edge detection для Start
   IF #Start AND NOT #startTrig THEN
      #state := 10;  // Почати виконання всіх тестів
      "DB_TestResults_Supervisor".CurrentTest := 1;
      
      // ✅ ВИПРАВЛЕННЯ: Обнулити лічильники перед запуском
      "DB_TestResults_Supervisor".PassedTests := 0;
      "DB_TestResults_Supervisor".FailedTests := 0;
      "DB_TestResults_Supervisor".AllTestsRun := FALSE;
      
      // ✅ ВИПРАВЛЕННЯ: Очистити всі попередні результати
      FOR #i := 1 TO 25 DO
         "DB_TestResults_Supervisor".Results[#i].Passed := FALSE;
         "DB_TestResults_Supervisor".Results[#i].ErrorCode := 0;
      END_FOR;
      
      #Running := TRUE;
      #Done := FALSE;
   END_IF;
   #startTrig := #Start;
   
   // Edge detection для RunSingleTest
   IF #RunSingleTest AND NOT #singleTestTrig THEN
      IF #TestNumber >= 1 AND #TestNumber <= 25 THEN
         #state := 20;  // Запустити один тест
         "DB_TestResults_Supervisor".CurrentTest := #TestNumber;
         
         // ✅ ВИПРАВЛЕННЯ: Очистити результат тесту перед запуском
         "DB_TestResults_Supervisor".Results[#TestNumber].Passed := FALSE;
         "DB_TestResults_Supervisor".Results[#TestNumber].ErrorCode := 0;
         
         #Running := TRUE;
         #Done := FALSE;
      END_IF;
   END_IF;
   #singleTestTrig := #RunSingleTest;
   
   // Edge detection для Reset
   IF #Reset AND NOT #resetTrig THEN
      #state := 0;
      #Running := FALSE;
      #Done := FALSE;
      #AllPassed := FALSE;
      "DB_TestResults_Supervisor".CurrentTest := 0;
      "DB_TestResults_Supervisor".PassedTests := 0;
      "DB_TestResults_Supervisor".FailedTests := 0;
      "DB_TestResults_Supervisor".AllTestsRun := FALSE;
      
      // Очистити результати
      FOR #i := 1 TO 15 DO
         "DB_TestResults_Supervisor".Results[#i].Passed := FALSE;
         "DB_TestResults_Supervisor".Results[#i].ErrorCode := 0;
      END_FOR;
   END_IF;
   #resetTrig := #Reset;
   
   // =================================================================
   // STATE MACHINE
   // =================================================================
   CASE #state OF
      
      // ============================================================
      // STATE 0: IDLE
      // ============================================================
      0:
         #Running := FALSE;
         #Done := FALSE;
         #CurrentTestNum := 0;
      
      
      // ============================================================
      // STATE 10: Виконання всіх тестів послідовно
      // ============================================================
      10:
         #currentTest := "DB_TestResults_Supervisor".CurrentTest;
         #CurrentTestNum := #currentTest;
         
         IF #currentTest <= "DB_TestResults_Supervisor".TotalTests THEN
            // Підготовка тестових даних
            #state := 11;  // Setup test
         ELSE
            // Всі тести виконані
            #state := 90;  // Завершення
         END_IF;
      
      
      // ============================================================
      // STATE 11: Setup та виконання тесту
      // ============================================================
      11:
         // Виклик тесту
         "FC_Test_RouteSupervisor"(
            TestNumber := #currentTest
         );
         
         #state := 12;  // Перехід до перевірки результату
      
      
      // ============================================================
      // STATE 12: Перевірка результату тесту
      // ============================================================
      12:
         // ✅ ВИПРАВЛЕННЯ: Коректний підрахунок
         // Перевірити результат ТІЛЬКИ ОДИН РАЗ для кожного тесту
         
         IF "DB_TestResults_Supervisor".Results[#currentTest].Passed THEN
            "DB_TestResults_Supervisor".PassedTests := 
               "DB_TestResults_Supervisor".PassedTests + 1;
         ELSE
            "DB_TestResults_Supervisor".FailedTests := 
               "DB_TestResults_Supervisor".FailedTests + 1;
         END_IF;
         
         // Наступний тест
         "DB_TestResults_Supervisor".CurrentTest := #currentTest + 1;
         #state := 10;
      
      
      // ============================================================
      // STATE 20: Виконання одного тесту
      // ============================================================
      20:
         #currentTest := "DB_TestResults_Supervisor".CurrentTest;
         #CurrentTestNum := #currentTest;
         
         // Виклик тесту
         "FC_Test_RouteSupervisor"(
            TestNumber := #currentTest
         );
         
         #state := 21;
      
      
      // ============================================================
      // STATE 21: Результат одиночного тесту
      // ============================================================
      21:
         #Running := FALSE;
         #Done := TRUE;
         
         // Оновити статистику для одиночного тесту
         IF "DB_TestResults_Supervisor".Results[#currentTest].Passed THEN
            #AllPassed := TRUE;
         ELSE
            #AllPassed := FALSE;
         END_IF;
         
         #state := 0;
      
      
      // ============================================================
      // STATE 90: Завершення всіх тестів
      // ============================================================
      90:
         "DB_TestResults_Supervisor".AllTestsRun := TRUE;
         #Running := FALSE;
         #Done := TRUE;
         
         // Перевірити чи всі тести пройшли
         IF "DB_TestResults_Supervisor".FailedTests = 0 THEN
            #AllPassed := TRUE;
         ELSE
            #AllPassed := FALSE;
         END_IF;
         
         #state := 0;  // Повернутись в IDLE
      
   END_CASE;
   
END_FUNCTION_BLOCK
