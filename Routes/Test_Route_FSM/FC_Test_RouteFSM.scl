FUNCTION "FC_Test_RouteFSM" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.1
   VAR_INPUT 
      TestNumber : USInt;   // Номер тесту для виконання
   END_VAR

   VAR_TEMP 
      i : Int;
      testPassed : Bool;
      testName : String[100];
      
      // Тестові дані
      routeIdx : USInt;
      cmd : "UDT_RouteCmd";
      fsm : "UDT_RouteFsm";
      sts : "UDT_RouteStatus";
      
      // Очікування
      Exp_State : UINT;
      Exp_ResultCode : UINT;
      Exp_ActiveStep : USINT;
      Exp_Owner : USINT;
   END_VAR

BEGIN
   // ===================================================================
   // TEST SUITE для FC_RouteFSM v2.0.1
   // ===================================================================
   // Версія: 1.1 - ВИПРАВЛЕНО: cleanup перед КОЖНИМ тестом
   // Дата: 2026-02-05
   // 
   // ЗМІНИ у v1.1:
   // - Додано FC_ResetMechsForTest у всі 16 тестів
   // - Додано відсутні RC_Steps[].RS_Action у тестах C1, C5, C6
   // - Гарантований чистий стан перед кожним тестом
   // 
   // ПОКРИТТЯ:
   // - GROUP A: Базові переходи станів (тести 1-8)
   // - GROUP B: Safety Stop (тести 9-10)
   // - GROUP C: Валідація (тести 11-16)
   // - GROUP D: Atomic Lock (тести 17-19) - шаблони
   // - GROUP E: Виконання кроків (тести 20-24) - шаблони
   // - GROUP F: STOPPING логіка (тести 25-28) - шаблони
   // - GROUP G: Abort scenarios (тести 29-32) - шаблони
   // - GROUP H: Edge cases (тести 33-35) - шаблони
   // ===================================================================
   
   CASE #TestNumber OF
      
      // ============================================================
      // GROUP A: Базові переходи станів (8 тестів)
      // ============================================================
      
      // ============================================================
      // TEST A1: IDLE → VALIDATING (START edge)
      // ============================================================
      1:
         #testName := 'A1: IDLE -> VALIDATING (START edge)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: FSM у IDLE, прийшов START
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 2;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;
         
         #fsm.RF_State := ROUTE_STS_IDLE;
         #fsm.lastCmd := RT_CMD_NONE;
         
         // Очікування
         #Exp_State := ROUTE_STS_VALIDATING;
         
         // ACT: Викликати FSM один раз
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[1].TestNumber := 1;
         "DB_TestResults_RouteFSM".Results[1].Passed := #testPassed;
      
      
      // ============================================================
      // TEST A2: VALIDATING → STARTING (validation OK)
      // ============================================================
      2:
         #testName := 'A2: VALIDATING -> STARTING (validation OK)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: FSM у VALIDATING, механізми готові
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;
         
         #fsm.RF_State := ROUTE_STS_VALIDATING;
         #fsm.lastCmd := RT_CMD_START;
         
         // Механізм вільний і готовий (вже встановлено FC_ResetMechsForTest)
         // Додаткові налаштування не потрібні
         
         // Очікування
         #Exp_State := ROUTE_STS_STARTING;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[2].TestNumber := 2;
         "DB_TestResults_RouteFSM".Results[2].Passed := #testPassed;
      
      
      // ============================================================
      // TEST A3: VALIDATING → REJECTED (owner busy)
      // ============================================================
      3:
         #testName := 'A3: VALIDATING -> REJECTED (owner busy)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: Механізм зайнято
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;  // ✅ ДОДАНО
         
         #fsm.RF_State := ROUTE_STS_VALIDATING;
         #fsm.lastCmd := RT_CMD_START;
         
         // Механізм зайнято іншим маршрутом
         "DB_Mechs".Mechs[0].OwnerCur := OWNER_ROUTE;
         "DB_Mechs".Mechs[0].OwnerCurId := 2;  // інший маршрут
         
         // Очікування
         #Exp_State := ROUTE_STS_REJECTED;
         #Exp_ResultCode := ROUTE_REJ_BY_OWNER;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[3].TestNumber := 3;
         "DB_TestResults_RouteFSM".Results[3].Passed := #testPassed;
      
      
      // ============================================================
      // TEST A4: STARTING → RUNNING (lock OK)
      // ============================================================
      4:
         #testName := 'A4: STARTING -> RUNNING (lock OK)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: FSM у STARTING
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;  // ✅ ДОДАНО
         
         #fsm.RF_State := ROUTE_STS_STARTING;
         #fsm.lastCmd := RT_CMD_START;
         
         // Механізм вільний (вже встановлено FC_ResetMechsForTest)
         
         // Очікування
         #Exp_State := ROUTE_STS_RUNNING;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         // Перевірити що owner встановлено
         IF "DB_Mechs".Mechs[0].OwnerCur <> OWNER_ROUTE THEN
            #testPassed := FALSE;
         END_IF;
         IF "DB_Mechs".Mechs[0].OwnerCurId <> #routeIdx THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[4].TestNumber := 4;
         "DB_TestResults_RouteFSM".Results[4].Passed := #testPassed;
      
      
      // ============================================================
      // TEST A5: STARTING → REJECTED (lock fail)
      // ============================================================
      5:
         #testName := 'A5: STARTING -> REJECTED (lock fail, race)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         "FC_ResetMechsForTest"(SlotIndex := 1);
         
         // ARRANGE: FSM у STARTING, але один механізм раптом зайнято (race)
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 2;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;  // ✅ ДОДАНО
         #cmd.RC_Steps[1].RS_Slot := 1;
         #cmd.RC_Steps[1].RS_Action := RS_ACT_START;
         #cmd.RC_Steps[1].RS_Wait := RS_WAIT_RUNNING;  // ✅ ДОДАНО
         
         #fsm.RF_State := ROUTE_STS_STARTING;
         #fsm.lastCmd := RT_CMD_START;
         
         // Перший механізм вільний, другий раптом зайнято
         "DB_Mechs".Mechs[1].OwnerCur := OWNER_SCADA;  // ❌ race condition
         
         // Очікування
         #Exp_State := ROUTE_STS_REJECTED;
         #Exp_ResultCode := ROUTE_REJ_BY_OWNER;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         // Перевірити rollback: перший механізм має бути звільнено
         IF "DB_Mechs".Mechs[0].OwnerCur <> OWNER_NONE THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[5].TestNumber := 5;
         "DB_TestResults_RouteFSM".Results[5].Passed := #testPassed;
      
      
      // ============================================================
      // TEST A6: RUNNING → RUNNING (all steps done)
      // ============================================================
      6:
         #testName := 'A6: RUNNING -> RUNNING (all done)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: FSM у RUNNING, виконані всі кроки
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;
         
         #fsm.RF_State := ROUTE_STS_RUNNING;
         #fsm.lastCmd := RT_CMD_START;
         #fsm.RF_ActiveStep := 1;  // вже виконано всі кроки (StepCount=1)
         
         // Механізм належить маршруту
         "DB_Mechs".Mechs[0].OwnerCur := OWNER_ROUTE;
         "DB_Mechs".Mechs[0].OwnerCurId := 1;
         "DB_Mechs".Mechs[0].Status := STS_RUNNING;
         
         // Очікування
         #Exp_State := ROUTE_STS_RUNNING;
         #Exp_ResultCode := 200;  // ROUTE_OK_DONE
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[6].TestNumber := 6;
         "DB_TestResults_RouteFSM".Results[6].Passed := #testPassed;
      
      
      // ============================================================
      // TEST A7: RUNNING → STOPPING (STOP_OP)
      // ============================================================
      7:
         #testName := 'A7: RUNNING -> STOPPING (STOP_OP)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: FSM у RUNNING, прийшов STOP_OP
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_STOP_OP;  // operator stop
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         
         #fsm.RF_State := ROUTE_STS_RUNNING;
         #fsm.lastCmd := RT_CMD_START;  // попередня команда була START
         
         // Механізм належить маршруту
         "DB_Mechs".Mechs[0].OwnerCur := OWNER_ROUTE;
         "DB_Mechs".Mechs[0].OwnerCurId := 1;
         "DB_Mechs".Mechs[0].Status := STS_RUNNING;
         
         // Очікування
         #Exp_State := ROUTE_STS_STOPPING;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         // Перевірити що AbortLatched встановлено
         IF #fsm.RF_AbortLatched <> ROUTE_ABRT_BY_OPERATOR THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[7].TestNumber := 7;
         "DB_TestResults_RouteFSM".Results[7].Passed := #testPassed;
      
      
      // ============================================================
      // TEST A8: STOPPING → ABORTED (all stopped)
      // ============================================================
      8:
         #testName := 'A8: STOPPING -> ABORTED (all stopped)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: FSM у STOPPING, всі механізми зупинені
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_STOP_OP;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         
         #fsm.RF_State := ROUTE_STS_STOPPING;
         #fsm.lastCmd := RT_CMD_STOP_OP;
         #fsm.RF_AbortLatched := ROUTE_ABRT_BY_OPERATOR;
         
         // Механізм зупинено
         "DB_Mechs".Mechs[0].OwnerCur := OWNER_ROUTE;
         "DB_Mechs".Mechs[0].OwnerCurId := 1;
         "DB_Mechs".Mechs[0].Status := STS_IDLE;  // зупинено
         
         // Очікування
         #Exp_State := ROUTE_STS_ABORTED;
         #Exp_ResultCode := ROUTE_ABRT_BY_OPERATOR;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         // Перевірити що owner звільнено
         IF "DB_Mechs".Mechs[0].OwnerCur <> OWNER_NONE THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[8].TestNumber := 8;
         "DB_TestResults_RouteFSM".Results[8].Passed := #testPassed;
      
      
      // ============================================================
      // GROUP B: Safety Stop (2 тести)
      // ============================================================
      
      // ============================================================
      // TEST B1: Safety Stop during RUNNING → ABORTED (immediate)
      // ============================================================
      9:
         #testName := 'B1: Safety Stop during RUNNING';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: FSM у RUNNING, GlobalSafetyStop=TRUE
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         
         #fsm.RF_State := ROUTE_STS_RUNNING;
         #fsm.lastCmd := RT_CMD_START;
         
         // Механізм належить маршруту
         "DB_Mechs".Mechs[0].OwnerCur := OWNER_ROUTE;
         "DB_Mechs".Mechs[0].OwnerCurId := 1;
         
         // Очікування
         #Exp_State := ROUTE_STS_ABORTED;
         #Exp_ResultCode := ROUTE_ABRT_BY_SAFETY;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := TRUE,  // ❌ аварійна зупинка
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[9].TestNumber := 9;
         "DB_TestResults_RouteFSM".Results[9].Passed := #testPassed;
      
      
      // ============================================================
      // TEST B2: Safety Stop during STARTING → ABORTED (immediate)
      // ============================================================
      10:
         #testName := 'B2: Safety Stop during STARTING';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: FSM у STARTING
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         
         #fsm.RF_State := ROUTE_STS_STARTING;
         
         // Очікування
         #Exp_State := ROUTE_STS_ABORTED;
         #Exp_ResultCode := ROUTE_ABRT_BY_SAFETY;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := TRUE,  // ❌ аварійна зупинка
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[10].TestNumber := 10;
         "DB_TestResults_RouteFSM".Results[10].Passed := #testPassed;
      
      
      // ============================================================
      // GROUP C: Валідація (6 тестів)
      // ============================================================
      
      // ============================================================
      // TEST C1: Duplicate START → REJECTED (205)
      // ============================================================
      11:
         #testName := 'C1: Duplicate START -> REJECTED (205)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: FSM у VALIDATING, другий START прийшов
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;  // ✅ ДОДАНО
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;  // ✅ ДОДАНО
         
         #fsm.RF_State := ROUTE_STS_VALIDATING;
         #fsm.lastCmd := RT_CMD_START;  // вже був START
         
         // Очікування
         #Exp_State := ROUTE_STS_REJECTED;
         #Exp_ResultCode := ROUTE_REJ_DUPLICATE_START;
         
         // ACT: detectEdge побачить що команда не змінилась
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[11].TestNumber := 11;
         "DB_TestResults_RouteFSM".Results[11].Passed := #testPassed;
      
      
      // ============================================================
      // TEST C2: Invalid StepCount=0 → REJECTED
      // ============================================================
      12:
         #testName := 'C2: Invalid StepCount=0 -> REJECTED';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: StepCount=0 (немає кроків)
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 0;  // ❌ невалідно
         
         #fsm.RF_State := ROUTE_STS_VALIDATING;
         #fsm.lastCmd := RT_CMD_START;
         
         // Очікування
         #Exp_State := ROUTE_STS_REJECTED;
         #Exp_ResultCode := ROUTE_REJ_BY_CONTRACT;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[12].TestNumber := 12;
         "DB_TestResults_RouteFSM".Results[12].Passed := #testPassed;
      
      
      // ============================================================
      // TEST C3: Invalid Action → REJECTED
      // ============================================================
      13:
         #testName := 'C3: Invalid Action -> REJECTED';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: Action не START і не STOP
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := 99;  // ❌ невалідне значення
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;
         
         #fsm.RF_State := ROUTE_STS_VALIDATING;
         #fsm.lastCmd := RT_CMD_START;
         
         // Очікування
         #Exp_State := ROUTE_STS_REJECTED;
         #Exp_ResultCode := ROUTE_REJ_BY_CONTRACT;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[13].TestNumber := 13;
         "DB_TestResults_RouteFSM".Results[13].Passed := #testPassed;
      
      
      // ============================================================
      // TEST C4: Invalid Wait → REJECTED
      // ============================================================
      14:
         #testName := 'C4: Invalid Wait -> REJECTED';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: Wait не RUNNING і не STOPPED
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;
         #cmd.RC_Steps[0].RS_Wait := 88;  // ❌ невалідне значення
         
         #fsm.RF_State := ROUTE_STS_VALIDATING;
         #fsm.lastCmd := RT_CMD_START;
         
         // Очікування
         #Exp_State := ROUTE_STS_REJECTED;
         #Exp_ResultCode := ROUTE_REJ_BY_CONTRACT;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[14].TestNumber := 14;
         "DB_TestResults_RouteFSM".Results[14].Passed := #testPassed;
      
      
      // ============================================================
      // TEST C5: Owner busy → REJECTED (202)
      // ============================================================
      15:
         #testName := 'C5: Owner busy -> REJECTED (202)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: Механізм зайнято SCADA
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;  // ✅ ДОДАНО
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;  // ✅ ДОДАНО
         
         #fsm.RF_State := ROUTE_STS_VALIDATING;
         #fsm.lastCmd := RT_CMD_START;
         
         "DB_Mechs".Mechs[0].OwnerCur := OWNER_SCADA;  // зайнято SCADA
         
         // Очікування
         #Exp_State := ROUTE_STS_REJECTED;
         #Exp_ResultCode := ROUTE_REJ_BY_OWNER;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[15].TestNumber := 15;
         "DB_TestResults_RouteFSM".Results[15].Passed := #testPassed;
      
      
      // ============================================================
      // TEST C6: Not ready (Enable_OK=0) → REJECTED (204)
      // ============================================================
      16:
         #testName := 'C6: Not ready (Enable_OK=0) -> REJECTED (204)';
         
         // ✅ CLEANUP: Очистити стан механізмів
         "FC_ResetMechsForTest"(SlotIndex := 0);
         
         // ARRANGE: Механізм не готовий
         #routeIdx := 1;
         #cmd.RC_Cmd := RT_CMD_START;
         #cmd.RC_StepCount := 1;
         #cmd.RC_Steps[0].RS_Slot := 0;
         #cmd.RC_Steps[0].RS_Action := RS_ACT_START;  // ✅ ДОДАНО
         #cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING;  // ✅ ДОДАНО
         
         #fsm.RF_State := ROUTE_STS_VALIDATING;
         #fsm.lastCmd := RT_CMD_START;
         
         "DB_Mechs".Mechs[0].Enable_OK := FALSE;  // ❌ не готовий
         
         // Очікування
         #Exp_State := ROUTE_STS_REJECTED;
         #Exp_ResultCode := ROUTE_REJ_NOT_READY;
         
         // ACT
         "FC_RouteFSM"(
            RouteIdx := #routeIdx,
            Cmd := #cmd,
            GlobalSafetyStop := FALSE,
            LocalManualGlobal := FALSE,
            Mechs := "DB_Mechs".Mechs,
            Fsm := #fsm,
            Sts => #sts
         );
         
         // ASSERT
         #testPassed := TRUE;
         IF #sts.RS_State <> #Exp_State THEN
            #testPassed := FALSE;
         END_IF;
         IF #sts.RS_ResultCode <> #Exp_ResultCode THEN
            #testPassed := FALSE;
         END_IF;
         
         "DB_TestResults_RouteFSM".Results[16].TestNumber := 16;
         "DB_TestResults_RouteFSM".Results[16].Passed := #testPassed;
      
      
      ELSE
         RETURN;
   END_CASE;
   
END_FUNCTION
