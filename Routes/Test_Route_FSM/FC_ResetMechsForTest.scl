FUNCTION "FC_ResetMechsForTest" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0
   VAR_INPUT 
      SlotIndex : USInt;   // Індекс механізму для очищення (0-199)
   END_VAR

BEGIN
   // ===================================================================
   // Допоміжна функція для скидання стану механізму між тестами
   // 
   // ПРИЗНАЧЕННЯ:
   // Кожен тест повинен викликати цю функцію в ARRANGE секції,
   // щоб гарантувати чистий початковий стан механізму.
   // 
   // ПРИКЛАД:
   //    // ARRANGE
   //    "FC_ResetMechsForTest"(SlotIndex := 0);
   //    "DB_Mechs".Mechs[0].OwnerCur := OWNER_ROUTE;  // тільки те що потрібно
   // ===================================================================
   
   IF #SlotIndex <= 199 THEN
      // Очистити ownership
      "DB_Mechs".Mechs[#SlotIndex].OwnerCur := OWNER_NONE;
      "DB_Mechs".Mechs[#SlotIndex].OwnerCurId := 0;
      
      // Очистити статус
      "DB_Mechs".Mechs[#SlotIndex].Status := STS_IDLE;
      "DB_Mechs".Mechs[#SlotIndex].Enable_OK := TRUE;
      "DB_Mechs".Mechs[#SlotIndex].LocalManual := FALSE;
      
      // Очистити помилки
      "DB_Mechs".Mechs[#SlotIndex].FLTCode := 0;
      
      // Встановити тип за замовчуванням
      "DB_Mechs".Mechs[#SlotIndex].DeviceType := TYPE_REDLER;
      "DB_Mechs".Mechs[#SlotIndex].TypedIndex := 0;
      
      // Очистити команди
      "DB_Mechs".Mechs[#SlotIndex].Cmd := CMD_NONE;
      "DB_Mechs".Mechs[#SlotIndex].CmdParam1 := 0;

   END_IF;
   
END_FUNCTION
