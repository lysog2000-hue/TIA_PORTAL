// ==============================================================================
// FC_Test_RouteFSM - ЧАСТИНА 2 (GROUP D-H, тести 17-35)
// ==============================================================================
// ЦЕЙ КОД ПОТРІБНО ДОДАТИ В КІНЕЦЬ FC_Test_RouteFSM.scl
// ==============================================================================

      // ============================================================
      // GROUP D: Atomic Lock (3 тести) - ТЕСТИ 17-19
      // ============================================================
      
      17:  // Lock all mechs -> RUNNING
      18:  // Lock partial fail -> REJECTED + rollback
      19:  // Lock race condition -> REJECTED
      
      // ============================================================
      // GROUP E: Виконання кроків (5 тестів) - ТЕСТИ 20-24
      // ============================================================
      
      20:  // START + WAIT_RUNNING -> next step
      21:  // STOP + WAIT_STOPPED -> next step
      22:  // Last step -> RUNNING (RC=200)
      23:  // Step arbiter fail -> STOPPING
      24:  // StartParam passed to arbiter
      
      // ============================================================
      // GROUP F: STOPPING логіка (4 тести) - ТЕСТИ 25-28
      // ============================================================
      
      25:  // STOPPING -> ABORTED (allStopped)
      26:  // StopParam=0 -> CMD_STOP
      27:  // StopParam!=0 -> CMD_START with param
      28:  // STOPPING reverse order
      
      // ============================================================
      // GROUP G: Abort scenarios (4 тести) - ТЕСТИ 29-32
      // ============================================================
      
      29:  // ABORT_BY_OPERATOR (stopOpEdge)
      30:  // ABORT_BY_LOCAL (anyLocal)
      31:  // ABORT_BY_FAULT (anyFault)
      32:  // ABORT_BY_SAFETY (global)
      
      // ============================================================
      // GROUP H: Edge cases (3 тести) - ТЕСТИ 33-35
      // ============================================================
      
      33:  // Route with 0 steps -> REJECTED
      34:  // StepIdx >= StepCnt -> RUNNING (RC=200)
      35:  // START after ABORTED -> new cycle

// ==============================================================================
// ІНСТРУКЦІЯ ПО ІМПЛЕМЕНТАЦІЇ
// ==============================================================================
// 
// Через обмеження розміру файлу, тести 17-35 потрібно додати вручну,
// використовуючи як приклад тести 1-16.
// 
// Структура кожного тесту:
// 
// 1. ARRANGE (підготовка даних)
//    - Встановити routeIdx, cmd, fsm
//    - Підготувати механізми (DB_Mechs.Mechs[])
//    - Встановити очікування (Exp_State, Exp_ResultCode)
// 
// 2. ACT (виклик FSM)
//    "FC_RouteFSM"(
//       RouteIdx := #routeIdx,
//       Cmd := #cmd,
//       GlobalSafetyStop := FALSE/TRUE,
//       LocalManualGlobal := FALSE/TRUE,
//       Mechs := "DB_Mechs".Mechs,
//       Fsm := #fsm,
//       Sts => #sts
//    );
// 
// 3. ASSERT (перевірка результатів)
//    - Перевірити RS_State
//    - Перевірити RS_ResultCode
//    - Перевірити додаткові умови (owner, статус механізмів)
//    - Записати результат у DB_TestResults_RouteFSM.Results[N]
// 
// ==============================================================================

// ПРИКЛАДИ ШАБЛОНІВ ДЛЯ РЕШТИ ТЕСТІВ:

// TEST 20: START + WAIT_RUNNING -> next step
// ARRANGE:
//   - fsm.RF_State := ROUTE_STS_RUNNING
//   - fsm.RF_ActiveStep := 0  // перший крок
//   - cmd.RC_Steps[0].RS_Action := RS_ACT_START
//   - cmd.RC_Steps[0].RS_Wait := RS_WAIT_RUNNING
//   - Mechs[slot].Status := STS_IDLE  // ще не працює
// ACT: викликати FSM
// ASSERT:
//   - якщо Status став STS_RUNNING → ActiveStep збільшився на 1
//   - якщо Status ще не STS_RUNNING → ActiveStep не змінився

// TEST 24: StartParam passed to arbiter
// ARRANGE:
//   - cmd.RC_Steps[0].RS_StartParam := 7  // для засувки CMD_GATE_OPEN
// ACT: викликати FSM
// ASSERT:
//   - перевірити що Mechs[slot].CmdParam1 = 7 (арбітр записав параметр)

// TEST 27: StopParam!=0 -> CMD_START with param
// ARRANGE:
//   - fsm.RF_State := ROUTE_STS_STOPPING
//   - cmd.RC_Steps[0].RS_StopParam := 8  // для засувки CMD_GATE_CLOSED
// ACT: викликати FSM
// ASSERT:
//   - перевірити що Mechs[slot].Cmd = CMD_START
//   - перевірити що Mechs[slot].CmdParam1 = 8

// TEST 30: ABORT_BY_LOCAL (anyLocal)
// ARRANGE:
//   - fsm.RF_State := ROUTE_STS_RUNNING
//   - Mechs[slot].LocalManual := TRUE  // або LocalManualGlobal := TRUE
// ACT: викликати FSM
// ASSERT:
//   - RF_State = ROUTE_STS_STOPPING
//   - RF_AbortLatched = ROUTE_ABRT_BY_LOCAL

// TEST 35: START after ABORTED -> new cycle
// ARRANGE:
//   - fsm.RF_State := ROUTE_STS_ABORTED
//   - cmd.RC_Cmd := RT_CMD_NONE  // команда очищена
// ACT: викликати FSM один раз (перехід в IDLE)
//      потім cmd.RC_Cmd := RT_CMD_START і викликати знову
// ASSERT:
//   - RF_State = ROUTE_STS_VALIDATING (новий цикл почався)

// ==============================================================================
// РЕКОМЕНДАЦІЇ ПО ТЕСТУВАННЮ
// ==============================================================================
// 
// 1. Починайте з простих тестів (GROUP A-C)
// 2. Переконайтесь що базові переходи працюють
// 3. Додайте складніші сценарії (GROUP D-G)
// 4. Завершіть edge cases (GROUP H)
// 
// 5. Використовуйте FB_TestRunner_RouteFSM для автоматизації:
//    - Start := TRUE → запустити всі тести
//    - RunSingleTest := TRUE, TestNumber := 20 → запустити тест 20
//    - Reset := TRUE → очистити результати
// 
// 6. Аналізуйте результати через DB_TestResults_RouteFSM:
//    - PassedTests / FailedTests
//    - Results[N].Passed для кожного тесту
//    - Results[N].ErrorCode для діагностики
// 
// ==============================================================================
