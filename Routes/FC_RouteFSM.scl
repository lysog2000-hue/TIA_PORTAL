// ==============================================================================
// FC_RouteFSM - Керування маршрутом (Mailbox Pattern v2.0)
// ==============================================================================
// Версія: 2.0.1
// Дата: 2026-02-02
// ==============================================================================
// КЛЮЧОВІ ЗМІНИ v2.0.1:
//   ✅ ROUTE_STS_DONE ВИДАЛЕНО
//   ✅ RUNNING (4) тепер КІНЦЕВИЙ СТАН (не потребує переходу в DONE)
//   ✅ Механізми залишаються під Owner=ROUTE після завершення останнього кроку
//   ✅ ResultCode = ROUTE_OK_RUNNING (200) при успішному виконанні
//   ✅ Release ownership ТІЛЬКИ при ABORTED
// ==============================================================================

FUNCTION "FC_RouteFSM" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.0

VAR_INPUT
    RouteIdx          : USINT;
    Cmd               : "UDT_RouteCmd";
    GlobalSafetyStop  : BOOL;
    LocalManualGlobal : BOOL;
END_VAR

VAR_IN_OUT
    Mechs : ARRAY[0..MECHS_COUNT] OF "UDT_BaseMechanism";
    Fsm   : "UDT_RouteFsm";
END_VAR

VAR_OUTPUT
    Sts : "UDT_RouteStatus";
END_VAR

BEGIN
    Fsm.safetyHit := FALSE;

    Fsm.startEdge  := (Cmd.RC_Cmd = RT_CMD_START) AND (Fsm.lastCmd <> RT_CMD_START);
    Fsm.stopOpEdge := (Cmd.RC_Cmd = RT_CMD_STOP_OP) AND (Fsm.lastCmd <> RT_CMD_STOP_OP);
    Fsm.lastCmd := Cmd.RC_Cmd;

    Fsm.stepCnt := USINT_TO_INT(Cmd.RC_StepCount);
    IF Fsm.stepCnt < 0 THEN Fsm.stepCnt := 0; END_IF;
    IF Fsm.stepCnt > 64 THEN Fsm.stepCnt := 64; END_IF;

    IF Fsm.RF_State = 0 THEN
        Fsm.RF_State := ROUTE_STS_IDLE;
    END_IF;

    Fsm.anyFault := FALSE;
    Fsm.anyLocal := FALSE;

    IF Fsm.stepCnt > 0 THEN
        FOR Fsm.i := 0 TO Fsm.stepCnt - 1 DO
            Fsm.slot := Cmd.RC_Steps[Fsm.i].RS_Slot;

            IF Mechs[Fsm.slot].FLTCode <> 0 THEN
                Fsm.anyFault := TRUE;
            END_IF;

            IF LocalManualGlobal OR Mechs[Fsm.slot].LocalManual THEN
                Fsm.anyLocal := TRUE;
            END_IF;

            IF Fsm.anyFault AND Fsm.anyLocal THEN EXIT; END_IF;
        END_FOR;
    END_IF;

    IF GlobalSafetyStop THEN
        Fsm.safetyHit := TRUE;

        IF Fsm.stepCnt > 0 THEN
            FOR Fsm.i := 0 TO Fsm.stepCnt - 1 DO
                Fsm.slot := Cmd.RC_Steps[Fsm.i].RS_Slot;

                Fsm.dummyOk := "FC_ArbiterMech"(
                    LocalManualGlobal := LocalManualGlobal,
                    OwnerReq          := OWNER_ROUTE,
                    OwnerReqId        := USINT_TO_UINT(RouteIdx),
                    ReqCmd            := CMD_NONE,
                    ReqParam1         := 0,
                    ReleaseOwner      := TRUE,
                    LockOnly          := FALSE,
                    M                 := Mechs[Fsm.slot]
                );
            END_FOR;
        END_IF;

        Fsm.RF_State      := ROUTE_STS_ABORTED;
        Fsm.RF_ResultCode := ROUTE_ABRT_BY_SAFETY;
    END_IF;

    IF NOT Fsm.safetyHit THEN

        IF Fsm.RF_State = ROUTE_STS_IDLE THEN
            IF Fsm.startEdge THEN
                Fsm.RF_ResultCode   := 0;
                Fsm.RF_AbortLatched := 0;
                Fsm.RF_ActiveStep   := 0;
                Fsm.RF_StepSts      := STEP_STS_IDLE;
                Fsm.RF_State        := ROUTE_STS_VALIDATING;
            END_IF;

        ELSIF Fsm.RF_State = ROUTE_STS_VALIDATING THEN
            IF Fsm.startEdge THEN
                Fsm.RF_State      := ROUTE_STS_REJECTED;
                Fsm.RF_ResultCode := ROUTE_REJ_DUPLICATE_START;
            ELSE
                IF Fsm.stepCnt <= 0 THEN
                    Fsm.RF_State      := ROUTE_STS_REJECTED;
                    Fsm.RF_ResultCode := ROUTE_REJ_BY_CONTRACT;
                ELSE
                    FOR Fsm.i := 0 TO Fsm.stepCnt - 1 DO
                        Fsm.slot := Cmd.RC_Steps[Fsm.i].RS_Slot;
                        Fsm.stepOk := TRUE;

                        IF (Cmd.RC_Steps[Fsm.i].RS_Action <> RS_ACT_START)
                           AND (Cmd.RC_Steps[Fsm.i].RS_Action <> RS_ACT_STOP) THEN
                            Fsm.stepOk := FALSE;
                        END_IF;

                        IF (Cmd.RC_Steps[Fsm.i].RS_Wait <> RS_WAIT_RUNNING)
                           AND (Cmd.RC_Steps[Fsm.i].RS_Wait <> RS_WAIT_STOPPED) THEN
                            Fsm.stepOk := FALSE;
                        END_IF;

                        IF NOT Fsm.stepOk THEN
                            Fsm.RF_State      := ROUTE_STS_REJECTED;
                            Fsm.RF_ResultCode := ROUTE_REJ_BY_CONTRACT;
                            EXIT;
                        ELSIF Mechs[Fsm.slot].OwnerCur <> OWNER_NONE THEN
                            Fsm.RF_State      := ROUTE_STS_REJECTED;
                            Fsm.RF_ResultCode := ROUTE_REJ_BY_OWNER;
                            EXIT;
                        ELSIF (NOT Mechs[Fsm.slot].Enable_OK)
                              OR LocalManualGlobal
                              OR Mechs[Fsm.slot].LocalManual
                              OR (Mechs[Fsm.slot].FLTCode <> 0) THEN
                            Fsm.RF_State      := ROUTE_STS_REJECTED;
                            Fsm.RF_ResultCode := ROUTE_REJ_NOT_READY;
                            EXIT;
                        END_IF;
                    END_FOR;

                    IF Fsm.RF_State = ROUTE_STS_VALIDATING THEN
                        Fsm.RF_State := ROUTE_STS_STARTING;
                    END_IF;
                END_IF;
            END_IF;

        ELSIF Fsm.RF_State = ROUTE_STS_STARTING THEN
            Fsm.lockOkAll := TRUE;

            IF Fsm.stepCnt > 0 THEN
                FOR Fsm.i := 0 TO Fsm.stepCnt - 1 DO
                    Fsm.slot := Cmd.RC_Steps[Fsm.i].RS_Slot;

                    Fsm.lockOkOne := "FC_ArbiterMech"(
                        LocalManualGlobal := LocalManualGlobal,
                        OwnerReq          := OWNER_ROUTE,
                        OwnerReqId        := USINT_TO_UINT(RouteIdx),
                        ReqCmd            := CMD_NONE,
                        ReqParam1         := 0,
                        ReleaseOwner      := FALSE,
                        LockOnly          := TRUE,
                        M                 := Mechs[Fsm.slot]
                    );

                    IF NOT Fsm.lockOkOne THEN
                        Fsm.lockOkAll := FALSE;
                    END_IF;
                END_FOR;
            ELSE
                Fsm.lockOkAll := FALSE;
            END_IF;

            IF NOT Fsm.lockOkAll THEN
                IF Fsm.stepCnt > 0 THEN
                    FOR Fsm.i := 0 TO Fsm.stepCnt - 1 DO
                        Fsm.slot := Cmd.RC_Steps[Fsm.i].RS_Slot;

                        Fsm.dummyOk := "FC_ArbiterMech"(
                            LocalManualGlobal := LocalManualGlobal,
                            OwnerReq          := OWNER_ROUTE,
                            OwnerReqId        := USINT_TO_UINT(RouteIdx),
                            ReqCmd            := CMD_NONE,
                            ReqParam1         := 0,
                            ReleaseOwner      := TRUE,
                            LockOnly          := FALSE,
                            M                 := Mechs[Fsm.slot]
                        );
                    END_FOR;
                END_IF;

                Fsm.RF_State      := ROUTE_STS_REJECTED;
                Fsm.RF_ResultCode := ROUTE_REJ_BY_OWNER;
            ELSE
                Fsm.RF_State := ROUTE_STS_RUNNING;
            END_IF;

        ELSIF Fsm.RF_State = ROUTE_STS_RUNNING THEN
            IF Fsm.stopOpEdge THEN
                Fsm.RF_AbortLatched := ROUTE_ABRT_BY_OPERATOR;
                Fsm.RF_State := ROUTE_STS_STOPPING;
            ELSIF Fsm.anyLocal THEN
                Fsm.RF_AbortLatched := ROUTE_ABRT_BY_LOCAL;
                Fsm.RF_State := ROUTE_STS_STOPPING;
            ELSIF Fsm.anyFault THEN
                Fsm.RF_AbortLatched := ROUTE_ABRT_BY_FAULT;
                Fsm.RF_State := ROUTE_STS_STOPPING;
            ELSE
                Fsm.stepIdx := USINT_TO_INT(Fsm.RF_ActiveStep);

                IF Fsm.stepIdx >= Fsm.stepCnt THEN
                    // ✅ ЗМІНА v2.0.1: Залишаємось у RUNNING (БЕЗ переходу в DONE)
                    // Механізми залишаються під Owner=ROUTE
                    Fsm.RF_ResultCode := ROUTE_OK_RUNNING;  // 200
                    // Fsm.RF_State залишається RUNNING (4)

                ELSE
                    Fsm.slot := Cmd.RC_Steps[Fsm.stepIdx].RS_Slot;

                    IF Cmd.RC_Steps[Fsm.stepIdx].RS_Action = RS_ACT_START THEN
                        Fsm.cmdOk := "FC_ArbiterMech"(
                            LocalManualGlobal := LocalManualGlobal,
                            OwnerReq          := OWNER_ROUTE,
                            OwnerReqId        := USINT_TO_UINT(RouteIdx),
                            ReqCmd            := CMD_START,
                            ReqParam1         := Cmd.RC_Steps[Fsm.stepIdx].RS_StartParam,
                            ReleaseOwner      := FALSE,
                            LockOnly          := FALSE,
                            M                 := Mechs[Fsm.slot]
                        );
                    ELSE
                        Fsm.cmdOk := "FC_ArbiterMech"(
                            LocalManualGlobal := LocalManualGlobal,
                            OwnerReq          := OWNER_ROUTE,
                            OwnerReqId        := USINT_TO_UINT(RouteIdx),
                            ReqCmd            := CMD_STOP,
                            ReqParam1         := 0,
                            ReleaseOwner      := FALSE,
                            LockOnly          := FALSE,
                            M                 := Mechs[Fsm.slot]
                        );
                    END_IF;

                    IF NOT Fsm.cmdOk THEN
                        Fsm.RF_AbortLatched := ROUTE_ABRT_BY_OWNER;
                        Fsm.RF_State := ROUTE_STS_STOPPING;
                    ELSE
                        Fsm.RF_StepSts := STEP_STS_WORK;

                        IF Cmd.RC_Steps[Fsm.stepIdx].RS_Wait = RS_WAIT_RUNNING THEN
                            IF Mechs[Fsm.slot].Status = STS_RUNNING THEN
                                Fsm.RF_ActiveStep := Fsm.RF_ActiveStep + 1;
                                Fsm.RF_StepSts := STEP_STS_DONE;
                            END_IF;
                        ELSE
                            IF Mechs[Fsm.slot].Status = STS_IDLE THEN
                                Fsm.RF_ActiveStep := Fsm.RF_ActiveStep + 1;
                                Fsm.RF_StepSts := STEP_STS_DONE;
                            END_IF;
                        END_IF;
                    END_IF;
                END_IF;
            END_IF;

        ELSIF Fsm.RF_State = ROUTE_STS_STOPPING THEN
            IF Fsm.stepCnt > 0 THEN
                FOR Fsm.i := Fsm.stepCnt - 1 TO 0 BY -1 DO
                    Fsm.slot := Cmd.RC_Steps[Fsm.i].RS_Slot;

                    IF Cmd.RC_Steps[Fsm.i].RS_StopParam <> 0 THEN
                        Fsm.dummyOk := "FC_ArbiterMech"(
                            LocalManualGlobal := LocalManualGlobal,
                            OwnerReq          := OWNER_ROUTE,
                            OwnerReqId        := USINT_TO_UINT(RouteIdx),
                            ReqCmd            := CMD_START,
                            ReqParam1         := Cmd.RC_Steps[Fsm.i].RS_StopParam,
                            ReleaseOwner      := FALSE,
                            LockOnly          := FALSE,
                            M                 := Mechs[Fsm.slot]
                        );
                    ELSE
                        Fsm.dummyOk := "FC_ArbiterMech"(
                            LocalManualGlobal := LocalManualGlobal,
                            OwnerReq          := OWNER_ROUTE,
                            OwnerReqId        := USINT_TO_UINT(RouteIdx),
                            ReqCmd            := CMD_STOP,
                            ReqParam1         := 0,
                            ReleaseOwner      := FALSE,
                            LockOnly          := FALSE,
                            M                 := Mechs[Fsm.slot]
                        );
                    END_IF;
                END_FOR;
            END_IF;

            Fsm.allStopped := TRUE;

            IF Fsm.stepCnt > 0 THEN
                FOR Fsm.i := 0 TO Fsm.stepCnt - 1 DO
                    Fsm.slot := Cmd.RC_Steps[Fsm.i].RS_Slot;
                    IF Mechs[Fsm.slot].Status <> STS_IDLE THEN
                        Fsm.allStopped := FALSE;
                    END_IF;
                END_FOR;
            END_IF;

            IF Fsm.allStopped THEN
                // ✅ ЗМІНА v2.0: Release ownership ТІЛЬКИ при ABORTED
                IF Fsm.stepCnt > 0 THEN
                    FOR Fsm.i := 0 TO Fsm.stepCnt - 1 DO
                        Fsm.slot := Cmd.RC_Steps[Fsm.i].RS_Slot;

                        Fsm.dummyOk := "FC_ArbiterMech"(
                            LocalManualGlobal := LocalManualGlobal,
                            OwnerReq          := OWNER_ROUTE,
                            OwnerReqId        := USINT_TO_UINT(RouteIdx),
                            ReqCmd            := CMD_NONE,
                            ReqParam1         := 0,
                            ReleaseOwner      := TRUE,
                            LockOnly          := FALSE,
                            M                 := Mechs[Fsm.slot]
                        );
                    END_FOR;
                END_IF;

                Fsm.RF_State := ROUTE_STS_ABORTED;

                IF Fsm.RF_AbortLatched = 0 THEN
                    Fsm.RF_AbortLatched := ROUTE_ABRT_BY_OPERATOR;
                END_IF;

                Fsm.RF_ResultCode := Fsm.RF_AbortLatched;
            END_IF;

        ELSIF (Fsm.RF_State = ROUTE_STS_REJECTED)
           OR (Fsm.RF_State = ROUTE_STS_ABORTED) THEN

            IF Cmd.RC_Cmd = RT_CMD_NONE THEN
                Fsm.RF_State := ROUTE_STS_IDLE;
            END_IF;

        ELSE
            Fsm.RF_State := ROUTE_STS_IDLE;
        END_IF;

    END_IF;

    Sts.RS_State      := Fsm.RF_State;
    Sts.RS_ResultCode := Fsm.RF_ResultCode;
    Sts.RS_ActiveStep := Fsm.RF_ActiveStep;
    Sts.RS_StepSts    := Fsm.RF_StepSts;

END_FUNCTION
