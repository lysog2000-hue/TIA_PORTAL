// ==============================================================================
// UDT_RouteFsm - Об'єднаний стан FSM маршруту
// ==============================================================================
// Версія: 3.0.0
// Дата: 2026-02-19
// ==============================================================================
// Зміни v3.0:
//   - lockOkOne : BOOL → USINT  (зберігає RejectCode від FC_ArbiterMech)
//   - cmdOk     : BOOL → USINT  (зберігає RejectCode від FC_ArbiterMech)
//   - dummyOk   : BOOL → USINT  (зберігає RejectCode від FC_ArbiterMech)
//   - lockOkAll : BOOL          (залишається BOOL - агрегований результат)
// ==============================================================================

TYPE "UDT_RouteFsm"
{ S7_Optimized_Access := 'TRUE' }
STRUCT
  // === Persistent State ===
  RF_State        : UINT;   // ROUTE_STS_*
  RF_ResultCode   : UINT;   // REJ_* / ABRT_* / DONE_*
  RF_ActiveStep   : USINT;  // індекс поточного кроку
  RF_StepSts      : USINT;  // STEP_STS_* (IDLE/WORK/DONE/TIMEOUT)
  RF_AbortLatched : UINT;   // latched abort code для STOPPING

  // === Working Variables ===
  lastCmd    : USINT;       // для edge detection
  startEdge  : BOOL;        // TRUE на фронті RT_CMD_START
  stopOpEdge : BOOL;        // TRUE на фронті RT_CMD_STOP_OP

  stepCnt    : INT;         // кількість кроків (0.."ROUTE_MAX_STEPS")
  stepIdx    : INT;         // поточний індекс у циклах
  i          : INT;         // ітератор циклів FOR
  slot       : UINT;        // поточний slot

  anyFault   : BOOL;        // є аварія на механізмах?
  anyLocal   : BOOL;        // є LocalManual на механізмах?
  allStopped : BOOL;        // всі механізми зупинені?
  stepOk     : BOOL;        // валідація кроку

  lockOkAll  : BOOL;        // atomic lock OK для всіх (агрегований)
  lockOkOne  : USINT;       // RejectCode від FC_ArbiterMech для lock одного механізму
                            // 0 = ARB_OK, інше = відмова

  cmdOk      : USINT;       // RejectCode від FC_ArbiterMech для команди (START/STOP)
                            // 0 = ARB_OK, інше = відмова

  dummyOk    : USINT;       // RejectCode від FC_ArbiterMech (результат ігнорується)
                            // використовується для release/stop без перевірки

  safetyHit  : BOOL;        // GlobalSafetyStop спрацював

  // === Step pause (RUNNING та STOPPING) ===
  stepPause    : BOOL;      // TRUE = у паузі між кроками (чекаємо RS_TimeoutMs)
  stepPauseTck : DINT;      // мітка старту паузи (від TIME_TCK, мс)
END_STRUCT
END_TYPE
