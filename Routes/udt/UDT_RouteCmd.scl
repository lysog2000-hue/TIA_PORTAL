// ==============================================================================
// Зміни v2.0.3:
//   - RC_Steps: ARRAY[1.."ROUTE_MAX_STEPS"] - 1-based індексація (TIA Portal)
// ==============================================================================

TYPE "UDT_RouteCmd"
{ S7_Optimized_Access := 'TRUE' }
STRUCT
  RC_Cmd       : USINT;  // RT_CMD_NONE / RT_CMD_START / RT_CMD_STOP_OP
  RC_StepCount : USINT;  // 0.."ROUTE_MAX_STEPS"
  RC_Steps     : ARRAY[1.."ROUTE_MAX_STEPS"] OF "UDT_RouteStep";
END_STRUCT
END_TYPE
