// ==============================================================================
// UDT_RouteStep - Опис одного кроку маршруту (Mailbox Pattern v2.0)
// ==============================================================================
// Версія: 2.0.1 (Mailbox Pattern)
// Дата: 2026-02-02
// ==============================================================================
// Зміни:
//   + RS_StartParam: параметр для CMD_START (напр., позиція засувки)
//   + RS_StopParam: параметр для зупинки (0=CMD_STOP, інше=CMD_START з параметром)
// ==============================================================================

TYPE "UDT_RouteStep"
{ S7_Optimized_Access := 'TRUE' }
STRUCT
  RS_Slot        : UINT;   // index в Mechs[]
  RS_Action      : USINT;  // RS_ACT_START / RS_ACT_STOP
  RS_StartParam  : INT;    // параметр при виконанні кроку (CmdParam1 для START)
  RS_StopParam   : INT;    // параметр при зупинці (0=CMD_STOP, інше=START з цим параметром)
  RS_Wait        : USINT;  // RS_WAIT_RUNNING / RS_WAIT_STOPPED
  RS_TimeoutMs   : DINT;   // 0 = без таймауту
END_STRUCT
END_TYPE
