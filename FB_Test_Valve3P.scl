пїњ// ==============================================================================
// FB_Test_Valve3P - –†—Ю–†¬µ–°–Г–°вАЪ–†—Х–†–Ж–†—С–†вДЦ –†¬±–†¬ї–†—Х–†—Ф –†“С–†¬ї–°–П Valve3P (–°вАЪ–°–В–†—С–†—Ч–†—Х–†¬Ј–†—С–°вА†–°вАУ–†вДЦ–†–Е–†—С–†вДЦ –†—Ф–†¬ї–†¬∞–†—Ч–†¬∞–†–Е)
// ==============================================================================
// –†вАЩ–†¬µ–°–В–°–Г–°вАУ–°–П: 1.0.0
// –†вАЭ–†¬∞–°вАЪ–†¬∞: 2026-03-27
// ==============================================================================
// –†—Я–°–В–†—С–†¬Ј–†–Е–†¬∞–°вА°–†¬µ–†–Е–†–Е–°–П:
//   Unit-–°вАЪ–†¬µ–°–Г–°вАЪ–†—С –†“С–†¬ї–°–П FC_Valve3P –†¬Ј–†¬∞ –†¬∞–†–Е–†¬∞–†¬ї–†—Х–†—Ц–°вАУ–°вАЭ–°–Л –†¬Ј FB_Test_Gate2P
//
// –†вАЩ–†—С–†—Ф–†—Х–°–В–†—С–°–Г–°вАЪ–†¬∞–†–Е–†–Е–°–П:
//   "FB_Test_Valve3P"(
//       Run    := TRUE,      // –†–Ж–†—С–†—Ф–†—Х–†–Е–†¬∞–°вАЪ–†—С –°вАЪ–†¬µ–°–Г–°вАЪ
//       CaseId := 1          // –†–Е–†—Х–†—Ш–†¬µ–°–В –°вАЪ–†¬µ–°–Г–°вАЪ-–†—Ф–†¬µ–†вДЦ–°–Г–°—У
//   );
//   // –†—Я–†¬µ–°–В–†¬µ–†–Ж–°вАУ–°–В–†—С–°вАЪ–†—С: Passed, Failed, FailMask
// ==============================================================================
FUNCTION_BLOCK "FB_Test_Valve3P"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0

VAR_INPUT
    Run : Bool;   // TRUE = –†–Ж–†—С–†—Ф–†—Х–†–Е–†¬∞–°вАЪ–†—С –°вАЪ–†¬µ–°–Г–°вАЪ
    CaseId : Int;   // –†–Е–†—Х–†—Ш–†¬µ–°–В –°вАЪ–†¬µ–°–Г–°вАЪ-–†—Ф–†¬µ–†вДЦ–°–Г–°—У
END_VAR

VAR_OUTPUT
    Passed : Bool;
    Failed : Bool;
    FailMask : DWord;
END_VAR

VAR
    F : "UDT_Valve3P";
    B : "UDT_BaseMechanism";
    now : DInt;   // –†—Ч–†—Х–°вАЪ–†—Х–°вА°–†–Е–†—С–†вДЦ –°вА°–†¬∞–°–Г (TIME_TCK)
    
    // –†—Ы–°вА°–°вАУ–†—Ф–°—У–†–Ж–†¬∞–†–Е–†–Е–°–П
    Exp_Status : UInt;
    Exp_FLTCode : UInt;
    Exp_DO_Pos0 : Bool;
    Exp_DO_Pos1 : Bool;
    Exp_DO_Pos2 : Bool;
END_VAR


BEGIN

    #Passed := FALSE;
    #Failed := FALSE;
    #FailMask := 0;

    IF NOT #Run THEN
        RETURN;
    END_IF;

    #now := TIME_TCK();

    // ==============================================================================
    // ARRANGE –≤–ВвАЭ –†¬±–†¬∞–†¬Ј–†—Х–†–Ж–†—С–†вДЦ "–†¬Ј–†“С–†—Х–°–В–†—Х–†–Ж–†—С–†вДЦ" –°–Г–°вАЪ–†¬∞–†–Е
    // ==============================================================================
    
    // Base
    #B.Enable_OK := TRUE;
    #B.LocalManual := FALSE;
    #B.DeviceType := "TYPE_VALVE3P";
    #B.Cmd := "CMD_NONE";
    #B.CmdParam1 := 0;
    #B.LastCmd := "CMD_NONE";
    #B.Force_Code := 0;
    #B.OwnerCur := 123;  // –†—Ч–†¬µ–°–В–†¬µ–†–Ж–°вАУ–°–В–†—С–†—Ш–†—Х –°вА∞–†—Х –†—Ф–†—С–†“С–†¬∞–°вАЭ
    #B.OwnerCurId := 456;
    #B.Status := "STS_IDLE";
    #B.FLTCode := "FLT_NONE";
    
    // –†—Ю–†¬∞–†вДЦ–†—Ш–°вАУ–†–Е–†—Ц–†—С
    #F.MoveStartMs := 0;
    #F.UnknownPositionMs := 0;

    // HAL
    #F.DI_Breaker_OK := TRUE;
    #F.DI_Pos0_OK := FALSE;
    #F.DI_Pos1_OK := FALSE;
    #F.DI_Pos2_OK := FALSE;

    // –†вАЭ–†¬µ–°вАЮ–†—Х–†¬ї–°вАЪ –†—Х–°вА°–°вАУ–†—Ф–°—У–†–Ж–†¬∞–†–Е–°–К
    #Exp_Status := #B.Status;
    #Exp_FLTCode := #B.FLTCode;
    #Exp_DO_Pos0 := FALSE;
    #Exp_DO_Pos1 := FALSE;
    #Exp_DO_Pos2 := FALSE;

    // ==============================================================================
    // TEST CASES
    // ==============================================================================
    CASE #CaseId OF

        // ======================================================================
        // A1: Enable_OK = FALSE –≤вА†вАЩ DISABLED
        // ======================================================================
        1:
            #B.Enable_OK := FALSE;
            #Exp_Status := "STS_DISABLED";

        // ======================================================================
        // A2: LocalManual = TRUE –≤вА†вАЩ LOCAL
        // ======================================================================
        2:
            #B.LocalManual := TRUE;
            #Exp_Status := "STS_LOCAL";

        // ======================================================================
        // B1: RESET –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ FAULT –°вАУ –°вАЪ–†¬∞–†вДЦ–†—Ш–°вАУ–†–Е–†—Ц–†—С
        // ======================================================================
        3:
            #B.Status := "STS_FAULT";
            #B.FLTCode := "FLT_VALVE_MOVE_TIMEOUT";
            #F.MoveStartMs := 111;
            #F.UnknownPositionMs := 2323;
            #B.Cmd := "CMD_RESET";
            #Exp_Status := "STS_IDLE";
            #Exp_FLTCode := "FLT_NONE";
            // –†—Я–°–В–†—С–†—Ш–°вАУ–°вАЪ–†—Ф–†¬∞: UnknownPositionMs –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ–°вАЪ–°–К–°–Г–°–П –°вАЪ–°вАУ–†¬ї–°–К–†—Ф–†—С –°–П–†—Ф–°вА∞–†—Х –†¬±–°—У–†¬ї–†¬∞ Unknown –†—Ч–†—Х–†¬Ј–†—С–°вА†–°вАУ–°–П
            // –†–И –°вА†–°–К–†—Х–†—Ш–°—У –°вАЪ–†¬µ–°–Г–°вАЪ–°вАУ FLT_VALVE_MOVE_TIMEOUT –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ–°вАЪ–°–К–°–Г–°–П –†¬Ј–†¬∞–†–Ж–†¬ґ–†“С–†—С (–†–Е–†¬µ–†—Ш–†¬∞–°вАЭ –°вАЮ–°вАУ–†¬Ј. –†“С–†¬∞–°вАЪ–°вА°–†—С–†—Ф–†¬∞)

        // ======================================================================
        // C1: Breaker –†¬∞–†–Ж–†¬∞–°–В–°вАУ–°–П
        // ======================================================================
        4:
            #F.DI_Breaker_OK := FALSE;
            #Exp_Status := "STS_FAULT";
            #Exp_FLTCode := "FLT_BREAKER";

        // ======================================================================
        // C2: Unknown Position (–†–Е–†¬µ–†–Ж–°вАУ–†“С–†—Х–†—Ш–†¬∞ –†—Ч–†—Х–†¬Ј–†—С–°вА†–°вАУ–°–П > –°вАЪ–†¬∞–†вДЦ–†—Ш–†¬∞–°—У–°вАЪ)
        // ======================================================================
        5:
            #B.Status := "STS_IDLE";
            #F.DI_Pos0_OK := FALSE;
            #F.DI_Pos1_OK := FALSE;
            #F.DI_Pos2_OK := FALSE;
            #F.UnknownPositionMs := #now - "TimeoutMs_Valve_Position_Unknown" - 1;
            #Exp_Status := "STS_FAULT";
            #Exp_FLTCode := "FLT_VALVE_POS_UNKNOWN";

        // ======================================================================
        // C3: Breaker > Unknown Position (–†—Ч–°–В–°вАУ–†—Х–°–В–†—С–°вАЪ–†¬µ–°вАЪ Breaker)
        // ======================================================================
        6:
            #B.Status := "STS_IDLE";
            #F.DI_Breaker_OK := FALSE;
            #F.DI_Pos0_OK := FALSE;
            #F.DI_Pos1_OK := FALSE;
            #F.DI_Pos2_OK := FALSE;
            #F.UnknownPositionMs := #now - "TimeoutMs_Valve_Position_Unknown" - 1;
            #Exp_Status := "STS_FAULT";
            #Exp_FLTCode := "FLT_BREAKER";

        // ======================================================================
        // C4: Multiple Positions (2+ –†“С–†¬∞–°вАЪ–°вА°–†—С–†—Ф–°вАУ–†–Ж –†¬∞–†—Ф–°вАЪ–†—С–†–Ж–†–Е–°вАУ)
        // ======================================================================
        7:
            #F.DI_Pos0_OK := TRUE;
            #F.DI_Pos1_OK := TRUE;
            #F.DI_Pos2_OK := FALSE;
            #Exp_Status := "STS_FAULT";
            #Exp_FLTCode := "FLT_VALVE_MULTIPLE_POS";

        // ======================================================================
        // C5: Multiple Positions (–†–Ж–°–Г–°вАУ 3 –†¬∞–†—Ф–°вАЪ–†—С–†–Ж–†–Е–°вАУ)
        // ======================================================================
        8:
            #F.DI_Pos0_OK := TRUE;
            #F.DI_Pos1_OK := TRUE;
            #F.DI_Pos2_OK := TRUE;
            #Exp_Status := "STS_FAULT";
            #Exp_FLTCode := "FLT_VALVE_MULTIPLE_POS";

        // ======================================================================
        // D1: –†¬§–†—Х–°–В–°–Г–°—У–†–Ж–†¬∞–†–Е–†–Е–°–П BREAKER
        // ======================================================================
        9:
            #F.DI_Breaker_OK := FALSE;
            #B.Force_Code := 1;  // BIT0 = forceBreaker
            #Exp_Status := "STS_IDLE";
            #Exp_FLTCode := "FLT_NONE";  // –†¬§–†—Х–°–В–°–Г–°—У–†–Ж–†¬∞–†–Е–†–Е–°–П –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ FLTCode
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // D2: –†¬§–†—Х–°–В–°–Г–°—У–†–Ж–†¬∞–†–Е–†–Е–°–П VALVE_POS_UNKNOWN
        // ======================================================================
        10:
            #B.Force_Code := 32;  // BIT5 = forcePosUnknown
            #B.Status := "STS_IDLE";
            #B.FLTCode := "FLT_NONE";  // –†–З–†–Ж–†–Е–†—Х –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ–†—Ш–†—Х FLTCode –†–Е–†¬∞ –†—Ч–†—Х–°вА°–†¬∞–°вАЪ–†—Ф–°—У
            #F.DI_Pos0_OK := FALSE;
            #F.DI_Pos1_OK := FALSE;
            #F.DI_Pos2_OK := FALSE;
            #F.UnknownPositionMs := #now - "TimeoutMs_Valve_Position_Unknown" - 1;
            #Exp_Status := "STS_IDLE";
            #Exp_FLTCode := "FLT_NONE";  // –†¬§–†—Х–°–В–°–Г–°—У–†–Ж–†¬∞–†–Е–†–Е–°–П –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ FLTCode
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // D3: –†¬§–†—Х–°–В–°–Г–°—У–†–Ж–†¬∞–†–Е–†–Е–°–П VALVE_MOVE_TIMEOUT
        // ======================================================================
        11:
            #B.Force_Code := 16;  // BIT4 = forceMoveTimeout
            #B.Status := "STS_RUNNING";
            #B.FLTCode := "FLT_NONE";  // –†–З–†–Ж–†–Е–†—Х –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ–†—Ш–†—Х FLTCode –†–Е–†¬∞ –†—Ч–†—Х–°вА°–†¬∞–°вАЪ–†—Ф–°—У
            #B.CmdParam1 := "CMD_VALVE_POS1";
            #F.DO_Pos1 := TRUE;  // –†вАЩ–°–Г–°вАЪ–†¬∞–†–Е–†—Х–†–Ж–†¬ї–°–Л–°вАЭ–†—Ш–†—Х –†—Ч–†¬µ–°–В–†¬µ–†“С –°вАЪ–†¬µ–°–Г–°вАЪ–†—Х–†—Ш
            #F.MoveStartMs := #now - "TimeoutMs_Valve_Move" - 1;
            #Exp_Status := "STS_RUNNING";
            #Exp_FLTCode := "FLT_NONE";  // –†¬§–†—Х–°–В–°–Г–°—У–†–Ж–†¬∞–†–Е–†–Е–°–П –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ FLTCode
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := TRUE;  // –†вАЩ–†—С–°вА¶–°вАУ–†“С –†¬Ј–†¬∞–†¬ї–†—С–°вВђ–†¬∞–°вАЭ–°вАЪ–°–К–°–Г–°–П –†¬∞–†—Ф–°вАЪ–†—С–†–Ж–†–Е–†—С–†—Ш
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E1: START + CMD_VALVE_POS0 + DI_Pos0_OK –≤вА†вАЩ IDLE (–†–Ж–†¬ґ–†¬µ –°—У –†—Ч–†—Х–†¬Ј–†—С–°вА†–°вАУ–°вАФ)
        // ======================================================================
        12:
            #B.Cmd := "CMD_START";
            #B.CmdParam1 := "CMD_VALVE_POS0";
            #F.DI_Pos0_OK := TRUE;
            #Exp_Status := "STS_IDLE";
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E2: START + CMD_VALVE_POS1 + DI_Pos1_OK –≤вА†вАЩ IDLE (–†–Ж–†¬ґ–†¬µ –°—У –†—Ч–†—Х–†¬Ј–†—С–°вА†–°вАУ–°вАФ)
        // ======================================================================
        13:
            #B.Cmd := "CMD_START";
            #B.CmdParam1 := "CMD_VALVE_POS1";
            #F.DI_Pos1_OK := TRUE;
            #Exp_Status := "STS_IDLE";
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E3: START + CMD_VALVE_POS2 + DI_Pos2_OK –≤вА†вАЩ IDLE (–†–Ж–†¬ґ–†¬µ –°—У –†—Ч–†—Х–†¬Ј–†—С–°вА†–°вАУ–°вАФ)
        // ======================================================================
        14:
            #B.Cmd := "CMD_START";
            #B.CmdParam1 := "CMD_VALVE_POS2";
            #F.DI_Pos2_OK := TRUE;
            #Exp_Status := "STS_IDLE";
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E4: START + CMD_VALVE_POS0 + Not DI_Pos0_OK –≤вА†вАЩ STARTING
        // ======================================================================
        15:
            #B.Cmd := "CMD_START";
            #B.CmdParam1 := "CMD_VALVE_POS0";
            #F.DI_Pos0_OK := FALSE;
            #Exp_Status := "STS_STARTING";
            #Exp_DO_Pos0 := TRUE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E5: START + CMD_VALVE_POS1 + Not DI_Pos1_OK –≤вА†вАЩ STARTING
        // ======================================================================
        16:
            #B.Cmd := "CMD_START";
            #B.CmdParam1 := "CMD_VALVE_POS1";
            #F.DI_Pos1_OK := FALSE;
            #Exp_Status := "STS_STARTING";
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := TRUE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E6: START + CMD_VALVE_POS2 + Not DI_Pos2_OK –≤вА†вАЩ STARTING
        // ======================================================================
        17:
            #B.Cmd := "CMD_START";
            #B.CmdParam1 := "CMD_VALVE_POS2";
            #F.DI_Pos2_OK := FALSE;
            #Exp_Status := "STS_STARTING";
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := TRUE;

        // ======================================================================
        // E7: STARTING + Not DI_Pos0_OK –≤вА†вАЩ RUNNING (–†¬Ј–°вАУ–†вДЦ–°вВђ–†—Х–†–Ж –†¬Ј –†—Ф–°вАУ–†–Е–°вА†–†¬µ–†–Ж–†—С–†—Ф–†¬∞)
        // ======================================================================
        18:
            #B.Status := "STS_STARTING";
            #B.CmdParam1 := "CMD_VALVE_POS0";
            #F.DI_Pos0_OK := FALSE;
            #Exp_Status := "STS_RUNNING";
            #Exp_DO_Pos0 := TRUE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E8: STARTING + DI_Pos0_OK –≤вА†вАЩ IDLE (–†–Е–†¬µ –†¬Ј–°вАУ–†вДЦ–°вВђ–†¬ї–†¬∞, –†–Ж–†¬ґ–†¬µ –°—У –†—Ч–†—Х–†¬Ј–†—С–°вА†–°вАУ–°вАФ)
        // ======================================================================
        19:
            #B.Status := "STS_STARTING";
            #B.CmdParam1 := "CMD_VALVE_POS0";
            #F.DI_Pos0_OK := TRUE;
            #Exp_Status := "STS_IDLE";
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E9: RUNNING + MoveTimeout –≤вА†вАЩ FLT_VALVE_MOVE_TIMEOUT
        // ======================================================================
        20:
            #B.Status := "STS_RUNNING";
            #B.CmdParam1 := "CMD_VALVE_POS1";
            #F.DO_Pos1 := TRUE;
            #F.MoveStartMs := #now - "TimeoutMs_Valve_Move" - 1;
            #Exp_Status := "STS_FAULT";
            #Exp_FLTCode := "FLT_VALVE_MOVE_TIMEOUT";
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E10: RUNNING + –†“С–†—Х–°–Г–°–П–†—Ц–†–Е–°—У–°вАЪ–†—Х –†—Ч–†—Х–†¬Ј–†—С–°вА†–°вАУ–°вАФ –≤вА†вАЩ STOPPING
        // ======================================================================
        21:
            #B.Status := "STS_RUNNING";
            #B.FLTCode := "FLT_NONE";  // –†–З–†–Ж–†–Е–†—Х –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ–†—Ш–†—Х FLTCode
            #B.CmdParam1 := "CMD_VALVE_POS1";
            #F.DI_Pos1_OK := TRUE;
            #F.MoveStartMs := 0;  // –†–О–†—Ф–†—С–†“С–†¬∞–°вАЭ–†—Ш–†—Х –°вАЪ–†¬∞–†вДЦ–†—Ш–†¬µ–°–В –°–В–°—У–°вА¶–°—У (–°вА∞–†¬µ –†–Е–†¬µ –°вА°–†¬∞–°–Г –°вАЪ–†¬∞–†вДЦ–†—Ш–†¬∞–°—У–°вАЪ–°—У)
            #Exp_Status := "STS_STOPPING";
            #Exp_FLTCode := "FLT_NONE";
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E11: STOPPING + DI_Pos1_OK –≤вА†вАЩ IDLE
        // ======================================================================
        22:
            #B.Status := "STS_STOPPING";
            #F.DI_Pos1_OK := TRUE;
            #Exp_Status := "STS_IDLE";
            #Exp_DO_Pos0 := FALSE;
            #Exp_DO_Pos1 := FALSE;
            #Exp_DO_Pos2 := FALSE;

        // ======================================================================
        // E12: STOP –†—Ч–°вАУ–†“С –°вА°–†¬∞–°–Г STARTING –≤вА†вАЩ STOPPING
        // ======================================================================
        23:
            #B.Status := "STS_STARTING";
            #B.Cmd := "CMD_STOP";
            #Exp_Status := "STS_STOPPING";

        // ======================================================================
        // E13: STOP –†—Ч–°вАУ–†“С –°вА°–†¬∞–°–Г RUNNING –≤вА†вАЩ STOPPING
        // ======================================================================
        24:
            #B.Status := "STS_RUNNING";
            #B.FLTCode := "FLT_NONE";  // –†–З–†–Ж–†–Е–†—Х –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ–†—Ш–†—Х FLTCode
            #B.Cmd := "CMD_STOP";
            #F.DI_Pos0_OK := FALSE;  // –†—Щ–†¬ї–†¬∞–†—Ч–†¬∞–†–Е –°—У –°–В–°—У–°–Г–°вАУ (–†–Е–†¬µ–†—Ш–†¬∞–°вАЭ –†—Ч–†—Х–†¬Ј–†—С–°вА†–°вАУ–°вАФ)
            #F.DI_Pos1_OK := FALSE;
            #F.DI_Pos2_OK := FALSE;
            #F.MoveStartMs := 0;  // –†–О–†—Ф–†—С–†“С–†¬∞–°вАЭ–†—Ш–†—Х –°вАЪ–†¬∞–†вДЦ–†—Ш–†¬µ–°–В –°–В–°—У–°вА¶–°—У (–°вА∞–†¬µ –†–Е–†¬µ –°вА°–†¬∞–°–Г –°вАЪ–†¬∞–†вДЦ–†—Ш–†¬∞–°—У–°вАЪ–°—У)
            #Exp_Status := "STS_STOPPING";
            #Exp_FLTCode := "FLT_NONE";

        // ======================================================================
        // E14: –†вАЩ–°вАУ–†“С–†–Е–†—Х–†–Ж–†¬ї–†¬µ–†–Е–†–Е–°–П –†¬Ј DISABLED –≤вА†вАЩ IDLE
        // ======================================================================
        25:
            #B.Status := "STS_DISABLED";
            #B.Enable_OK := TRUE;
            #Exp_Status := "STS_IDLE";

        // ======================================================================
        // E15: –†вАЩ–°вАУ–†“С–†–Е–†—Х–†–Ж–†¬ї–†¬µ–†–Е–†–Е–°–П –†¬Ј LOCAL –≤вА†вАЩ IDLE
        // ======================================================================
        26:
            #B.Status := "STS_LOCAL";
            #B.LocalManual := FALSE;
            #Exp_Status := "STS_IDLE";

        ELSE
            RETURN;
    END_CASE;

    // ==============================================================================
    // ACT –≤–ВвАЭ –†–Ж–†—С–†—Ф–†¬ї–†—С–†—Ф –°вАЮ–°—У–†–Е–†—Ф–°вА†–°вАУ–°вАФ –†—Ф–†¬µ–°–В–°—У–†–Ж–†¬∞–†–Е–†–Е–°–П
    // ==============================================================================
    "FC_Valve3P"(
        F := #F,
        B := #B
    );

    // ==============================================================================
    // ASSERT –≤–ВвАЭ –†—Ч–†¬µ–°–В–†¬µ–†–Ж–°вАУ–°–В–†—Ф–†¬∞ –°–В–†¬µ–†¬Ј–°—У–†¬ї–°–К–°вАЪ–†¬∞–°вАЪ–°вАУ–†–Ж
    // ==============================================================================
    IF #B.Status <> #Exp_Status THEN
        #FailMask := #FailMask OR 16#0001;
    END_IF;
    
    IF #B.FLTCode <> #Exp_FLTCode THEN
        #FailMask := #FailMask OR 16#0002;
    END_IF;
    
    IF #F.DO_Pos0 <> #Exp_DO_Pos0 THEN
        #FailMask := #FailMask OR 16#0004;
    END_IF;
    
    IF #F.DO_Pos1 <> #Exp_DO_Pos1 THEN
        #FailMask := #FailMask OR 16#0008;
    END_IF;
    
    IF #F.DO_Pos2 <> #Exp_DO_Pos2 THEN
        #FailMask := #FailMask OR 16#0010;
    END_IF;

    // RESET –†“С–†—Х–†“С–†¬∞–°вАЪ–†—Ф–†—Х–†–Ж–°вАУ –†—Ц–†¬∞–°–В–†¬∞–†–Е–°вАЪ–°вАУ–°вАФ (–°вАЪ–†¬∞–†вДЦ–†—Ш–°вАУ–†–Е–†—Ц–†—С –†—Ч–†—Х–†–Ж–†—С–†–Е–†–Е–°вАУ –†—Х–†¬±–†–Е–°—У–†¬ї–†—С–°вАЪ–†—С–°–Г–°–П)
    IF #CaseId = 3 THEN
        IF #F.MoveStartMs <> 0 THEN
            #FailMask := #FailMask OR 16#0020;
        END_IF;
        // UnknownPositionMs –°–Г–†—Ф–†—С–†“С–†¬∞–°вАЭ–°вАЪ–°–К–°–Г–°–П –°вАЪ–°вАУ–†¬ї–°–К–†—Ф–†—С –°–П–†—Ф–°вА∞–†—Х FLTCode –†¬±–°—У–†–Ж FLT_VALVE_POS_UNKNOWN
        // –†–И –°вА†–°–К–†—Х–†—Ш–°—У –°вАЪ–†¬µ–°–Г–°вАЪ–°вАУ FLT_VALVE_MOVE_TIMEOUT –≤вА†вАЩ UnknownPositionMs –†–Е–†¬µ –°вА°–°вАУ–†—Ч–†¬∞–°вАЭ–°вАЪ–°–К–°–Г–°–П
        // –†—Ю–†—Х–†—Ш–°—У –†—Ч–†¬µ–°–В–†¬µ–†–Ж–°вАУ–°–В–°–П–°вАЭ–†—Ш–†—Х –°вАЪ–°вАУ–†¬ї–°–К–†—Ф–†—С MoveStartMs
    END_IF;

    #Failed := (#FailMask <> 0);
    #Passed := NOT #Failed;

END_FUNCTION_BLOCK
