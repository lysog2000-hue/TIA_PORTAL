// ==============================================================================
// DB_Plc_RouteExecutor - Внутрішній буфер PLC для виконання маршрутів
// ==============================================================================
// Версія: 2.0.1 (Mailbox Pattern)
// Дата: 2026-02-02
// ==============================================================================
// ПРИЗНАЧЕННЯ:
// 
// Після отримання команди з Mailbox, PLC копіює її у відповідний слот
// RouteExecutor[RouteId] для подальшого виконання через FC_RouteFSM.
//
// WORKFLOW:
// 1. Mailbox → PLC детектує нову команду (commitIn != commitAck)
// 2. Validate → RouteId ∈ [1..12], перевірка стану маршруту
// 3. Copy → RouteExecutor[RouteId] := Mailbox.CMD_Route
// 4. ACK → ACK_CommitApplied++, ACK_RouteId = RouteId
// 5. Execute → FC_RouteFSM працює з RouteExecutor[RouteId]
// 6. Cleanup → після ABORTED/IDLE очищується RouteExecutor[RouteId]
//
// ОЧИЩЕННЯ:
// - RouteExecutor[i] очищується після переходу в ABORTED або повернення в IDLE
// - Це запобігає повторному виконанню старих команд після перезавантаження
//
// НЕЗАЛЕЖНІСТЬ:
// - Кожен маршрут виконується незалежно
// - Mailbox обробляє команди послідовно
// - Виконання маршрутів відбувається паралельно
// ==============================================================================

DATA_BLOCK "DB_Plc_RouteExecutor"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.0
NON_RETAIN

VAR
  // === Буфер команд для 12 маршрутів ===
  // Індексація: 1..12 (0 не використовується)
  Routes : ARRAY[1..12] OF "UDT_RouteCmd";
END_VAR

BEGIN
  // Початкова ініціалізація порожньої
END_DATA_BLOCK
