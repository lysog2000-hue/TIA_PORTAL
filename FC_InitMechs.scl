// ==============================================================================
// FC_InitMechs - Ініціалізація SlotId у базових механізмах
// ==============================================================================
// Project  : Elevator_System
// Author   : Engineering Team
// Version  : 3.0.0
// Generated: 2026-02-08
// ==============================================================================
// ПРИЗНАЧЕННЯ:
//   Викликається при ініціалізації PLC (Startup OB) для заповнення поля
//   SlotId у кожному елементі масиву DB_Mechs.Mechs[].
//
// ВАЖЛИВО:
//   Це НЕ мапінг механізмів! Мапінг виконується в DB_Mechs BEGIN section.
//   Ця функція тільки заповнює SlotId = індекс у масиві.
//
// ВИКЛИК:
//   Викликається один раз при старті PLC (з "Startup" OB).
// ==============================================================================

FUNCTION "FC_InitMechs" : VOID
{ S7_Optimized_Access := 'TRUE' }
VERSION : 3.0

VAR_TEMP
    i : USINT;
END_VAR

BEGIN
    // ==============================================================================
    // Проходимо через ВСІ слоти базової шини механізмів
    // ==============================================================================
    // Заповнюємо поле SlotId номером слоту (0..MECHS_COUNT)
    // Це дозволяє механізму "знати свій слот" без зовнішніх параметрів
    // ==============================================================================
    
    FOR i := 0 TO "MECHS_COUNT" DO
        "DB_Mechs".Mechs[i].SlotId := i;
    END_FOR;

    
END_FUNCTION
