// ==============================================================================
// FC_InitMechs - Ініціалізація механізмів через константи
// ==============================================================================
// Project  : Elevator_System
// Author   : Engineering Team
// Version  : 3.1.0
// Generated: 2026-02-08
// ==============================================================================
// ПРИЗНАЧЕННЯ:
//   Послідовна ініціалізація всіх механізмів через константи
//   Структура: Редлери → Норії → Засувки → Вентилятори
//   Без розривів у slot нумерації
//
// ВИКЛИК:
//   Викликається один раз при старті PLC (з "Startup" OB)
// ==============================================================================

FUNCTION "FC_InitMechs" : VOID
{ S7_Optimized_Access := 'TRUE' }
VERSION : 3.1

VAR_TEMP
    i         : USINT;
    slot      : USINT;
END_VAR

BEGIN
    // ==============================================================================
    // Спочатку очистити ВСІ слоти (TYPE_NONE)
    // ==============================================================================
    FOR i := 0 TO "MECHS_COUNT" DO
        "DB_Mechs".Mechs[i].SlotId := i;
        "DB_Mechs".Mechs[i].DeviceType := "TYPE_NONE";
        "DB_Mechs".Mechs[i].TypedIndex := UINT#16#FFFF;
        "DB_Mechs".Mechs[i].Enable_OK := FALSE;
    END_FOR;
    
    // ==============================================================================
    // ПОСЛІДОВНА ІНІЦІАЛІЗАЦІЯ (без розривів)
    // ==============================================================================
    
    slot := 0;  // Починаємо з slot 0
    
    // === 1. РЕДЛЕРИ (slot 0..REDLERS_COUNT) ===
    FOR i := 0 TO "REDLERS_COUNT" DO
        "DB_Mechs".Mechs[slot].DeviceType := "TYPE_REDLER";
        "DB_Mechs".Mechs[slot].TypedIndex := i;
        "DB_Mechs".Mechs[slot].Enable_OK := TRUE;
        slot := slot + 1;
    END_FOR;
    
    // === 2. НОРІЇ (продовження від slot) ===
    FOR i := 0 TO "NORIAS_COUNT" DO
        "DB_Mechs".Mechs[slot].DeviceType := "TYPE_NORIA";
        "DB_Mechs".Mechs[slot].TypedIndex := i;
        "DB_Mechs".Mechs[slot].Enable_OK := TRUE;
        slot := slot + 1;
    END_FOR;
    
    // === 3. ЗАСУВКИ (продовження від slot) ===
    FOR i := 0 TO "GATES2P_COUNT" DO
        "DB_Mechs".Mechs[slot].DeviceType := "TYPE_GATE2P";
        "DB_Mechs".Mechs[slot].TypedIndex := i;
        "DB_Mechs".Mechs[slot].Enable_OK := TRUE;
        slot := slot + 1;
    END_FOR;
    
    // === 4. ВЕНТИЛЯТОРИ (продовження від slot) ===
    FOR i := 0 TO "FANS_COUNT" DO
        "DB_Mechs".Mechs[slot].DeviceType := "TYPE_FAN";
        "DB_Mechs".Mechs[slot].TypedIndex := i;
        "DB_Mechs".Mechs[slot].Enable_OK := TRUE;
        slot := slot + 1;
    END_FOR;
    
    // ==============================================================================
    // ІНФОРМАЦІЯ ПРО ALLOCATION
    // ==============================================================================
    // Загальна кількість замаплених механізмів: slot
    // Редлери:     slot 0          .. REDLERS_COUNT
    // Норії:       slot REDLERS+1  .. REDLERS+NORIAS+1
    // Засувки:     slot ...        .. ...
    // Вентилятори: slot ...        .. slot-1
    // Вільні:      slot            .. 255
    // ==============================================================================
    
END_FUNCTION
