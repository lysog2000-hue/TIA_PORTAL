	//    ÐÑ€Ð±Ñ–Ñ‚Ñ€ ÑÐ°Ð¼ Ñ€Ð¾Ð·Ð±ÐµÑ€ÐµÑ‚ÑŒÑÑ Ð· ÐºÐ¾Ð¼Ð°Ð½Ð´Ð¾ÑŽ (meta Ñ‡Ð¸ Ð·Ð²Ð¸Ñ‡Ð°Ð¹Ð½Ð°)
	// =========================================================
	#rejectCode := "FC_ArbiterMech"(
