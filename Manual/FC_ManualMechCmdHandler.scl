// ==============================================================================
// Ð’ÐµÑ€ÑÑ–Ñ: 6.0.0 (ÐœÐ°ÐºÑÐ¸Ð¼Ð°Ð»ÑŒÐ½Ðµ ÑÐ¿Ñ€Ð¾Ñ‰ÐµÐ½Ð½Ñ)
// Ð”Ð°Ñ‚Ð°: 2026-02-15
// ==============================================================================
// ÐšÐžÐÐ¦Ð•ÐŸÐ¦Ð†Ð¯:
//   Ð¥ÐµÐ½Ð´Ð»ÐµÑ€ = MailBox Ð¿ÐµÑ€ÐµÐºÐ»Ð°Ð´Ð°Ñ‡ Ð¼Ñ–Ð¶ SCADA Ñ– ÐÑ€Ð±Ñ–Ñ‚Ñ€Ð¾Ð¼
//   - Ð§Ð¸Ñ‚Ð°Ñ” ÐºÐ¾Ð¼Ð°Ð½Ð´Ð¸ Ð· MailBox (Ð¼Ð¾Ð²Ð° SCADA)
//   - Ð’Ð¸ÐºÐ»Ð¸ÐºÐ°Ñ” Ð°Ñ€Ð±Ñ–Ñ‚Ñ€ (Ð¼Ð¾Ð²Ð° Ð¼ÐµÑ…Ð°Ð½Ñ–Ð·Ð¼Ñ–Ð²)
//   - ÐŸÐ¸ÑˆÐµ Ð²Ñ–Ð´Ð¿Ð¾Ð²Ñ–Ð´ÑŒ Ð² MailBox (ÐºÐ¾Ð´Ð¸ Ð°Ñ€Ð±Ñ–Ñ‚Ñ€Ð° ARB_*)
// ==============================================================================
   VAR_TEMP 
      slot : UInt;
