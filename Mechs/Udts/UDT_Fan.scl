TYPE "UDT_Fan" :
STRUCT
    // ===== Дискретні входи/виходи (HAL / залізо) =====
    DI_Breaker_OK   : BOOL;    // автомат захисту [cite: 79, 80]
    DI_Feedback_OK  : BOOL;    // зворотний зв'язок контактора [cite: 80]
    DO_Run          : BOOL;    // вихід на контактор [cite: 81]

    // ===== Стан/таймінги вентилятора =====
    StartMs         : DINT;    // час старту (мітка) [cite: 82]
END_STRUCT;
END_TYPE