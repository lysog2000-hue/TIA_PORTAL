FUNCTION "FC_Noria" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.5
   VAR_IN_OUT 
      N : "UDT_Noria";
      B : "UDT_BaseMechanism";
   END_VAR

   VAR_TEMP 
      elapsedMs : DInt;
      nowTck : DInt;
      forceBreaker : Bool;
      forceOverflow : Bool;
      forceAlingment : Bool;
      forceSpeed : Bool;
      forceFeedback : Bool;
      forceStopTimeout : Bool;
      isFault : Bool;
      isBlocked : Bool;
   END_VAR


BEGIN
	
	REGION "0) Декодування форсування"
	    // BIT0(1)=forceBreaker, BIT1(2)=forceOverflow, BIT2(4)=forceSpeed, BIT3(8)=forceAlingment, BIT8(256)=forceFeedback, BIT6(64)=forceStopTimeout
	    #forceBreaker := (#B.Force_Code AND 1) <> 0;
	    #forceOverflow := (#B.Force_Code AND 2) <> 0;
	    #forceSpeed := (#B.Force_Code AND 4) <> 0;
	    #forceAlingment := (#B.Force_Code AND 8) <> 0;
	    #forceFeedback := (#B.Force_Code AND 256) <> 0;
	    #forceStopTimeout := (#B.Force_Code AND 64) <> 0;
	END_REGION
	
	REGION "1) RESET (Тільки за умови усунення причини)"
	    IF #B.Cmd = "CMD_RESET" THEN
	        // Скидання бітів аварій, якщо причина усунена
	        IF (#B.FLTCode AND "FLT_BREAKER") <> 0 THEN
	            IF #N.DI_Breaker_OK OR #forceBreaker THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_BREAKER";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_OVERFLOW") <> 0 THEN
	            IF #N.DI_Overflow_OK OR #forceOverflow THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_OVERFLOW";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_ALINGMENT") <> 0 THEN
	            IF #N.DI_Alingment_OK OR #forceAlingment THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_ALINGMENT";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_NO_RUNFB") <> 0 THEN
	            IF #N.DI_Speed_OK OR #forceSpeed THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_NO_RUNFB";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_NO_FEEDBACK") <> 0 THEN
	            IF #N.DI_Feedback_OK OR #forceFeedback THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_NO_FEEDBACK";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_STOP_TIMEOUT") <> 0 THEN
	            IF NOT #N.DI_Speed_OK OR #forceStopTimeout THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_STOP_TIMEOUT";
	            END_IF;
	        END_IF;
	        
	        IF #B.FLTCode = "FLT_NONE" AND #B.Status = "STS_FAULT" THEN
	            #B.Status := "STS_IDLE";
	            #N.StartMs := 0;
	            #N.SpeedLostMs := 0;
	            #N.FeedbackLostMs := 0;
	            #N.StopMs := 0;
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "2) Обробка блокувань"
	    IF NOT #B.Enable_OK THEN
	        #B.Status := "STS_DISABLED";
	        #isBlocked := TRUE;
	    ELSIF #B.LocalManual THEN
	        #B.Status := "STS_LOCAL";
	        #isBlocked := TRUE;
	    ELSE
	        #isBlocked := FALSE;
	        IF (#B.Status = "STS_DISABLED") OR (#B.Status = "STS_LOCAL") THEN
	            #B.Status := "STS_IDLE";
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "3) Моніторинг аварій (Diagnostic Latch)"
	    IF NOT #isBlocked THEN
	        IF NOT #N.DI_Breaker_OK THEN
	            #B.FLTCode := #B.FLTCode OR "FLT_BREAKER";
	        END_IF;
	        IF NOT #N.DI_Overflow_OK THEN
	            #B.FLTCode := #B.FLTCode OR "FLT_OVERFLOW";
	        END_IF;
	        IF NOT #N.DI_Alingment_OK THEN
	            #B.FLTCode := #B.FLTCode OR "FLT_ALINGMENT";
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "4) Визначення виконавчої аварії"
	    #isFault := FALSE;
	    IF #B.FLTCode <> "FLT_NONE" THEN
	        // Перевірка кожного біта аварії з урахуванням форсування
	        IF (#B.FLTCode AND "FLT_BREAKER") <> 0 AND NOT #forceBreaker THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_OVERFLOW") <> 0 AND NOT #forceOverflow THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_ALINGMENT") <> 0 AND NOT #forceAlingment THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_NO_RUNFB") <> 0 AND NOT #forceSpeed THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_NO_FEEDBACK") <> 0 AND NOT #forceFeedback THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_STOP_TIMEOUT") <> 0 AND NOT #forceStopTimeout THEN
	            #isFault := TRUE;
	        END_IF;
	    END_IF;
	    
	    IF #isFault THEN
	        #B.Status := "STS_FAULT";
	    END_IF;
	    #isFault := (#B.Status = "STS_FAULT");
	END_REGION
	
	REGION "5 & 6) Машина станів та виконання команд"
	    IF (NOT #isFault) AND (NOT #isBlocked) THEN
	        IF #B.Cmd <> "CMD_NONE" THEN
	            #B.LastCmd := #B.Cmd;
	        END_IF;
	        
	        CASE #B.Status OF
	            "STS_IDLE":
	                IF #B.Cmd = "CMD_START" THEN
	                    // Перевірка мінімального інтервалу перезапуску
	                    IF #N.LastStopMs = 0 OR "FC_TimeElapsedMs"(StartTck := #N.LastStopMs, TimeoutMs := "TimeoutMs_Noria_MinRestart",
	                                                                ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.Status := "STS_STARTING";
	                        #N.StartMs := TIME_TCK();
	                    END_IF;
	                END_IF;
	                
	            "STS_STARTING":
	                IF #N.DI_Speed_OK OR #forceSpeed THEN
	                    #B.Status := "STS_RUNNING";
	                ELSE
	                    IF "FC_TimeElapsedMs"(StartTck := #N.StartMs, TimeoutMs := "TimeoutMs_Noria_Start",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.FLTCode := #B.FLTCode OR "FLT_NO_RUNFB";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                END_IF;
	                
	            "STS_RUNNING":
	                IF NOT (#N.DI_Feedback_OK OR #forceFeedback) THEN
	                    IF #N.FeedbackLostMs = 0 THEN
	                        #N.FeedbackLostMs := TIME_TCK();
	                    END_IF;
	                    IF "FC_TimeElapsedMs"(StartTck := #N.FeedbackLostMs, TimeoutMs := "TimeoutMs_Noria_FeedbackPause",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.FLTCode := #B.FLTCode OR "FLT_NO_FEEDBACK";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                ELSE
	                    #N.FeedbackLostMs := 0;
	                END_IF;
	                IF NOT (#N.DI_Speed_OK OR #forceSpeed) THEN
	                    IF #N.SpeedLostMs = 0 THEN
	                        #N.SpeedLostMs := TIME_TCK();
	                    END_IF;
	                    IF "FC_TimeElapsedMs"(StartTck := #N.SpeedLostMs, TimeoutMs := "TimeoutMs_Noria_SpeedPause",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.FLTCode := #B.FLTCode OR "FLT_NO_RUNFB";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                ELSE
	                    #N.SpeedLostMs := 0;
	                END_IF;
	                
	            "STS_STOPPING":
	                IF (NOT #N.DI_Speed_OK) OR #forceSpeed THEN
	                    #B.Status := "STS_IDLE";
	                    #N.StopMs := 0;
	                    #N.LastStopMs := TIME_TCK();  // Зберігаємо час останньої зупинки
	                ELSE
	                    IF #N.StopMs = 0 THEN
	                        #N.StopMs := TIME_TCK();
	                    END_IF;
	                    IF "FC_TimeElapsedMs"(StartTck := #N.StopMs, TimeoutMs := "TimeoutMs_Noria_Stop",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.FLTCode := #B.FLTCode OR "FLT_STOP_TIMEOUT";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                END_IF;
	        END_CASE;
	        
	        IF #B.Cmd = "CMD_STOP" AND #B.Status <> "STS_IDLE" THEN
	            #B.Status := "STS_STOPPING";
	            #N.StopMs := 0;
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "7) Фіналізація"
	    #N.DO_Run := (#B.Status = "STS_STARTING") OR (#B.Status = "STS_RUNNING");
	    #B.Cmd := "CMD_NONE";
	END_REGION
	
END_FUNCTION
