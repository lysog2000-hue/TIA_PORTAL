FUNCTION "FC_ReceivingPit" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.2
// ==============================================================================
// FC_ReceivingPit - Завальная яма (пассивная стартовая точка)
// ==============================================================================
// Яма не является механизмом - у неё нет автомата, контактора и т.д.
// Единственная функция - хранить GrainType (тип зерна задаётся из SCADA)
// ==============================================================================
   VAR_IN_OUT 
      F : "UDT_ReceivingPit";
      B : "UDT_BaseMechanism";
   END_VAR


BEGIN
	
	// Яма - пассивная точка. Всегда в IDLE, без аварий.
	// GrainType задаётся из SCADA и используется в FC_RouteFSM
	// при валидации маршрута (ReceivingPit ↔ Silos)
	
	IF #B.Status <> "STS_IDLE" AND #B.Status <> "STS_FAULT" THEN
	    #B.Status := "STS_IDLE";
	END_IF;
	
	#B.Cmd := "CMD_NONE";
	
END_FUNCTION

