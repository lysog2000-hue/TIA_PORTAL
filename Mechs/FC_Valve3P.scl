FUNCTION "FC_Valve3P" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.1
// ==============================================================================
// FC_Valve3P - Керування трипозиційним клапаном
// ==============================================================================
// Версія: 1.0.0
// Дата: 2026-03-27
// ==============================================================================
// Призначення:
//   Керування трипозиційним клапаном (3 кінцеві датчики позиції)
//   Архітектура аналогічна FC_Gate2P з розширенням для 3 позицій
//
// Команди (CmdParam1):
//   CMD_VALVE_POS0 (3) - рух у позицію 0
//   CMD_VALVE_POS1 (4) - рух у позицію 1
//   CMD_VALVE_POS2 (5) - рух у позицію 2
//
// Аварії:
//   FLT_BREAKER (11)           - спрацював автомат захисту
//   FLT_VALVE_MOVE_TIMEOUT (19) - таймаут переміщення (>TimeoutMs_Valve_Move)
//   FLT_VALVE_POS_UNKNOWN (20)  - невизначена позиція (>TimeoutMs_Valve_Position_Unknown)
//   FLT_VALVE_MULTIPLE_POS (21) - кілька датчиків позиції активні одночасно
//
// Status_Param:
//   VALVE_AT_POS0 (3) - клапан у позиції 0
//   VALVE_AT_POS1 (4) - клапан у позиції 1
//   VALVE_AT_POS2 (5) - клапан у позиції 2
//   0 - невизначена позиція (у русі або помилка)
//
// Форсування захистів (Force_Code):
//   BIT0 (1)  - forceBreaker (скидає FLT_BREAKER)
//   BIT4 (16) - forceMoveTimeout (скидає FLT_VALVE_MOVE_TIMEOUT)
//   BIT5 (32) - forcePosUnknown (скидає FLT_VALVE_POS_UNKNOWN)
// ==============================================================================
   VAR_IN_OUT 
      V : "UDT_Valve3P";
      B : "UDT_BaseMechanism";
   END_VAR

   VAR_TEMP 
      elapsedMs : DInt;
      nowTck : DInt;
      forceBreaker : Bool;
      forceMoveTimeout : Bool;
      forcePosUnknown : Bool;
      isFault : Bool;
      isBlocked : Bool;
      isKnownPosition : Bool;
      targetReached : Bool;
      paramValid : Bool;
   END_VAR


BEGIN
	
	REGION "0) Декодування форсування"
	    // Єдина таблиця бітів (спільна для всіх механізмів):
	    // BIT0(1)=forceBreaker, BIT4(16)=forceMoveTimeout, BIT5(32)=forcePosUnknown
	    #forceBreaker := (#B.Force_Code AND 1) <> 0;
	    #forceMoveTimeout := (#B.Force_Code AND 16) <> 0;
	    #forcePosUnknown := (#B.Force_Code AND 32) <> 0;
	END_REGION
	
	REGION "1) RESET (Тільки за умови усунення причини)"
	    IF #B.Cmd = "CMD_RESET" THEN
	        IF (#B.FLTCode AND "FLT_BREAKER") <> 0 THEN
	            IF #V.DI_Breaker_OK OR #forceBreaker THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_BREAKER";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_VALVE_MOVE_TIMEOUT") <> 0 THEN
	            #B.FLTCode := #B.FLTCode AND NOT "FLT_VALVE_MOVE_TIMEOUT";
	        END_IF;
	        IF (#B.FLTCode AND "FLT_VALVE_POS_UNKNOWN") <> 0 THEN
	            #B.FLTCode := #B.FLTCode AND NOT "FLT_VALVE_POS_UNKNOWN";
	        END_IF;
	        IF (#B.FLTCode AND "FLT_VALVE_MULTIPLE_POS") <> 0 THEN
	            #B.FLTCode := #B.FLTCode AND NOT "FLT_VALVE_MULTIPLE_POS";
	        END_IF;
	        
	        IF #B.FLTCode = "FLT_NONE" AND #B.Status = "STS_FAULT" THEN
	            IF NOT #B.LocalManual THEN
	                #B.Status := "STS_IDLE";
	            ELSE
	                #B.Status := "STS_LOCAL";
	            END_IF;
	            #V.MoveStartMs := 0;
	            #V.UnknownPositionMs := 0;
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "2) Обробка блокувань"
	    IF NOT #B.Enable_OK THEN
	        #B.Status := "STS_DISABLED";
	        #isBlocked := TRUE;
	    ELSIF #B.LocalManual THEN
	        #B.Status := "STS_LOCAL";
	        #isBlocked := TRUE;
	    ELSE
	        #isBlocked := FALSE;
	        IF (#B.Status = "STS_DISABLED") OR (#B.Status = "STS_LOCAL") THEN
	            #B.Status := "STS_IDLE";
	        END_IF;
	    END_IF;
	    
	    // Скидання міток часу при блокуванні
	    IF #isBlocked THEN
	        #V.MoveStartMs := 0;
	        #V.UnknownPositionMs := 0;
	    END_IF;
	END_REGION
	
	REGION "3) Моніторинг аварій (Diagnostic Latch)"
	    IF #B.FLTCode = "FLT_NONE" AND NOT #isBlocked THEN
	        IF NOT #V.DI_Breaker_OK THEN
	            #B.FLTCode := #B.FLTCode OR "FLT_BREAKER";
	        END_IF;
	        IF (#V.DI_Pos0_OK AND #V.DI_Pos1_OK) OR
	            (#V.DI_Pos0_OK AND #V.DI_Pos2_OK) OR
	            (#V.DI_Pos1_OK AND #V.DI_Pos2_OK) THEN
	            #B.FLTCode := #B.FLTCode OR "FLT_VALVE_MULTIPLE_POS";
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "4) Визначення виконавчої аварії"
	    #isFault := FALSE;
	    IF #B.FLTCode <> "FLT_NONE" THEN
	        IF (#B.FLTCode AND "FLT_BREAKER") <> 0 AND NOT #forceBreaker THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_VALVE_MOVE_TIMEOUT") <> 0 AND NOT #forceMoveTimeout THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_VALVE_POS_UNKNOWN") <> 0 AND NOT #forcePosUnknown THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_VALVE_MULTIPLE_POS") <> 0 THEN
	            #isFault := TRUE;
	        END_IF;
	    END_IF;
	    
	    IF #isFault THEN
	        #B.Status := "STS_FAULT";
	    END_IF;
	    #isFault := (#B.Status = "STS_FAULT");
	END_REGION
	
	REGION "5 & 6) Машина станів (FSM) та обробка команд"
	    // Відоме положення = хоча б один датчик позиції активний (і не кілька одночасно)
	    #isKnownPosition := (#V.DI_Pos0_OK AND NOT #V.DI_Pos1_OK AND NOT #V.DI_Pos2_OK) OR
	    (#V.DI_Pos1_OK AND NOT #V.DI_Pos0_OK AND NOT #V.DI_Pos2_OK) OR
	    (#V.DI_Pos2_OK AND NOT #V.DI_Pos0_OK AND NOT #V.DI_Pos1_OK);
	    
	    IF (NOT #isFault) AND (NOT #isBlocked) THEN
	        IF #B.Cmd <> "CMD_NONE" THEN
	            #B.LastCmd := #B.Cmd;
	        END_IF;
	        
	        CASE #B.Status OF
	            "STS_IDLE":
	                // Контроль перебування у невідомій позиції
	                IF NOT #isKnownPosition THEN
	                    IF #V.UnknownPositionMs = 0 THEN
	                        #V.UnknownPositionMs := TIME_TCK();
	                    END_IF;
	                    
	                    IF "FC_TimeElapsedMs"(StartTck := #V.UnknownPositionMs, TimeoutMs := "TimeoutMs_Valve_Position_Unknown",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        // Фіксуємо аварію тільки якщо НЕ форсовано
	                        IF NOT #forcePosUnknown THEN
	                            #B.FLTCode := #B.FLTCode OR "FLT_VALVE_POS_UNKNOWN";
	                            #B.Status := "STS_FAULT";
	                        END_IF;
	                    END_IF;
	                ELSE
	                    #V.UnknownPositionMs := 0;
	                END_IF;
	                
	                // Старт руху
	                IF #B.Cmd = "CMD_START" THEN
	                    // Перевірка: чи вже досягнуто цільової позиції
	                    #targetReached := (#B.CmdParam1 = "CMD_VALVE_POS0" AND #V.DI_Pos0_OK) OR
	                    (#B.CmdParam1 = "CMD_VALVE_POS1" AND #V.DI_Pos1_OK) OR
	                    (#B.CmdParam1 = "CMD_VALVE_POS2" AND #V.DI_Pos2_OK);
	                    
	                    // Перевірка: валідність параметру команди
	                    #paramValid := (#B.CmdParam1 = "CMD_VALVE_POS0") OR
	                    (#B.CmdParam1 = "CMD_VALVE_POS1") OR
	                    (#B.CmdParam1 = "CMD_VALVE_POS2");
	                    
	                    IF #paramValid AND NOT #targetReached THEN
	                        #B.Status := "STS_STARTING";
	                        #V.MoveStartMs := TIME_TCK();
	                    END_IF;
	                END_IF;
	                
	            "STS_STARTING":
	                // Перехід у RUNNING, якщо клапан почав рух (зійшов з кінцевика)
	                IF (#B.CmdParam1 = "CMD_VALVE_POS0" AND NOT #V.DI_Pos0_OK) OR
	                    (#B.CmdParam1 = "CMD_VALVE_POS1" AND NOT #V.DI_Pos1_OK) OR
	                    (#B.CmdParam1 = "CMD_VALVE_POS2" AND NOT #V.DI_Pos2_OK) THEN
	                    #B.Status := "STS_RUNNING";
	                ELSIF #isKnownPosition THEN
	                    // Якщо вже на іншому кінцевику або не зійшла → повернутись у IDLE
	                    #B.Status := "STS_IDLE";
	                END_IF;
	                
	            "STS_RUNNING":
	                // Таймер контролю руху
	                IF "FC_TimeElapsedMs"(StartTck := #V.MoveStartMs, TimeoutMs := "TimeoutMs_Valve_Move",
	                                          ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                    // Фіксуємо аварію тільки якщо НЕ форсовано
	                    IF NOT #forceMoveTimeout THEN
	                        #B.FLTCode := #B.FLTCode OR "FLT_VALVE_MOVE_TIMEOUT";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                END_IF;
	                
	                // Успішне завершення руху
	                IF (#B.CmdParam1 = "CMD_VALVE_POS0" AND #V.DI_Pos0_OK) OR
	                    (#B.CmdParam1 = "CMD_VALVE_POS1" AND #V.DI_Pos1_OK) OR
	                    (#B.CmdParam1 = "CMD_VALVE_POS2" AND #V.DI_Pos2_OK) THEN
	                    #B.Status := "STS_STOPPING";
	                END_IF;
	                
	            "STS_STOPPING":
	                IF #isKnownPosition THEN
	                    #B.Status := "STS_IDLE";
	                    #V.MoveStartMs := 0;
	                    #V.UnknownPositionMs := 0;
	                END_IF;
	        END_CASE;
	        
	        // Пріоритет команди STOP
	        IF #B.Cmd = "CMD_STOP" AND ((#B.Status = "STS_STARTING") OR (#B.Status = "STS_RUNNING")) THEN
	            #B.Status := "STS_STOPPING";
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "7) Формування виходів DO та Status_Param"
	    // Виходи DO: активні тільки під час STARTING або RUNNING
	    IF (#B.Status = "STS_STARTING") OR (#B.Status = "STS_RUNNING") THEN
	        #V.DO_Pos0 := (#B.CmdParam1 = "CMD_VALVE_POS0");
	        #V.DO_Pos1 := (#B.CmdParam1 = "CMD_VALVE_POS1");
	        #V.DO_Pos2 := (#B.CmdParam1 = "CMD_VALVE_POS2");
	    ELSE
	        #V.DO_Pos0 := FALSE;
	        #V.DO_Pos1 := FALSE;
	        #V.DO_Pos2 := FALSE;
	    END_IF;
	    
	    // Поточна фізична позиція (оновлюється щосканово за кінцевиками)
	    // Два або більше датчиків активні = аварія FLT_VALVE_MULTIPLE_POS → позиція невідома
	    IF #B.Status = "STS_FAULT" OR #B.FLTCode <> 0 OR #B.Status="STS_DISABLED"  THEN
	        #B.Status_Param := "VALVE_FAULT";
	    ELSIF #V.DI_Pos1_OK AND NOT #V.DI_Pos0_OK AND NOT #V.DI_Pos2_OK THEN
	        #B.Status_Param := "VALVE_AT_POS1";    // = 4
	    ELSIF #V.DI_Pos2_OK AND NOT #V.DI_Pos0_OK AND NOT #V.DI_Pos1_OK THEN
	        #B.Status_Param := "VALVE_AT_POS2";    // = 5
	    ELSIF #V.DI_Pos0_OK AND NOT #V.DI_Pos1_OK AND NOT #V.DI_Pos2_OK THEN
	        #B.Status_Param := "VALVE_AT_POS0";    // = 3
	    ELSE
	        #B.Status_Param := 0;                  // невідома (у русі, обидва датчики, або не ініціалізована)
	    END_IF;
	    
	    // Скидання команди
	    #B.Cmd := "CMD_NONE";
	END_REGION
	
END_FUNCTION

