FUNCTION "FC_Fan" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.2
    VAR_IN_OUT
      F : "UDT_Fan";
      B : "UDT_BaseMechanism";
    END_VAR

    VAR_TEMP
      elapsedMs : DInt;
      nowTck    : DInt;
      forceBreaker : Bool;
      forceSpeed   : Bool;
      isFault   : Bool;
      isBlocked : Bool;
    END_VAR

BEGIN

REGION "0) Декодування форсування"
    // BIT0(1)=forceBreaker, BIT2(4)=forceSpeed
    #forceBreaker := (#B.Force_Code AND 1) <> 0;
    #forceSpeed   := (#B.Force_Code AND 4) <> 0;
END_REGION

REGION "1) RESET (Тільки за умови усунення причини)"
    // Скидання FLTCode можливе лише якщо фізичний сигнал OK або активоване форсування
    IF #B.Cmd = "CMD_RESET" THEN
        CASE #B.FLTCode OF
            "FLT_BREAKER":
                IF #F.DI_Breaker_OK OR #forceBreaker THEN #B.FLTCode := "FLT_NONE"; END_IF;
            "FLT_NO_RUNFB":
                IF #F.DI_Feedback_OK OR #forceSpeed THEN #B.FLTCode := "FLT_NONE"; END_IF;
        END_CASE;

        IF #B.FLTCode = "FLT_NONE" AND #B.Status = "STS_FAULT" THEN
            #B.Status := "STS_IDLE";
            #F.StartMs := 0;
        END_IF;
    END_IF;
END_REGION

REGION "2) Обробка блокувань"
    IF NOT #B.Enable_OK THEN
        #B.Status := "STS_DISABLED";
        #isBlocked := TRUE;
    ELSIF #B.LocalManual THEN
        #B.Status := "STS_LOCAL";
        #isBlocked := TRUE;
    ELSE
        #isBlocked := FALSE;
        IF (#B.Status = "STS_DISABLED") OR (#B.Status = "STS_LOCAL") THEN
            #B.Status := "STS_IDLE";
        END_IF;
    END_IF;
END_REGION

REGION "3) Моніторинг аварій (Diagnostic Latch)"
    // Фіксація першої виявленої аварії
    IF #B.FLTCode = "FLT_NONE" AND NOT #isBlocked THEN
        IF NOT #F.DI_Breaker_OK THEN
            #B.FLTCode := "FLT_BREAKER";
        END_IF;
    END_IF;
END_REGION

REGION "4) Визначення виконавчої аварії"
    #isFault := FALSE;
    IF #B.FLTCode <> "FLT_NONE" THEN
        CASE #B.FLTCode OF
            "FLT_BREAKER":  #isFault := NOT #forceBreaker;
            "FLT_NO_RUNFB": #isFault := NOT #forceSpeed;
        END_CASE;
    END_IF;

    IF #isFault THEN
        #B.Status := "STS_FAULT";
    END_IF;
    #isFault := (#B.Status = "STS_FAULT");
END_REGION

REGION "5 & 6) Машина станів та виконання команд"
    IF (NOT #isFault) AND (NOT #isBlocked) THEN
        // Реєстрація останньої надісланої команди
        IF #B.Cmd <> "CMD_NONE" THEN #B.LastCmd := #B.Cmd; END_IF;

        CASE #B.Status OF
            "STS_IDLE":
                IF #B.Cmd = "CMD_START" THEN
                    #B.Status := "STS_STARTING";
                    #F.StartMs := TIME_TCK();
                END_IF;

            "STS_STARTING":
                IF #F.DI_Feedback_OK OR #forceSpeed THEN
                    #B.Status := "STS_RUNNING";
                ELSE
                    IF "FC_TimeElapsedMs"(StartTck := #F.StartMs, TimeoutMs := "TimeoutMs_Fan_Feedback",
                                          ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
                        #B.FLTCode := "FLT_NO_RUNFB";
                        #B.Status  := "STS_FAULT";
                    END_IF;
                END_IF;

            "STS_RUNNING":
                // Миттєвий контроль фідбеку контактора під час роботи
                IF NOT (#F.DI_Feedback_OK OR #forceSpeed) THEN
                    #B.FLTCode := "FLT_NO_RUNFB";
                    #B.Status  := "STS_FAULT";
                END_IF;

            "STS_STOPPING":
                // Вентилятор зупинено при зникненні фідбеку контактора
                IF (NOT #F.DI_Feedback_OK) OR #forceSpeed THEN
                    #B.Status := "STS_IDLE";
                END_IF;
        END_CASE;

        // Пріоритетна зупинка
        IF #B.Cmd = "CMD_STOP" AND #B.Status <> "STS_IDLE" THEN
            #B.Status := "STS_STOPPING";
        END_IF;
    END_IF;
END_REGION

REGION "7) Фіналізація"
    // Вихід на контактор активний у станах розгону та роботи
    #F.DO_Run := (#B.Status = "STS_STARTING") OR (#B.Status = "STS_RUNNING");

    // Скидання поточної команди
    #B.Cmd := "CMD_NONE";
END_REGION

END_FUNCTION
