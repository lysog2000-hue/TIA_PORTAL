FUNCTION "FC_Redler" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.6
   VAR_IN_OUT 
      R : "UDT_Redler";
      B : "UDT_BaseMechanism";
   END_VAR

   VAR_TEMP 
      elapsedMs : DInt;
      nowTck : DInt;
      forceBreaker : Bool;
      forceOverflow : Bool;
      forceSpeed : Bool;
      forceFeedback : Bool;
      forceStopTimeout : Bool;
      isFault : Bool;
      isBlocked : Bool;
   END_VAR


BEGIN
	
	REGION "0) Декодування форсування"
	    // BIT0(1)=forceBreaker, BIT1(2)=forceOverflow, BIT2(4)=forceSpeed, BIT8(256)=forceFeedback, BIT6(64)=forceStopTimeout
	    #forceBreaker := (#B.Force_Code AND 1) <> 0;
	    #forceOverflow := (#B.Force_Code AND 2) <> 0;
	    #forceSpeed := (#B.Force_Code AND 4) <> 0;
	    #forceFeedback := (#B.Force_Code AND 256) <> 0;
	    #forceStopTimeout := (#B.Force_Code AND 64) <> 0;
	END_REGION
	
	REGION "1) RESET (Тільки за умови усунення причини)"
	    IF #B.Cmd = "CMD_RESET" THEN
	        // Скидання бітів аварій, якщо причина усунена
	        IF (#B.FLTCode AND "FLT_BREAKER") <> 0 THEN
	            IF #R.DI_Breaker_OK OR #forceBreaker THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_BREAKER";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_OVERFLOW") <> 0 THEN
	            IF #R.DI_Overflow_OK OR #forceOverflow THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_OVERFLOW";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_NO_RUNFB") <> 0 THEN
	            IF #R.DI_Speed_OK OR #forceSpeed THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_NO_RUNFB";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_NO_FEEDBACK") <> 0 THEN
	            IF #R.DI_Feedback_OK OR #forceFeedback THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_NO_FEEDBACK";
	            END_IF;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_STOP_TIMEOUT") <> 0 THEN
	            IF NOT #R.DI_Speed_OK OR #forceStopTimeout THEN
	                #B.FLTCode := #B.FLTCode AND NOT "FLT_STOP_TIMEOUT";
	            END_IF;
	        END_IF;
	        
	        IF #B.FLTCode = "FLT_NONE" AND #B.Status = "STS_FAULT" THEN
	            #B.Status := "STS_IDLE";
	            #R.StartMs := 0;
	            #R.SpeedLostMs := 0;
	            #R.FeedbackLostMs := 0;
	            #R.StopMs := 0;
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "2) Обробка блокувань"
	    IF NOT #B.Enable_OK THEN
	        #B.Status := "STS_DISABLED";
	        #isBlocked := TRUE;
	    ELSIF #B.LocalManual THEN
	        #B.Status := "STS_LOCAL";
	        #isBlocked := TRUE;
	    ELSE
	        #isBlocked := FALSE;
	        IF (#B.Status = "STS_DISABLED") OR (#B.Status = "STS_LOCAL") THEN
	            #B.Status := "STS_IDLE";
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "3) Моніторинг аварій (Diagnostic Latch)"
	    IF NOT #isBlocked THEN
	        IF NOT #R.DI_Breaker_OK THEN
	            #B.FLTCode := #B.FLTCode OR "FLT_BREAKER";
	        END_IF;
	        IF NOT #R.DI_Overflow_OK THEN
	            #B.FLTCode := #B.FLTCode OR "FLT_OVERFLOW";
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "4) Визначення виконавчої аварії"
	    #isFault := FALSE;
	    IF #B.FLTCode <> "FLT_NONE" THEN
	        IF (#B.FLTCode AND "FLT_BREAKER") <> 0 AND NOT #forceBreaker THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_OVERFLOW") <> 0 AND NOT #forceOverflow THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_NO_RUNFB") <> 0 AND NOT #forceSpeed THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_NO_FEEDBACK") <> 0 AND NOT #forceFeedback THEN
	            #isFault := TRUE;
	        END_IF;
	        IF (#B.FLTCode AND "FLT_STOP_TIMEOUT") <> 0 AND NOT #forceStopTimeout THEN
	            #isFault := TRUE;
	        END_IF;
	    END_IF;
	    
	    IF #isFault THEN
	        #B.Status := "STS_FAULT";
	    END_IF;
	    #isFault := (#B.Status = "STS_FAULT");
	END_REGION
	
	REGION "5 & 6) Машина станів та виконання команд"
	    IF (NOT #isFault) AND (NOT #isBlocked) THEN
	        IF #B.Cmd <> "CMD_NONE" THEN
	            #B.LastCmd := #B.Cmd;
	        END_IF;
	        
	        CASE #B.Status OF
	            "STS_IDLE":
	                IF #B.Cmd = "CMD_START" THEN
	                    // Перевірка мінімального інтервалу перезапуску
	                    IF #R.LastStopMs = 0 OR "FC_TimeElapsedMs"(StartTck := #R.LastStopMs, TimeoutMs := "TimeoutMs_Redler_MinRestart",
	                                                                ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.Status := "STS_STARTING";
	                        #R.StartMs := TIME_TCK();
	                    END_IF;
	                END_IF;
	                
	            "STS_STARTING":
	                IF #R.DI_Speed_OK OR #forceSpeed THEN
	                    #B.Status := "STS_RUNNING";
	                ELSE
	                    IF "FC_TimeElapsedMs"(StartTck := #R.StartMs, TimeoutMs := "TimeoutMs_Redler_Start",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.FLTCode := #B.FLTCode OR "FLT_NO_RUNFB";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                END_IF;
	                
	            "STS_RUNNING":
	                IF NOT (#R.DI_Feedback_OK OR #forceFeedback) THEN
	                    IF #R.FeedbackLostMs = 0 THEN
	                        #R.FeedbackLostMs := TIME_TCK();
	                    END_IF;
	                    IF "FC_TimeElapsedMs"(StartTck := #R.FeedbackLostMs, TimeoutMs := "TimeoutMs_Redler_FeedbackPause",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.FLTCode := #B.FLTCode OR "FLT_NO_FEEDBACK";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                ELSE
	                    #R.FeedbackLostMs := 0;
	                END_IF;
	                IF NOT (#R.DI_Speed_OK OR #forceSpeed) THEN
	                    IF #R.SpeedLostMs = 0 THEN
	                        #R.SpeedLostMs := TIME_TCK();
	                    END_IF;
	                    IF "FC_TimeElapsedMs"(StartTck := #R.SpeedLostMs, TimeoutMs := "TimeoutMs_Redler_SpeedPause",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.FLTCode := #B.FLTCode OR "FLT_NO_RUNFB";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                ELSE
	                    #R.SpeedLostMs := 0;
	                END_IF;
	                
	            "STS_STOPPING":
	                IF (NOT #R.DI_Speed_OK) OR #forceSpeed THEN
	                    #B.Status := "STS_IDLE";
	                    #R.StopMs := 0;
	                    #R.LastStopMs := TIME_TCK();  // Зберігаємо час останньої зупинки
	                ELSE
	                    IF #R.StopMs = 0 THEN
	                        #R.StopMs := TIME_TCK();
	                    END_IF;
	                    IF "FC_TimeElapsedMs"(StartTck := #R.StopMs, TimeoutMs := "TimeoutMs_Redler_Stop",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.FLTCode := #B.FLTCode OR "FLT_STOP_TIMEOUT";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                END_IF;
	        END_CASE;
	        
	        IF #B.Cmd = "CMD_STOP" AND #B.Status <> "STS_IDLE" THEN
	            #B.Status := "STS_STOPPING";
	            #R.StopMs := 0;
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "7) Фіналізація"
	    #R.DO_Run := (#B.Status = "STS_STARTING") OR (#B.Status = "STS_RUNNING");
	    #B.Cmd := "CMD_NONE";
	END_REGION
	
END_FUNCTION
