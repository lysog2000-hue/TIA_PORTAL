FUNCTION "FC_Redler" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.4
    VAR_IN_OUT 
      R : "UDT_Redler";
      B : "UDT_BaseMechanism";
    END_VAR

    VAR_TEMP 
      elapsedMs : DInt;
      nowTck : DInt;
      forceBreaker : Bool;
      forceOverflow : Bool;
      forceSpeed : Bool;
      isFault : Bool;
      isBlocked : Bool;
    END_VAR

BEGIN

REGION "0) Декодування форсування"
    // BIT0(1)=forceBreaker, BIT1(2)=forceOverflow, BIT2(4)=forceSpeed — як у Noria
    #forceBreaker   := (#B.Force_Code AND 1) <> 0;
    #forceOverflow  := (#B.Force_Code AND 2) <> 0;
    #forceSpeed     := (#B.Force_Code AND 4) <> 0;
END_REGION

REGION "1) RESET (Тільки за умови усунення причини)"
    // Скидаємо FLTCode, тільки якщо фізичний сигнал OK або активоване форсування
    IF #B.Cmd = "CMD_RESET" THEN
        CASE #B.FLTCode OF
            "FLT_BREAKER":
                IF #R.DI_Breaker_OK OR #forceBreaker THEN #B.FLTCode := "FLT_NONE"; END_IF;
            "FLT_OVERFLOW":
                IF #R.DI_Overflow_OK OR #forceOverflow THEN #B.FLTCode := "FLT_NONE"; END_IF;
            "FLT_NO_RUNFB":
                IF #R.DI_Speed_OK OR #forceSpeed THEN #B.FLTCode := "FLT_NONE"; END_IF;
        END_CASE;

        IF #B.FLTCode = "FLT_NONE" AND #B.Status = "STS_FAULT" THEN
            #B.Status := "STS_IDLE";
            #R.StartMs := 0;
            #R.SpeedLostMs := 0;
        END_IF;
    END_IF;
END_REGION

REGION "2) Обробка блокувань"
    IF NOT #B.Enable_OK THEN
        #B.Status := "STS_DISABLED";
        #isBlocked := TRUE;
    ELSIF #B.LocalManual THEN
        #B.Status := "STS_LOCAL";
        #isBlocked := TRUE;
    ELSE
        #isBlocked := FALSE;
        IF (#B.Status = "STS_DISABLED") OR (#B.Status = "STS_LOCAL") THEN
            #B.Status := "STS_IDLE";
        END_IF;
    END_IF;
END_REGION

REGION "3) Моніторинг аварій (Diagnostic Latch)"
    // Фіксуємо першу виявлену аварію ("засувка")
    IF #B.FLTCode = "FLT_NONE" AND NOT #isBlocked THEN
        IF NOT #R.DI_Breaker_OK THEN
            #B.FLTCode := "FLT_BREAKER";
        ELSIF NOT #R.DI_Overflow_OK THEN
            #B.FLTCode := "FLT_OVERFLOW";
        END_IF;
    END_IF;
END_REGION

REGION "4) Визначення виконавчої аварії"
    #isFault := FALSE;
    IF #B.FLTCode <> "FLT_NONE" THEN
        CASE #B.FLTCode OF
            "FLT_BREAKER":   #isFault := NOT #forceBreaker;
            "FLT_OVERFLOW":  #isFault := NOT #forceOverflow;
            "FLT_NO_RUNFB":  #isFault := NOT #forceSpeed;
        END_CASE;
    END_IF;

    IF #isFault THEN
        #B.Status := "STS_FAULT";
    END_IF;
    #isFault := (#B.Status = "STS_FAULT");
END_REGION

REGION "5 & 6) Машина станів та виконання команд"
    IF (NOT #isFault) AND (NOT #isBlocked) THEN
        // Фіксація останньої команди
        IF #B.Cmd <> "CMD_NONE" THEN #B.LastCmd := #B.Cmd; END_IF;

        CASE #B.Status OF
            "STS_IDLE":
                IF #B.Cmd = "CMD_START" THEN
                    #B.Status := "STS_STARTING";
                    #R.StartMs := TIME_TCK();
                END_IF;
                
            "STS_STARTING":
                IF #R.DI_Speed_OK OR #forceSpeed THEN
                    #B.Status := "STS_RUNNING";
                ELSE
                    IF "FC_TimeElapsedMs"(StartTck := #R.StartMs, TimeoutMs := "TimeoutMs_Redler_Start",
                                          ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
                        #B.FLTCode := "FLT_NO_RUNFB";
                        #B.Status := "STS_FAULT";
                    END_IF;
                END_IF;

            "STS_RUNNING":
                IF NOT (#R.DI_Speed_OK OR #forceSpeed) THEN
                    IF #R.SpeedLostMs = 0 THEN #R.SpeedLostMs := TIME_TCK(); END_IF;
                    IF "FC_TimeElapsedMs"(StartTck := #R.SpeedLostMs, TimeoutMs := "TimeoutMs_Redler_SpeedPause",
                                          ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
                        #B.FLTCode := "FLT_NO_RUNFB";
                        #B.Status := "STS_FAULT";
                    END_IF;
                ELSE
                    #R.SpeedLostMs := 0;
                END_IF;

            "STS_STOPPING":
                IF (NOT #R.DI_Speed_OK) OR #forceSpeed THEN
                    #B.Status := "STS_IDLE";
                END_IF;
        END_CASE;

        // Команда Стоп (пріоритетна)
        IF #B.Cmd = "CMD_STOP" AND #B.Status <> "STS_IDLE" THEN
            #B.Status := "STS_STOPPING";
        END_IF;
    END_IF;
END_REGION

REGION "7) Фіналізація"
    // Керування виходом DO_Run
    #R.DO_Run := (#B.Status = "STS_STARTING") OR (#B.Status = "STS_RUNNING");
    
    // Скидання команди для запобігання зацикленню
    #B.Cmd := "CMD_NONE";
END_REGION

END_FUNCTION