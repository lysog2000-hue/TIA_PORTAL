FUNCTION "FC_Sushka_1B" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.8
// ==============================================================================
// FC_Sushka_1B - Версия для сушилки с 1 горелкой
// Fans: 0..6 (Breaker), 7..13 (FB)
// Burners: 14..15 (Breaker), 16..17 (FB), 18..19 (Temp), 20..21 (Alarm), 22..23 (Auto)
// Discharge: 24 (FB)
// Levels: 25 (High), 26 (Low)
// ==============================================================================
   VAR_INPUT 
      Index : Int;
   END_VAR

   VAR_IN_OUT 
      B : "UDT_BaseMechanism";
      S : "UDT_Sushka";
      R : "UDT_Sushka_Recipe";
   END_VAR

   VAR_TEMP 
      i : Int;   // Итератор
      timeElapsed : Bool;
      elapsedMs : DInt;
      nowTck : DInt;
      anyFanFault : Bool;   // Флаг аварии любого вентилятора
      anyBurnerFault : Bool;   // Флаг аварии любой горелки
      stepTimeout : DInt;   // Задержка между шагами
      isBreakerFlt : Bool;
      isFbFlt : Bool;
      isTempFlt : Bool;
      isAlarmFlt : Bool;
      isAutoFlt : Bool;
      isFbWait : Bool;   // Флаг завершения задержки пуска для контроля фидбека
      tempWord : Word;
      m : DWord;   // Временная маска бита
      totalCycleMs : DInt; // Общий цикл (Работа + Пауза)
      runTimeMs : DInt;    // Рассчитанное время включения
      scaledPower : Int;   // Для масштабирования AI_Power
      rawNominal : DInt;   // NominalTemp сконвертирован в raw (0-27648)
      raw30Deg : DInt;     // 30 градусов в RAW (0-27648)
      rawTdNom : DInt;     // Рецептная температура сушки в RAW
      rawTpNom : DInt;     // Рецептная температура продукта в RAW
      rawTgNom : DInt;     // Рецептная температура газа в RAW
      rawPWNom : DInt;     // Рецептная температура PW в RAW
      avgTdRaw : DInt;     // Среднее значение датчиков 10..11 в RAW
      avgTpRaw : DInt;     // Значение датчика 14 в RAW
      avgTgRaw : DInt;     // Среднее значение датчиков 6..7 в RAW
      avgPWRaw : DInt;     // Значение датчика 15 в RAW
      raw5Deg : DInt;      // 5 °C в RAW
      isLowLevelActive : Bool;   // Флаг срабатывания нижнего уровня
      isHighLevelActive : Bool;  // Флаг срабатывания верхнего уровня
      isStoppingFault : Bool;   // Флаг критической аварии (требующей останова сушилки)
      isRecipeTempsReady : Bool; // Все три рецептурные температуры достигнуты
      isRecipeTdOver : Bool;  // Перегрев Td
      isRecipeTpOver : Bool;  // Перегрев Tp
      isRecipeTgOver : Bool;  // Перегрев Tg
      isRecipePWOver : Bool;  // Перегрев PW
      isTempOver : Bool;      // Общий признак перегрева для блокировки горелок/выгрузки
      sensorSpan : DInt;      // Диапазон датчика (Max - Min)
      highLevelHoldMs : DInt; // Время удержания уровня в мс
   END_VAR


BEGIN
	    #stepTimeout := 3000; // 3 секунды между включениями компонентов
	    
	    // Расчет параметров масштабирования
	    #sensorSpan := INT_TO_DINT(#R.SensorMax - #R.SensorMin);
	    IF #sensorSpan <= 0 THEN #sensorSpan := 700; END_IF; // Защита от деления на 0
	    
	    #raw30Deg := (30 - INT_TO_DINT(#R.SensorMin)) * 27648 / #sensorSpan;
	    #raw5Deg := (5 * 27648) / #sensorSpan; // 5 градусов в единицах RAW
	    
	    #rawTdNom := (INT_TO_DINT(#R.TdNom) - INT_TO_DINT(#R.SensorMin)) * 27648 / #sensorSpan;
	    #rawTpNom := (INT_TO_DINT(#R.TpNom) - INT_TO_DINT(#R.SensorMin)) * 27648 / #sensorSpan;
	    #rawTgNom := (INT_TO_DINT(#R.TgNom) - INT_TO_DINT(#R.SensorMin)) * 27648 / #sensorSpan;
	    #rawPWNom := (INT_TO_DINT(#R.PWNom) - INT_TO_DINT(#R.SensorMin)) * 27648 / #sensorSpan;

	    // Приводим время к миллисекундам один раз
	    #highLevelHoldMs := #R.Time_High_Level * 1000;

	    #avgTdRaw := (INT_TO_DINT(#S.Temps[10]) + INT_TO_DINT(#S.Temps[11])) / 2;
	    #avgTpRaw := INT_TO_DINT(#S.Temps[14]);
	    #avgTgRaw := (INT_TO_DINT(#S.Temps[6]) + INT_TO_DINT(#S.Temps[7])) / 2;
	    #avgPWRaw := INT_TO_DINT(#S.Temps[15]);
	    #isRecipeTempsReady := (#avgTdRaw >= #rawTdNom) AND (#avgTpRaw >= #rawTpNom) AND (#avgTgRaw >= #rawTgNom) AND (#avgPWRaw >= #rawPWNom);
	    
	    // Логика гистерезиса: включаем блокировку при Nom+5, выключаем только при спуске до Nom
	    // Зона Td
	    IF (#avgTdRaw > (#rawTdNom + #raw5Deg)) THEN #isRecipeTdOver := TRUE;
	    ELSIF (#avgTdRaw <= #rawTdNom) THEN #isRecipeTdOver := FALSE;
	    ELSE #isRecipeTdOver := (#S.FLTCode AND DW#16#8000000) <> 0; END_IF;
	    #isRecipeTdOver := #isRecipeTdOver AND ((#S.ForceCode AND DW#16#8000000) = 0);

	    // Зона Tp
	    IF (#avgTpRaw > (#rawTpNom + #raw5Deg)) THEN #isRecipeTpOver := TRUE;
	    ELSIF (#avgTpRaw <= #rawTpNom) THEN #isRecipeTpOver := FALSE;
	    ELSE #isRecipeTpOver := (#S.FLTCode AND DW#16#10000000) <> 0; END_IF;
	    #isRecipeTpOver := #isRecipeTpOver AND ((#S.ForceCode AND DW#16#10000000) = 0);

	    // Зона Tg
	    IF (#avgTgRaw > (#rawTgNom + #raw5Deg)) THEN #isRecipeTgOver := TRUE;
	    ELSIF (#avgTgRaw <= #rawTgNom) THEN #isRecipeTgOver := FALSE;
	    ELSE #isRecipeTgOver := (#S.FLTCode AND DW#16#20000000) <> 0; END_IF;
	    #isRecipeTgOver := #isRecipeTgOver AND ((#S.ForceCode AND DW#16#20000000) = 0);

	    // Зона PW
	    IF (#avgPWRaw > (#rawPWNom + #raw5Deg)) THEN #isRecipePWOver := TRUE;
	    ELSIF (#avgPWRaw <= #rawPWNom) THEN #isRecipePWOver := FALSE;
	    ELSE #isRecipePWOver := (#S.FLTCode AND DW#16#40000000) <> 0; END_IF;
	    #isRecipePWOver := #isRecipePWOver AND ((#S.ForceCode AND DW#16#40000000) = 0);

	    #isTempOver := #isRecipeTdOver OR #isRecipeTpOver OR #isRecipeTgOver OR #isRecipePWOver;
	    
	    // 1. Сброс аварий (RESET)
	    IF #B.Cmd = "CMD_RESET" THEN
	        #S.FLTCode := 16#0; // Сброс детальной маски
	        #B.FLTCode := 16#0; // Сброс базовой маски
	        IF #B.FLTCode = "FLT_NONE" AND #B.Status = "STS_FAULT" THEN
	            IF NOT #B.LocalManual THEN
	                #B.Status := "STS_IDLE";
	                #S.Status := "STS_IDLE";
	            ELSE
	                #B.Status := "STS_LOCAL";
	                #S.Status := "STS_IDLE";
	            END_IF;
	        END_IF;
	        IF #B.Enable_OK AND #B.Status = "STS_DISABLED" THEN
	            #B.Status := "STS_IDLE";
	            #S.Status := "STS_IDLE";
	        END_IF;
	    END_IF;
	    
	    // 2. Мониторинг под-устройств (Вентиляторы и Горелки)
	    #anyFanFault := FALSE;
	    FOR #i := 0 TO 6 DO
	        #isBreakerFlt := NOT #S.Fans[#i].DI_Breaker_OK AND ((#S.ForceCode AND SHL(IN := DW#16#1, N := INT_TO_UINT(#i))) = 0);
	        
	        #isFbWait := (#B.Status = "STS_RUNNING") OR (#B.Status = "STS_STARTING" AND #S.Step > (#i + 1));
	        #m := SHL(IN := DW#16#1, N := INT_TO_UINT(#i + 7)); // Бит 7..13 (Feedback)
	        
	        // Контроль фидбека вентиляторов с задержкой 2с
	        IF #S.Fans[#i].DO_Run AND NOT #S.Fans[#i].DI_Feedback_OK AND #isFbWait AND ((#S.ForceCode AND #m) = 0) THEN
	            IF #S.FbTck[#i + 1] = 0 THEN
	                #S.FbTck[#i + 1] := TIME_TCK();
	                #isFbFlt := FALSE;
	            ELSE
	                #isFbFlt := "FC_TimeElapsedMs"(StartTck := #S.FbTck[#i + 1], TimeoutMs := 2000, ElapsedMs => #elapsedMs, NowTck => #nowTck);
	            END_IF;
	        ELSE
	            #S.FbTck[#i + 1] := 0;
	            #isFbFlt := FALSE;
	        END_IF;
	        
	        IF #isBreakerFlt OR #isFbFlt THEN
	            #S.Fans[#i].Status := "STS_FAULT";
	            #anyFanFault := TRUE;
	            IF #isBreakerFlt THEN
	                #S.FLTCode := #S.FLTCode OR SHL(IN := DW#16#1, N := INT_TO_UINT(#i));
	            END_IF;
	            IF #isFbFlt THEN
	                #S.FLTCode := #S.FLTCode OR #m;
	            END_IF;
	        ELSIF NOT #S.Fans[#i].DO_Run THEN
	            IF #B.Status = "STS_STOPPING" AND #S.Step = (#i + 1) THEN
	                #S.Fans[#i].Status := "STS_STOPPING";
	            ELSE
	                #S.Fans[#i].Status := "STS_IDLE";
	            END_IF;
	        ELSE
	            IF #B.Status = "STS_STARTING" AND #S.Step = (#i + 1) THEN
	                #S.Fans[#i].Status := "STS_STARTING";
	            ELSE
	                #S.Fans[#i].Status := "STS_RUNNING";
	            END_IF;
	        END_IF;
	    END_FOR;
	    
	    #anyBurnerFault := FALSE;
	    FOR #i := 0 TO 0 DO
	        #isBreakerFlt := NOT #S.Burners[#i].DI_Breaker_OK AND ((#S.ForceCode AND SHL(IN := DW#16#1, N := INT_TO_UINT(14 + #i))) = 0);
	        #isTempFlt := NOT #S.Burners[#i].DI_Temp_OK AND ((#S.ForceCode AND SHL(IN := DW#16#1, N := INT_TO_UINT(18 + #i))) = 0);
	        #isAlarmFlt := #S.Burners[#i].DI_Alarm AND ((#S.ForceCode AND SHL(IN := DW#16#1, N := INT_TO_UINT(20 + #i))) = 0);
	        #isAutoFlt := NOT #S.Burners[#i].DI_Auto_OK AND ((#S.ForceCode AND SHL(IN := DW#16#1, N := INT_TO_UINT(22 + #i))) = 0);
	        
	        // Фидбек контролируется когда горелка включена и B.Status=RUNNING
	        #isFbWait := #S.Burners[#i].DO_Run AND #B.Status = "STS_RUNNING";
	        
	        IF #S.Burners[#i].DO_Run AND (NOT #S.Burners[#i].DI_Feedback1_OK OR NOT #S.Burners[#i].DI_Feedback2_OK)
	            AND #isFbWait AND ((#S.ForceCode AND SHL(IN := DW#16#1, N := INT_TO_UINT(16 + #i))) = 0) THEN
	            IF #S.FbTck[#i + 8] = 0 THEN
	                #S.FbTck[#i + 8] := TIME_TCK();
	                #isFbFlt := FALSE;
	            ELSE
	                #isFbFlt := "FC_TimeElapsedMs"(StartTck := #S.FbTck[#i + 8], TimeoutMs := 2000, ElapsedMs => #elapsedMs, NowTck => #nowTck);
	            END_IF;
	        ELSE
	            #S.FbTck[#i + 8] := 0;
	            #isFbFlt := FALSE;
	        END_IF;
	        
	        IF #isBreakerFlt OR #isTempFlt OR #isAlarmFlt OR #isFbFlt OR #isAutoFlt THEN
	            #S.Burners[#i].Status := "STS_FAULT";
	            #anyBurnerFault := TRUE;
	            IF #isBreakerFlt THEN #S.FLTCode := #S.FLTCode OR SHL(IN := DW#16#1, N := INT_TO_UINT(14 + #i)); END_IF;
	            IF #isFbFlt     THEN #S.FLTCode := #S.FLTCode OR SHL(IN := DW#16#1, N := INT_TO_UINT(16 + #i)); END_IF;
	            IF #isTempFlt   THEN #S.FLTCode := #S.FLTCode OR SHL(IN := DW#16#1, N := INT_TO_UINT(18 + #i)); END_IF;
	            IF #isAlarmFlt  THEN #S.FLTCode := #S.FLTCode OR SHL(IN := DW#16#1, N := INT_TO_UINT(20 + #i)); END_IF;
	            IF #isAutoFlt   THEN #S.FLTCode := #S.FLTCode OR SHL(IN := DW#16#1, N := INT_TO_UINT(22 + #i)); END_IF;
	        ELSIF NOT #S.Burners[#i].DO_Run THEN
	            IF #B.Status = "STS_STOPPING" AND #S.Step = (8 + #i) THEN
	                #S.Burners[#i].Status := "STS_STOPPING";
	            ELSE
	                #S.Burners[#i].Status := "STS_IDLE";
	            END_IF;
	        ELSE
	            // DO_Run=TRUE:
	            // STARTING — шаг 8 (запуск горелки)
	            // RUNNING  — шаг 9+ (ждём T°) или B.Status=RUNNING
	            IF #B.Status = "STS_STARTING" AND #S.Step = 8 THEN
	                #S.Burners[#i].Status := "STS_STARTING";
	            ELSE
	                #S.Burners[#i].Status := "STS_RUNNING";
	            END_IF;
	        END_IF;
	    END_FOR;
	    
	    // 3. Выгрузка и Уровни
	    IF #S.Discharge.DO_Run AND NOT #S.Discharge.DI_Feedback_OK AND ((#S.ForceCode AND DW#16#1000000) = 0) THEN
	        IF #S.FbTck[10] = 0 THEN
	            #S.FbTck[10] := TIME_TCK();
	        ELSIF "FC_TimeElapsedMs"(StartTck := #S.FbTck[10], TimeoutMs := 2000, ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	            #S.FLTCode := #S.FLTCode OR DW#16#1000000; // Бит 24
	        END_IF;
	    ELSE
	        #S.FbTck[10] := 0;
	    END_IF;
	    
	    // Логика удержания верхнего уровня (Minimum Hold Time)
	    IF NOT #S.Levels.High_OK THEN
	        #S.FbTck[11] := TIME_TCK(); // Запуск/обновление таймера при срабатывании датчика
	    END_IF;
	    
	    IF #S.FbTck[11] <> 0 THEN
	        #isHighLevelActive := TRUE;
	        // Если время удержания вышло И физический датчик в норме — отпускаем логический уровень
	        IF "FC_TimeElapsedMs"(StartTck := #S.FbTck[11], TimeoutMs := #highLevelHoldMs, ElapsedMs => #elapsedMs, NowTck => #nowTck) AND #S.Levels.High_OK THEN
	            #S.FbTck[11] := 0;
	            #isHighLevelActive := FALSE;
	        END_IF;
	    ELSE
	        #isHighLevelActive := FALSE;
	    END_IF;
	    
	    // Динамическое обновление битов уровней и перегревов (25-30)
	    #S.FLTCode := #S.FLTCode AND DW#16#81FFFFFF;
	    
	    IF #isHighLevelActive AND ((#S.ForceCode AND DW#16#2000000) = 0) THEN
	        #S.FLTCode := #S.FLTCode OR DW#16#2000000; // Бит 25
	    END_IF;
	    IF NOT #S.Levels.Low_OK AND ((#S.ForceCode AND DW#16#4000000) = 0) THEN
	        #S.FLTCode := #S.FLTCode OR DW#16#4000000; // Бит 26
	    END_IF;
	    IF #isRecipeTdOver THEN
	        #S.FLTCode := #S.FLTCode OR DW#16#8000000; // Бит 27
	    END_IF;
	    IF #isRecipeTpOver THEN
	        #S.FLTCode := #S.FLTCode OR DW#16#10000000; // Бит 28
	    END_IF;
	    IF #isRecipeTgOver THEN
	        #S.FLTCode := #S.FLTCode OR DW#16#20000000; // Бит 29
	    END_IF;
	    IF #isRecipePWOver THEN
	        #S.FLTCode := #S.FLTCode OR DW#16#40000000; // Бит 30
	    END_IF;
	    
	    // Связь с базовым механизмом: если есть хоть одна ошибка в S.FLTCode, 
	    // ставим общую аварию в B.FLTCode для Арбитра и Маршрутов.
	    IF #S.FLTCode <> DW#16#0 THEN
	        #B.FLTCode := #B.FLTCode OR W#16#0001; // Просто "Авария" в базовом слоте
	    END_IF;
	    
	    // 4. Определение общего статуса
	    IF NOT #B.Enable_OK THEN
	        #B.Status := "STS_DISABLED";
	        #S.Step := 0;
	    ELSIF #B.LocalManual THEN
	        #B.Status := "STS_LOCAL";
	        #S.Step := 0;
	    ELSIF #B.FLTCode <> 0 THEN // Любой бит в маске — это авария
	        #B.Status := "STS_FAULT";
	        #S.Step := 0;
	    ELSE
	        CASE #B.Status OF
	            "STS_IDLE":
	                // Сушилка запускается ТОЛЬКО оператором вручную (OWNER_SCADA)
	                IF #B.Cmd = "CMD_START" AND #B.OwnerCur = "OWNER_SCADA" THEN
	                    // Сушилка готова к пуску если:
	                    // 1. Прошло время отдыха первого вентилятора
	                    // 2. Горелки в режиме AUTO
	                    #timeElapsed := #S.Fans[0].LastStopMs = 0 OR
	                    "FC_TimeElapsedMs"(StartTck := #S.Fans[0].LastStopMs,
	                                       TimeoutMs := 5000,
	                                       ElapsedMs => #elapsedMs,
	                                       NowTck => #nowTck);
	                    
	                    // Проверяем только горелку №0
	                    IF #timeElapsed AND #S.Burners[0].DI_Auto_OK THEN
	                        #B.Status := "STS_STARTING";
	                        #S.Step := 1;
	                        #S.StepStartTck := TIME_TCK();
	                    END_IF;
	                END_IF;
	                
	            "STS_STARTING":
	                #timeElapsed := "FC_TimeElapsedMs"(StartTck := #S.StepStartTck,
	                                                   TimeoutMs := #stepTimeout,
	                                                   ElapsedMs => #elapsedMs,
	                                                   NowTck => #nowTck);
	                IF #timeElapsed THEN
	                    IF #S.Step < 8 THEN
	                        IF (#S.Step + 1) <= 7 THEN
	                            IF #S.Fans[#S.Step].LastStopMs = 0 OR "FC_TimeElapsedMs"(StartTck := #S.Fans[#S.Step].LastStopMs,
	                                                                                             TimeoutMs := 5000,
	                                                                                             ElapsedMs => #elapsedMs,
	                                                                                             NowTck => #nowTck) THEN
	                                #S.Step := #S.Step + 1;
	                                #S.StepStartTck := TIME_TCK();
	                            END_IF;
	                        ELSE
	                            #S.Step := #S.Step + 1;
	                            #S.StepStartTck := TIME_TCK();
	                        END_IF;
	                    ELSIF #S.Step = 8 THEN
	                        // Шаг 9: горелка запущена, переходим на ожидание температуры
	                        #S.Step := 9;
	                        #S.StepStartTck := TIME_TCK();
	                    ELSE
	                        // Шаг 9: ждём соответствия рецептурных температур
	                        IF #isRecipeTempsReady THEN
	                            IF #highLevelHoldMs <= 0 OR
	                               "FC_TimeElapsedMs"(StartTck := #S.StepStartTck,
	                                                   TimeoutMs := #highLevelHoldMs,
	                                                   ElapsedMs => #elapsedMs,
	                                                   NowTck => #nowTck) THEN
	                                #B.Status := "STS_RUNNING";
	                            END_IF;
	                        END_IF;
	                    END_IF;
	                END_IF;
	                
	                IF #B.Cmd = "CMD_STOP" THEN
	                    #B.Status := "STS_STOPPING";
	                    #S.StepStartTck := TIME_TCK();
	                END_IF;
	                
	            "STS_RUNNING":
	                IF #B.Cmd = "CMD_STOP" THEN
	                    #B.Status := "STS_STOPPING";
	                    #S.Step := 9;
	                    #S.StepStartTck := TIME_TCK();
	                END_IF;
	                
	            "STS_STOPPING":
	                #timeElapsed := "FC_TimeElapsedMs"(StartTck := #S.StepStartTck,
	                                                   TimeoutMs := #stepTimeout,
	                                                   ElapsedMs => #elapsedMs,
	                                                   NowTck => #nowTck);
	                IF #timeElapsed THEN
	                    // Если текущий шаг — вентилятор, фиксируем время его остановки
	                    IF #S.Step >= 1 AND #S.Step <= 7 THEN
	                        #S.Fans[#S.Step - 1].LastStopMs := TIME_TCK();
	                    END_IF;
	                    
	                    IF #S.Step > 0 THEN
	                        #S.Step := #S.Step - 1;
	                        #S.StepStartTck := TIME_TCK();
	                    END_IF;
	                    
	                    IF #S.Step = 0 THEN
	                        #B.Status := "STS_IDLE";
	                    END_IF;
	                END_IF;
	        END_CASE;
	    END_IF;
	    
	    // 5. Распределение команд на компоненты
	    IF #B.Status = "STS_FAULT" OR #B.Status = "STS_DISABLED" THEN
	        // Гасим всё при аварии или остановке
	        FOR #i := 0 TO 6 DO
	            #S.Fans[#i].DO_Run := FALSE;
	        END_FOR;
	        FOR #i := 0 TO 0 DO
	            #S.Burners[#i].DO_Run := FALSE;
	            #S.Burners[#i].AQ_Power := 0;
	        END_FOR;
	        #S.Discharge.DO_Run := FALSE;
	        #S.DischargeTimerTck := 0;
	    ELSE
	        // Управление вентиляторами (Шаги 1-7)
	        FOR #i := 0 TO 6 DO
	            IF #B.Status = "STS_RUNNING" THEN
	                #S.Fans[#i].DO_Run := TRUE;
	            ELSIF #B.Status = "STS_STARTING" AND #S.Step >= (#i + 1) THEN
	                #S.Fans[#i].DO_Run := TRUE;
	            ELSIF #B.Status = "STS_STOPPING" AND #S.Step >= (#i + 1) THEN
	                #S.Fans[#i].DO_Run := TRUE;
	            ELSE
	                #S.Fans[#i].DO_Run := FALSE;
	            END_IF;
	        END_FOR;

	        // Управление горелками (Шаги 8-9)
	        FOR #i := 0 TO 0 DO
            #scaledPower := #S.Burners[#i].AI_Power;
            IF #scaledPower < 0 THEN #scaledPower := 0; END_IF;
            IF #scaledPower > 100 THEN #scaledPower := 100; END_IF;
                #S.Burners[#i].AQ_Power := DINT_TO_INT((INT_TO_DINT(#scaledPower) * 27648) / 100);
            
	            // Горелка работает только если нет перегрева
	            IF (#B.Status = "STS_RUNNING" AND NOT #isTempOver) THEN
	                #S.Burners[#i].DO_Run := TRUE;
	            ELSIF (#B.Status = "STS_STARTING" AND #S.Step >= 8 AND NOT #isTempOver) THEN
	                #S.Burners[#i].DO_Run := TRUE;
	            ELSIF #B.Status = "STS_STOPPING" AND #S.Step > 8 THEN
	                #S.Burners[#i].DO_Run := TRUE;
	            ELSE
	                #S.Burners[#i].AQ_Power := 0;
	            END_IF;
	        END_FOR;
	        
	        // Горелка №1 всегда выключена в этой версии
	        #S.Burners[1].DO_Run := FALSE;
	        #S.Burners[1].AQ_Power := 0;
	        
	         // Периодическое управление выгрузкой (PWM на базе процента)
	        IF #B.Status = "STS_RUNNING" AND #R.DischargePercent > 0 AND NOT #isTempOver THEN
	            #runTimeMs := (INT_TO_DINT(#R.DischargePercent) * #R.MaxTimeRun) / 100;
	            #totalCycleMs := #runTimeMs + (INT_TO_DINT(#R.DischargePercent) * #R.MaxTimePause) / 100;
	            
	            // Проверка прогресса текущего цикла
	            #timeElapsed := "FC_TimeElapsedMs"(StartTck := #S.DischargeTimerTck, TimeoutMs := #totalCycleMs, ElapsedMs => #elapsedMs, NowTck => #nowTck);
	            
	            // Сброс или перезапуск таймера при завершении цикла
	            IF #S.DischargeTimerTck = 0 OR #timeElapsed THEN
	                #S.DischargeTimerTck := #nowTck;
	                #elapsedMs := 0;
	            END_IF;
	            
	            #S.Discharge.DO_Run := #elapsedMs < #runTimeMs;
	        ELSE
	            #S.Discharge.DO_Run := FALSE;
	            #S.DischargeTimerTck := 0;
	        END_IF;
	    END_IF;
	    
	    IF #B.Cmd <> "CMD_NONE" THEN
	        #B.LastCmd := #B.Cmd;
	    END_IF;
	    #B.Cmd := "CMD_NONE";
	    IF #S.ForceCode <> 0 THEN
	        #B.Force_Code := 1;
	    ELSE
	        #B.Force_Code := 0;
	    END_IF;
	    
END_FUNCTION
