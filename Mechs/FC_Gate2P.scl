FUNCTION "FC_Gate2P" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.4
   VAR_IN_OUT 
      G : "UDT_Gate2P";
      B : "UDT_BaseMechanism";
   END_VAR

   VAR_TEMP 
      elapsedMs : DInt;
      nowTck : DInt;
      forceBreaker : Bool;
      forceMoveTimeout : Bool;
      forcePosUnknown : Bool;
      isFault : Bool;
      isBlocked : Bool;
      isKnownPosition : Bool;
      targetReached : Bool;
      paramValid : Bool;
   END_VAR


BEGIN
	
	
	REGION "0) Ð”ÐµÐºÐ¾Ð´ÑƒÐ²Ð°Ð½Ð½Ñ Ñ„Ð¾Ñ€ÑÑƒÐ²Ð°Ð½Ð½Ñ"
	    // Ð„Ð´Ð¸Ð½Ð° Ñ‚Ð°Ð±Ð»Ð¸Ñ†Ñ Ð±Ñ–Ñ‚Ñ–Ð² (ÑÐ¿Ñ–Ð»ÑŒÐ½Ð° Ð´Ð»Ñ Ð²ÑÑ–Ñ… Ð¼ÐµÑ…Ð°Ð½Ñ–Ð·Ð¼Ñ–Ð²):
	    // BIT0(1)=forceBreaker, BIT4(16)=forceMoveTimeout, BIT5(32)=forcePosUnknown
	    #forceBreaker := (#B.Force_Code AND 1) <> 0;
	    #forceMoveTimeout := (#B.Force_Code AND 16) <> 0;
	    #forcePosUnknown := (#B.Force_Code AND 32) <> 0;
	END_REGION
	
	REGION "1) RESET (Ð¢Ñ–Ð»ÑŒÐºÐ¸ Ð·Ð° ÑƒÐ¼Ð¾Ð²Ð¸ ÑƒÑÑƒÐ½ÐµÐ½Ð½Ñ Ð¿Ñ€Ð¸Ñ‡Ð¸Ð½Ð¸)"
	    IF #B.Cmd = "CMD_RESET" THEN
	        CASE #B.FLTCode OF
	            "FLT_BREAKER":
	                IF #G.DI_Breaker_OK OR #forceBreaker THEN
	                    #B.FLTCode := "FLT_NONE";
	                END_IF;
	                
	            "FLT_GATE_MOVE_TIMEOUT", "FLT_GATE_POS_UNKNOWN", "FLT_BOTH_SENSORS":
	                #B.FLTCode := "FLT_NONE";
	        END_CASE;
	        
	        IF #B.FLTCode = "FLT_NONE" AND #B.Status = "STS_FAULT" THEN
	            #B.Status := "STS_IDLE";
	            #G.MoveStartMs := 0;
	            #G.UnknownPositionMs := 0;
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "2) ÐžÐ±Ñ€Ð¾Ð±ÐºÐ° Ð±Ð»Ð¾ÐºÑƒÐ²Ð°Ð½ÑŒ"
	    IF NOT #B.Enable_OK THEN
	        #B.Status := "STS_DISABLED";
	        #isBlocked := TRUE;
	    ELSIF #B.LocalManual THEN
	        #B.Status := "STS_LOCAL";
	        #isBlocked := TRUE;
	    ELSE
	        #isBlocked := FALSE;
	        IF (#B.Status = "STS_DISABLED") OR (#B.Status = "STS_LOCAL") THEN
	            #B.Status := "STS_IDLE";
	        END_IF;
	    END_IF;
	    
	    // Ð¡ÐºÐ¸Ð´Ð°Ð½Ð½Ñ Ð¼Ñ–Ñ‚Ð¾Ðº Ñ‡Ð°ÑÑƒ Ð¿Ñ€Ð¸ Ð±Ð»Ð¾ÐºÑƒÐ²Ð°Ð½Ð½Ñ–
	    IF #isBlocked THEN
	        #G.MoveStartMs := 0;
	        #G.UnknownPositionMs := 0;
	    END_IF;
	END_REGION
	
	REGION "3) ÐœÐ¾Ð½Ñ–Ñ‚Ð¾Ñ€Ð¸Ð½Ð³ Ð°Ð²Ð°Ñ€Ñ–Ð¹ (Diagnostic Latch)"
	    IF #B.FLTCode = "FLT_NONE" AND NOT #isBlocked THEN
	        IF NOT #G.DI_Breaker_OK THEN
	            #B.FLTCode := "FLT_BREAKER";
	        ELSIF #G.DI_Pos0_OK AND #G.DI_Pos1_OK THEN
	            #B.FLTCode := "FLT_BOTH_SENSORS";
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "4) Ð’Ð¸Ð·Ð½Ð°Ñ‡ÐµÐ½Ð½Ñ Ð²Ð¸ÐºÐ¾Ð½Ð°Ð²Ñ‡Ð¾Ñ— Ð°Ð²Ð°Ñ€Ñ–Ñ—"
	    #isFault := FALSE;
	    IF #B.FLTCode <> "FLT_NONE" THEN
	        CASE #B.FLTCode OF
	            "FLT_BREAKER":
	                #isFault := NOT #forceBreaker;
	            "FLT_GATE_MOVE_TIMEOUT":
	                #isFault := NOT #forceMoveTimeout;
	            "FLT_GATE_POS_UNKNOWN":
	                #isFault := NOT #forcePosUnknown;
	            "FLT_BOTH_SENSORS":
	                #isFault := TRUE;
	        END_CASE;
	    END_IF;
	    
	    IF #isFault THEN
	        #B.Status := "STS_FAULT";
	    END_IF;
	    #isFault := (#B.Status = "STS_FAULT");
	END_REGION
	
	REGION "5 & 6) ÐœÐ°ÑˆÐ¸Ð½Ð° ÑÑ‚Ð°Ð½Ñ–Ð² (FSM) Ñ‚Ð° Ð¾Ð±Ñ€Ð¾Ð±ÐºÐ° ÐºÐ¾Ð¼Ð°Ð½Ð´"
	    #isKnownPosition := #G.DI_Pos0_OK OR #G.DI_Pos1_OK;
	    
	    IF (NOT #isFault) AND (NOT #isBlocked) THEN
	        IF #B.Cmd <> "CMD_NONE" THEN
	            #B.LastCmd := #B.Cmd;
	        END_IF;
	        
	        CASE #B.Status OF
	            "STS_IDLE":
	                // ÐšÐ¾Ð½Ñ‚Ñ€Ð¾Ð»ÑŒ Ð¿ÐµÑ€ÐµÐ±ÑƒÐ²Ð°Ð½Ð½Ñ Ð² Ð½ÐµÐ²Ñ–Ð´Ð¾Ð¼Ñ–Ð¹ Ð¿Ð¾Ð·Ð¸Ñ†Ñ–Ñ—
	                IF NOT #isKnownPosition THEN
	                    IF #G.UnknownPositionMs = 0 THEN
	                        #G.UnknownPositionMs := TIME_TCK();
	                    END_IF;
	                    
	                    IF "FC_TimeElapsedMs"(StartTck := #G.UnknownPositionMs, TimeoutMs := "TimeoutMs_Gate_Position_Unknown",
	                                              ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                        #B.FLTCode := "FLT_GATE_POS_UNKNOWN";
	                        #B.Status := "STS_FAULT";
	                    END_IF;
	                ELSE
	                    #G.UnknownPositionMs := 0;
	                END_IF;
	                
	                // Ð¡Ñ‚Ð°Ñ€Ñ‚ Ñ€ÑƒÑ…Ñƒ
	                IF #B.Cmd = "CMD_START" THEN
	                    #targetReached := (#B.CmdParam1 = "CMD_GATE_POS0" AND #G.DI_Pos0_OK) OR
	                    (#B.CmdParam1 = "CMD_GATE_POS1" AND #G.DI_Pos1_OK);
	                    #paramValid := (#B.CmdParam1 = "CMD_GATE_POS0") OR (#B.CmdParam1 = "CMD_GATE_POS1");
	                    
	                    IF #paramValid AND NOT #targetReached THEN
	                        #B.Status := "STS_STARTING";
	                        #G.MoveStartMs := TIME_TCK();
	                    END_IF;
	                END_IF;
	                
	            "STS_STARTING":
	                // ÐŸÐµÑ€ÐµÑ…Ñ–Ð´ Ñƒ RUNNING, ÑÐºÑ‰Ð¾ Ð·Ð°ÑÑƒÐ²ÐºÐ° Ð¿Ð¾Ñ‡Ð°Ð»Ð° Ñ€ÑƒÑ… (Ð·Ñ–Ð¹ÑˆÐ»Ð° Ð· ÐºÑ–Ð½Ñ†ÐµÐ²Ð¸ÐºÐ°)
	                IF (#B.CmdParam1 = "CMD_GATE_POS0" AND NOT #G.DI_Pos0_OK) OR
	                    (#B.CmdParam1 = "CMD_GATE_POS1" AND NOT #G.DI_Pos1_OK) THEN
	                    #B.Status := "STS_RUNNING";
	                ELSIF #isKnownPosition THEN // Ð¯ÐºÑ‰Ð¾ Ð²Ð¶Ðµ Ð½Ð° Ñ–Ð½ÑˆÐ¾Ð¼Ñƒ ÐºÑ–Ð½Ñ†ÐµÐ²Ð¸ÐºÑƒ Ð°Ð±Ð¾ Ð½Ðµ Ð·Ñ–Ð¹ÑˆÐ»Ð°
	                    #B.Status := "STS_IDLE";
	                END_IF;
	                
	            "STS_RUNNING":
	                // Ð¢Ð°Ð¹Ð¼ÐµÑ€ ÐºÐ¾Ð½Ñ‚Ñ€Ð¾Ð»ÑŽ Ñ€ÑƒÑ…Ñƒ
	                IF "FC_TimeElapsedMs"(StartTck := #G.MoveStartMs, TimeoutMs := "TimeoutMs_Gate_Move",
	                                          ElapsedMs => #elapsedMs, NowTck => #nowTck) THEN
	                    #B.FLTCode := "FLT_GATE_MOVE_TIMEOUT";
	                    #B.Status := "STS_FAULT";
	                END_IF;
	                
	                // Ð£ÑÐ¿Ñ–ÑˆÐ½Ðµ Ð·Ð°Ð²ÐµÑ€ÑˆÐµÐ½Ð½Ñ Ñ€ÑƒÑ…Ñƒ
	                IF (#B.CmdParam1 = "CMD_GATE_POS0" AND #G.DI_Pos0_OK) OR
	                    (#B.CmdParam1 = "CMD_GATE_POS1" AND #G.DI_Pos1_OK) THEN
	                    #B.Status := "STS_STOPPING";
	                END_IF;
	                
	            "STS_STOPPING":
	                IF #isKnownPosition THEN
	                    #B.Status := "STS_IDLE";
	                    #G.MoveStartMs := 0;
	                    #G.UnknownPositionMs := 0;
	                END_IF;
	        END_CASE;
	        
	        // ÐŸÑ€Ñ–Ð¾Ñ€Ð¸Ñ‚ÐµÑ‚ ÐºÐ¾Ð¼Ð°Ð½Ð´Ð¸ STOP
	        IF #B.Cmd = "CMD_STOP" AND (#B.Status = "STS_STARTING" OR #B.Status = "STS_RUNNING") THEN
	            #B.Status := "STS_STOPPING";
	        END_IF;
	    END_IF;
	END_REGION
	
	REGION "7) Ð¤Ð¾Ñ€Ð¼ÑƒÐ²Ð°Ð½Ð½Ñ Ð²Ð¸Ñ…Ð¾Ð´Ñ–Ð² DO Ñ‚Ð° Status_Param"
	    IF (#B.Status = "STS_STARTING") OR (#B.Status = "STS_RUNNING") THEN
	        #G.DO_Pos0 := (#B.CmdParam1 = "CMD_GATE_POS0");
	        #G.DO_Pos1 := (#B.CmdParam1 = "CMD_GATE_POS1");
	    ELSE
	        #G.DO_Pos0 := FALSE;
	        #G.DO_Pos1 := FALSE;
	    END_IF;
	    
	    // ÐŸÐ¾Ñ‚Ð¾Ñ‡Ð½Ð° Ñ„Ñ–Ð·Ð¸Ñ‡Ð½Ð° Ð¿Ð¾Ð·Ð¸Ñ†Ñ–Ñ (Ð¾Ð½Ð¾Ð²Ð»ÑŽÑ”Ñ‚ÑŒÑÑ Ñ‰Ð¾ÑÐºÐ°Ð½Ð¾Ð²Ð¾ Ð·Ð° ÐºÑ–Ð½Ñ†ÐµÐ²Ð¸ÐºÐ°Ð¼Ð¸)
	    // ÐžÐ±Ð¸Ð´Ð²Ð° Ð´Ð°Ñ‚Ñ‡Ð¸ÐºÐ¸ Ð°ÐºÑ‚Ð¸Ð²Ð½Ñ– = Ð°Ð²Ð°Ñ€Ñ–Ñ FLT_BOTH_SENSORS â†’ Ð¿Ð¾Ð·Ð¸Ñ†Ñ–Ñ Ð½ÐµÐ²Ñ–Ð´Ð¾Ð¼Ð°
	    
		IF #B.Status="STS_FAULT" OR B.FLTCode<>0 THEN
			B.Status_Param:="VALVE_FAULT";  
	    ELSIF #G.DI_Pos1_OK AND NOT #G.DI_Pos0_OK THEN
	        #B.Status_Param := "GATE_AT_POS1";    // = 7
	    ELSIF #G.DI_Pos0_OK AND NOT #G.DI_Pos1_OK THEN
			#B.Status_Param := "GATE_AT_POS0";    // = 6
		ELSE
	        #B.Status_Param := 0;                 // Ð½ÐµÐ²Ñ–Ð´Ð¾Ð¼Ð° (Ð² Ñ€ÑƒÑÑ–, Ð¾Ð±Ð¸Ð´Ð²Ð° Ð´Ð°Ñ‚Ñ‡Ð¸ÐºÐ¸, Ð°Ð±Ð¾ Ð½Ðµ Ñ–Ð½Ñ–Ñ†Ñ–Ð°Ð»Ñ–Ð·Ð¾Ð²Ð°Ð½Ð°)
	    END_IF;
	    
	    #B.Cmd := "CMD_NONE";
	END_REGION
	
	
END_FUNCTION

