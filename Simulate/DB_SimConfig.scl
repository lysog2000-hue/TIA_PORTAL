// ==============================================================================
// DB_SimRedlersConfig - Конфігурація симуляторів редлерів
// ==============================================================================
// Версія: 2.0.0
// Дата: 2026-01-29
// ==============================================================================
// Призначення:
//   Зберігає налаштування симуляції для кожного редлера
//   RETAIN - налаштування зберігаються після перезавантаження CPU
//   
// Розділення відповідальності:
//   - DB_SimRedlers (NON_RETAIN) - runtime стан (мотор працює, розгін, аварії)
//   - DB_SimRedlersConfig (RETAIN) - налаштування (часи, увімкнення симуляції)
//
// Використання:
//   1. Налаштуйте параметри у DB_SimRedlersConfig через HMI або онлайн-редагування
//   2. Викликайте FC_SimRedler, передаючи параметри з конфігу
// ==============================================================================

DATA_BLOCK "DB_SimConfig"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.0
    
VAR
    // === Масив конфігурацій ===
    Redler : ARRAY[0.."REDLERS_COUNT"] OF "UDT_SimRedlerConfig";
END_VAR

BEGIN
    // Початкові налаштуваня 
	// Решта  за замовчуванням вимкнені (Enable := FALSE)
    Redler[0].Enable := TRUE;
    Redler[0].StartupTime_ms := 5000;
    Redler[0].StopTime_ms := 2000;
    Redler[0].SimFault_Breaker := FALSE;
    Redler[0].FaultTime_Breaker_ms := 10000;
    Redler[0].SimFault_Overflow := FALSE;
    Redler[0].FaultTime_Overflow_ms := 15000;
    
    // Решта редлерів за замовчуванням вимкнені (Enable := FALSE)
    
END_DATA_BLOCK
