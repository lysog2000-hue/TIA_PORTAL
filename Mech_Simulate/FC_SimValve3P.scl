FUNCTION "FC_SimValve3P" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0
// ==============================================================================
// FC_SimValve3P - Симулятор клапана 3П (трипозиційний)
// ==============================================================================
// Версія: 1.0.0
// Дата: 2026-03-27
// ==============================================================================
// Призначення:
//   Імітує фізичне залізо Valve3P для тестування FC_Valve3P без обладнання
//
// Комунікація з FC_Valve3P ТІЛЬКИ через сигнали:
//   - Читає:  DB_Mechs.Valve3P[Valve3PIdx].DO_Pos0
//             DB_Mechs.Valve3P[Valve3PIdx].DO_Pos1
//             DB_Mechs.Valve3P[Valve3PIdx].DO_Pos2
//   - Пише:   DB_Mechs.Valve3P[Valve3PIdx].DI_Pos0_OK
//             DB_Mechs.Valve3P[Valve3PIdx].DI_Pos1_OK
//             DB_Mechs.Valve3P[Valve3PIdx].DI_Pos2_OK
//             DB_Mechs.Valve3P[Valve3PIdx].DI_Breaker_OK
//
// Використання в OB1:
//   "FC_SimValve3P"(
//       Valve3PIdx           := 0,
//       TravelTime_ms        := 15000,
//       InitPosition         := 0,
//       SimFault_Breaker     := FALSE,
//       FaultTime_Breaker_ms := 10000,
//       ManualReset          := FALSE
//   );
//
//   "FC_DeviceRunner"(...);  // викликає FC_Valve3P як завжди
//
// Особливості Valve3P:
//   - Три виходи DO_Pos0/DO_Pos1/DO_Pos2
//   - Три входи DI_Pos0_OK/DI_Pos1_OK/DI_Pos2_OK
//   - Під час руху всі кінцевики FALSE (клапан між позиціями)
//   - Ініціалізація позиції при першому скані
// ==============================================================================
   VAR_INPUT 
      Valve3PIdx : Int;   // індекс у DB_Mechs.Valve3P[] (0..N) === Фізика клапана ===
      TravelTime_ms : DInt;   // час переміщення між позиціями (мс)
      InitPosition : USInt;   // початкова позиція (0, 1, або 2) === Симуляція аварії автомата ===
      SimFault_Breaker : Bool;   // увімкнути симуляцію FLT_BREAKER
      FaultTime_Breaker_ms : DInt;   // час до аварії від початку руху (мс) === Ручний скид аварій ===
      ManualReset : Bool;   // скинути латчовані аварії (Breaker)
   END_VAR

   VAR_TEMP 
      idx : Int;
      elapsedMs : DInt;
      nowTck : DInt;
      travelDone : Bool;
      breakerTimeout : Bool;
   END_VAR


BEGIN
	
	// =========================================================
	// VALIDATE INDEX
	// =========================================================
	IF #Valve3PIdx > "VALVES3P_COUNT" THEN
	    RETURN;
	END_IF;
	
	#idx := #Valve3PIdx;
	
	// =========================================================
	// PHASE 0: Ініціалізація та ручний скид
	// =========================================================
	
	// Перший скан: встановити початкову позицію
	IF NOT "DB_SimMechs".Valve3P[#idx].Initialized THEN
	    "DB_SimMechs".Valve3P[#idx].IsAtPos0 := (#InitPosition = 0);
	    "DB_SimMechs".Valve3P[#idx].IsAtPos1 := (#InitPosition = 1);
	    "DB_SimMechs".Valve3P[#idx].IsAtPos2 := (#InitPosition = 2);
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos0 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos1 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos2 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].Initialized := TRUE;
	END_IF;
	
	// Ручний скид аварій та примусова ініціалізація позиції
	IF #ManualReset THEN
	    "DB_SimMechs".Valve3P[#idx].Breaker_Tripped := FALSE;
	    // Примусово встановити позицію за InitPosition
	    "DB_SimMechs".Valve3P[#idx].IsAtPos0 := (#InitPosition = 0);
	    "DB_SimMechs".Valve3P[#idx].IsAtPos1 := (#InitPosition = 1);
	    "DB_SimMechs".Valve3P[#idx].IsAtPos2 := (#InitPosition = 2);
	END_IF;
	
	// =========================================================
	// PHASE 1: Edge detection DO_Pos0 / DO_Pos1 / DO_Pos2
	// =========================================================
	
	// Фронт 0→1 DO_Pos0 (FC_Valve3P починає рух до Pos0)
	IF "DB_Mechs".Valve3P[#idx].DO_Pos0 AND NOT "DB_SimMechs".Valve3P[#idx].LastDO_Pos0 THEN
	    "DB_SimMechs".Valve3P[#idx].IsAtPos0 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsAtPos1 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsAtPos2 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos0 := TRUE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos1 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos2 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].MoveStartTck := TIME_TCK();
	    "DB_SimMechs".Valve3P[#idx].FaultStartTck := TIME_TCK();
	END_IF;
	
	// Фронт 0→1 DO_Pos1 (FC_Valve3P починає рух до Pos1)
	IF "DB_Mechs".Valve3P[#idx].DO_Pos1 AND NOT "DB_SimMechs".Valve3P[#idx].LastDO_Pos1 THEN
	    "DB_SimMechs".Valve3P[#idx].IsAtPos0 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsAtPos1 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsAtPos2 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos0 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos1 := TRUE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos2 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].MoveStartTck := TIME_TCK();
	    "DB_SimMechs".Valve3P[#idx].FaultStartTck := TIME_TCK();
	END_IF;
	
	// Фронт 0→1 DO_Pos2 (FC_Valve3P починає рух до Pos2)
	IF "DB_Mechs".Valve3P[#idx].DO_Pos2 AND NOT "DB_SimMechs".Valve3P[#idx].LastDO_Pos2 THEN
	    "DB_SimMechs".Valve3P[#idx].IsAtPos0 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsAtPos1 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsAtPos2 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos0 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos1 := FALSE;
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos2 := TRUE;
	    "DB_SimMechs".Valve3P[#idx].MoveStartTck := TIME_TCK();
	    "DB_SimMechs".Valve3P[#idx].FaultStartTck := TIME_TCK();
	END_IF;
	
	// Фронт 1→0 DO_Pos0 під час руху (CMD_STOP або аварія)
	IF NOT "DB_Mechs".Valve3P[#idx].DO_Pos0 AND "DB_SimMechs".Valve3P[#idx].LastDO_Pos0
	    AND "DB_SimMechs".Valve3P[#idx].IsMovingToPos0 THEN
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos0 := FALSE;
	    // Залишається у невизначеній позиції
	END_IF;
	
	// Фронт 1→0 DO_Pos1 під час руху
	IF NOT "DB_Mechs".Valve3P[#idx].DO_Pos1 AND "DB_SimMechs".Valve3P[#idx].LastDO_Pos1
	    AND "DB_SimMechs".Valve3P[#idx].IsMovingToPos1 THEN
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos1 := FALSE;
	END_IF;
	
	// Фронт 1→0 DO_Pos2 під час руху
	IF NOT "DB_Mechs".Valve3P[#idx].DO_Pos2 AND "DB_SimMechs".Valve3P[#idx].LastDO_Pos2
	    AND "DB_SimMechs".Valve3P[#idx].IsMovingToPos2 THEN
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos2 := FALSE;
	END_IF;
	
	"DB_SimMechs".Valve3P[#idx].LastDO_Pos0 := "DB_Mechs".Valve3P[#idx].DO_Pos0;
	"DB_SimMechs".Valve3P[#idx].LastDO_Pos1 := "DB_Mechs".Valve3P[#idx].DO_Pos1;
	"DB_SimMechs".Valve3P[#idx].LastDO_Pos2 := "DB_Mechs".Valve3P[#idx].DO_Pos2;
	
	// =========================================================
	// PHASE 2: Симуляція переміщення (таймер → прибуття)
	// =========================================================
	
	IF "DB_SimMechs".Valve3P[#idx].IsMovingToPos0 THEN
	    #travelDone := "FC_TimeElapsedMs"(
	                                      StartTck := "DB_SimMechs".Valve3P[#idx].MoveStartTck,
	                                      TimeoutMs := #TravelTime_ms,
	                                      ElapsedMs => #elapsedMs,
	                                      NowTck => #nowTck
	    );
	    IF #travelDone THEN
	        "DB_SimMechs".Valve3P[#idx].IsAtPos0 := TRUE;
	        "DB_SimMechs".Valve3P[#idx].IsMovingToPos0 := FALSE;
	    END_IF;
	END_IF;
	
	IF "DB_SimMechs".Valve3P[#idx].IsMovingToPos1 THEN
	    #travelDone := "FC_TimeElapsedMs"(
	                                      StartTck := "DB_SimMechs".Valve3P[#idx].MoveStartTck,
	                                      TimeoutMs := #TravelTime_ms,
	                                      ElapsedMs => #elapsedMs,
	                                      NowTck => #nowTck
	    );
	    IF #travelDone THEN
	        "DB_SimMechs".Valve3P[#idx].IsAtPos1 := TRUE;
	        "DB_SimMechs".Valve3P[#idx].IsMovingToPos1 := FALSE;
	    END_IF;
	END_IF;
	
	IF "DB_SimMechs".Valve3P[#idx].IsMovingToPos2 THEN
	    #travelDone := "FC_TimeElapsedMs"(
	                                      StartTck := "DB_SimMechs".Valve3P[#idx].MoveStartTck,
	                                      TimeoutMs := #TravelTime_ms,
	                                      ElapsedMs => #elapsedMs,
	                                      NowTck => #nowTck
	    );
	    IF #travelDone THEN
	        "DB_SimMechs".Valve3P[#idx].IsAtPos2 := TRUE;
	        "DB_SimMechs".Valve3P[#idx].IsMovingToPos2 := FALSE;
	    END_IF;
	END_IF;
	
	// =========================================================
	// PHASE 3: Симуляція аварії BREAKER
	// =========================================================
	
	IF #SimFault_Breaker
	    AND ("DB_SimMechs".Valve3P[#idx].IsMovingToPos0 OR
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos1 OR
	    "DB_SimMechs".Valve3P[#idx].IsMovingToPos2)
	    AND NOT "DB_SimMechs".Valve3P[#idx].Breaker_Tripped THEN
	    #breakerTimeout := "FC_TimeElapsedMs"(
	                                          StartTck := "DB_SimMechs".Valve3P[#idx].FaultStartTck,
	                                          TimeoutMs := #FaultTime_Breaker_ms,
	                                          ElapsedMs => #elapsedMs,
	                                          NowTck => #nowTck
	    );
	    IF #breakerTimeout THEN
	        "DB_SimMechs".Valve3P[#idx].Breaker_Tripped := TRUE;
	    END_IF;
	END_IF;
	
	// =========================================================
	// PHASE 4: Запис DI сигналів
	// =========================================================
	
	"DB_Mechs".Valve3P[#idx].DI_Pos0_OK := "DB_SimMechs".Valve3P[#idx].IsAtPos0;
	"DB_Mechs".Valve3P[#idx].DI_Pos1_OK := "DB_SimMechs".Valve3P[#idx].IsAtPos1;
	"DB_Mechs".Valve3P[#idx].DI_Pos2_OK := "DB_SimMechs".Valve3P[#idx].IsAtPos2;
	"DB_Mechs".Valve3P[#idx].DI_Breaker_OK := NOT "DB_SimMechs".Valve3P[#idx].Breaker_Tripped;
	
	
END_FUNCTION

