FUNCTION "FC_SimSilos" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.1
// Симулятор силосу
// За замовчуванням: рівні в нормі (TRUE = OK)
// Реальна симуляція заповнення може бути додана пізніше
   VAR_INPUT 
      SilosIdx : Int;
      Enable : Bool;
   END_VAR


BEGIN
	
	IF #SilosIdx > "SILOS_COUNT" THEN
	    RETURN;
	END_IF;
	
	IF #Enable THEN
	    // Симулюємо нормальний стан: рівні в нормі
	    "DB_Mechs".Silos[#SilosIdx].DI_LevelHigh_OK := TRUE;
	    "DB_Mechs".Silos[#SilosIdx].DI_LevelLow_OK  := TRUE;
	END_IF;
	
END_FUNCTION
