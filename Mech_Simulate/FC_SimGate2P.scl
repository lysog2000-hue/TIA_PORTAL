FUNCTION "FC_SimGate2P" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0
// ==============================================================================
// FC_SimGate2P - Ð¡Ð¸Ð¼ÑƒÐ»ÑÑ‚Ð¾Ñ€ Ñ„Ñ–Ð·Ð¸ÐºÐ¸ Ñ‚Ð° Ð½ÐµÑÐ¿Ñ€Ð°Ð²Ð½Ð¾ÑÑ‚ÐµÐ¹ Gate2P
// ==============================================================================
// Ð’ÐµÑ€ÑÑ–Ñ: 1.0.0
// Ð”Ð°Ñ‚Ð°: 2026-02-26
// ==============================================================================
// ÐŸÑ€Ð¸Ð·Ð½Ð°Ñ‡ÐµÐ½Ð½Ñ:
//   Ð†Ð¼Ñ–Ñ‚ÑƒÑ” Ñ„Ñ–Ð·Ð¸Ñ‡Ð½Ðµ Ð·Ð°Ð»Ñ–Ð·Ð¾ Gate2P Ð´Ð»Ñ Ñ‚ÐµÑÑ‚ÑƒÐ²Ð°Ð½Ð½Ñ FC_Gate2P Ð±ÐµÐ· Ð¾Ð±Ð»Ð°Ð´Ð½Ð°Ð½Ð½Ñ
//
// ÐšÐ¾Ð¼ÑƒÐ½Ñ–ÐºÐ°Ñ†Ñ–Ñ Ð· FC_Gate2P Ð¢Ð†Ð›Ð¬ÐšÐ˜ Ñ‡ÐµÑ€ÐµÐ· 5 ÑÐ¸Ð³Ð½Ð°Ð»Ñ–Ð²:
//   - Ð§Ð¸Ñ‚Ð°Ñ”:  DB_Mechs.Gate2P[GateIdx].DO_Pos0
//             DB_Mechs.Gate2P[GateIdx].DO_Pos1
//   - ÐŸÐ¸ÑˆÐµ:   DB_Mechs.Gate2P[GateIdx].DI_Pos0_OK
//             DB_Mechs.Gate2P[GateIdx].DI_Pos1_OK
//             DB_Mechs.Gate2P[GateIdx].DI_Breaker_OK
//
// Ð’Ð¸ÐºÐ¾Ñ€Ð¸ÑÑ‚Ð°Ð½Ð½Ñ Ð² OB1:
//   "FC_SimGate2P"(
//       GateIdx              := 0,
//       TravelTime_ms        := 5000,
//       InitAtPos0           := TRUE,
//       SimFault_Breaker     := FALSE,
//       FaultTime_Breaker_ms := 10000,
//       ManualReset          := FALSE
//   );
//
//   FC_DeviceRunner(...);  // Ð²Ð¸ÐºÐ»Ð¸ÐºÐ°Ñ” FC_Gate2P ÑÐº Ð·Ð°Ð·Ð²Ð¸Ñ‡Ð°Ð¹
//
// ÐžÑÐ¾Ð±Ð»Ð¸Ð²Ð¾ÑÑ‚Ñ– Gate2P:
//   - Ð”Ð²Ð° Ð²Ð¸Ñ…Ð¾Ð´Ð¸ DO_Pos0/DO_Pos1 (Ð·Ð°Ð¼Ñ–ÑÑ‚ÑŒ Ð¾Ð´Ð½Ð¾Ð³Ð¾ DO_Run)
//   - ÐŸÑ–Ð´ Ñ‡Ð°Ñ Ñ€ÑƒÑ…Ñƒ Ð¾Ð±Ð¸Ð´Ð²Ð° ÐºÑ–Ð½Ñ†ÐµÐ²Ð¸ÐºÐ¸ FALSE (Ð·Ð°ÑÑƒÐ²ÐºÐ° Ð¼Ñ–Ð¶ Ð¿Ð¾Ð·Ð¸Ñ†Ñ–ÑÐ¼Ð¸)
//   - ÐŸÑ€Ð¸ Ð·ÑƒÐ¿Ð¸Ð½Ñ†Ñ– DO Ð´Ð¾ Ð¿Ñ€Ð¸Ð±ÑƒÑ‚Ñ‚Ñ â€” Ð·Ð°ÑÑƒÐ²ÐºÐ° Ñƒ Ð½ÐµÐ²Ð¸Ð·Ð½Ð°Ñ‡ÐµÐ½Ñ–Ð¹ Ð¿Ð¾Ð·Ð¸Ñ†Ñ–Ñ—
//   - Ð†Ð½Ñ–Ñ†Ñ–Ð°Ð»Ñ–Ð·Ð°Ñ†Ñ–Ñ Ð¿Ð¾Ð·Ð¸Ñ†Ñ–Ñ— Ð¿Ñ€Ð¸ Ð¿ÐµÑ€ÑˆÐ¾Ð¼Ñƒ ÑÐºÐ°Ð½Ñ– (InitAtPos0)
// ==============================================================================
   VAR_INPUT 
      GateIdx : UInt;   // Ñ–Ð½Ð´ÐµÐºÑ Ñƒ DB_Mechs.Gate2P[] (0..N) === Ð¤Ñ–Ð·Ð¸ÐºÐ° Ð·Ð°ÑÑƒÐ²ÐºÐ¸ ===
      TravelTime_ms : DInt;   // Ñ‡Ð°Ñ Ð¿ÐµÑ€ÐµÐ¼Ñ–Ñ‰ÐµÐ½Ð½Ñ Ð¼Ñ–Ð¶ ÐºÑ–Ð½Ñ†ÐµÐ²Ð¸ÐºÐ°Ð¼Ð¸ (Ð¼Ñ)
      InitAtPos0 : Bool;   // Ð¿Ð¾Ñ‡Ð°Ñ‚ÐºÐ¾Ð²Ð° Ð¿Ð¾Ð·Ð¸Ñ†Ñ–Ñ (TRUE=Pos0, FALSE=Pos1) === Ð¡Ð¸Ð¼ÑƒÐ»ÑÑ†Ñ–Ñ Ð°Ð²Ð°Ñ€Ñ–Ñ— Ð°Ð²Ñ‚Ð¾Ð¼Ð°Ñ‚Ð° ===
      SimFault_Breaker : Bool;   // ÑƒÐ²Ñ–Ð¼ÐºÐ½ÑƒÑ‚Ð¸ ÑÐ¸Ð¼ÑƒÐ»ÑÑ†Ñ–ÑŽ FLT_BREAKER
      FaultTime_Breaker_ms : DInt;   // Ñ‡Ð°Ñ Ð´Ð¾ Ð°Ð²Ð°Ñ€Ñ–Ñ— Ð²Ñ–Ð´ Ð¿Ð¾Ñ‡Ð°Ñ‚ÐºÑƒ Ñ€ÑƒÑ…Ñƒ (Ð¼Ñ) === Ð ÑƒÑ‡Ð½Ð¸Ð¹ ÑÐºÐ¸Ð´ Ð°Ð²Ð°Ñ€Ñ–Ð¹ ===
      ManualReset : Bool;   // ÑÐºÐ¸Ð½ÑƒÑ‚Ð¸ Ð»Ð°Ñ‚Ñ‡Ð¾Ð²Ð°Ð½Ñ– Ð°Ð²Ð°Ñ€Ñ–Ñ— (Breaker)
   END_VAR

   VAR_TEMP 
      idx : UInt;
      elapsedMs : DInt;
      nowTck : DInt;
      travelDone : Bool;
      breakerTimeout : Bool;
   END_VAR


BEGIN
	
	
	// =========================================================
	// VALIDATE INDEX
	// =========================================================
	IF #GateIdx > "GATES2P_COUNT" THEN
	    RETURN;
	END_IF;
	
	#idx := #GateIdx;
	
	// =========================================================
	// PHASE 0: Ð†Ð½Ñ–Ñ†Ñ–Ð°Ð»Ñ–Ð·Ð°Ñ†Ñ–Ñ Ñ‚Ð° Ñ€ÑƒÑ‡Ð½Ð¸Ð¹ ÑÐºÐ¸Ð´
	// =========================================================
	
	// ÐŸÐµÑ€ÑˆÐ¸Ð¹ ÑÐºÐ°Ð½: Ð²ÑÑ‚Ð°Ð½Ð¾Ð²Ð¸Ñ‚Ð¸ Ð¿Ð¾Ñ‡Ð°Ñ‚ÐºÐ¾Ð²Ñƒ Ð¿Ð¾Ð·Ð¸Ñ†Ñ–ÑŽ
	IF NOT "DB_SimMechs".Gate2P[#idx].Initialized THEN
	    "DB_SimMechs".Gate2P[#idx].IsAtPos0 := #InitAtPos0;
	    "DB_SimMechs".Gate2P[#idx].IsAtPos1 := NOT #InitAtPos0;
	    "DB_SimMechs".Gate2P[#idx].IsMovingToPos0 := FALSE;
	    "DB_SimMechs".Gate2P[#idx].IsMovingToPos1 := FALSE;
	    "DB_SimMechs".Gate2P[#idx].Initialized := TRUE;
	END_IF;
	
	IF #ManualReset THEN
	    "DB_SimMechs".Gate2P[#idx].Breaker_Tripped := FALSE;
	END_IF;
	
	// =========================================================
	// PHASE 1: Edge detection DO_Pos0 / DO_Pos1
	// =========================================================
	
	// Ð¤Ñ€Ð¾Ð½Ñ‚ 0â†’1 DO_Pos0 (FC_Gate2P Ð¿Ð¾Ñ‡Ð¸Ð½Ð°Ñ” Ñ€ÑƒÑ… Ð´Ð¾ Pos0)
	IF "DB_Mechs".Gate2P[#idx].DO_Pos0 AND NOT "DB_SimMechs".Gate2P[#idx].LastDO_Pos0 THEN
	    "DB_SimMechs".Gate2P[#idx].IsAtPos0 := FALSE;  // Ð·Ð°Ð»Ð¸ÑˆÐ°Ñ”Ð¼Ð¾ Ð¿Ð¾Ñ‚Ð¾Ñ‡Ð½Ñƒ Ð¿Ð¾Ð·Ð¸Ñ†Ñ–ÑŽ
	    "DB_SimMechs".Gate2P[#idx].IsAtPos1 := FALSE;
	    "DB_SimMechs".Gate2P[#idx].IsMovingToPos0 := TRUE;
	    "DB_SimMechs".Gate2P[#idx].IsMovingToPos1 := FALSE;
	    "DB_SimMechs".Gate2P[#idx].MoveStartTck := TIME_TCK();
	    "DB_SimMechs".Gate2P[#idx].FaultStartTck := TIME_TCK();
	END_IF;
	
	// Ð¤Ñ€Ð¾Ð½Ñ‚ 0â†’1 DO_Pos1 (FC_Gate2P Ð¿Ð¾Ñ‡Ð¸Ð½Ð°Ñ” Ñ€ÑƒÑ… Ð´Ð¾ Pos1)
	IF "DB_Mechs".Gate2P[#idx].DO_Pos1 AND NOT "DB_SimMechs".Gate2P[#idx].LastDO_Pos1 THEN
	    "DB_SimMechs".Gate2P[#idx].IsAtPos0 := FALSE;
	    "DB_SimMechs".Gate2P[#idx].IsAtPos1 := FALSE;
	    "DB_SimMechs".Gate2P[#idx].IsMovingToPos0 := FALSE;
	    "DB_SimMechs".Gate2P[#idx].IsMovingToPos1 := TRUE;
	    "DB_SimMechs".Gate2P[#idx].MoveStartTck := TIME_TCK();
	    "DB_SimMechs".Gate2P[#idx].FaultStartTck := TIME_TCK();
	END_IF;
	
	// Ð¤Ñ€Ð¾Ð½Ñ‚ 1â†’0 DO_Pos0 Ð¿Ñ–Ð´ Ñ‡Ð°Ñ Ñ€ÑƒÑ…Ñƒ (CMD_STOP Ð°Ð±Ð¾ Ð°Ð²Ð°Ñ€Ñ–Ñ â€” Ð·Ð°ÑÑƒÐ²ÐºÐ° Ð·ÑƒÐ¿Ð¸Ð½ÑÑ”Ñ‚ÑŒÑÑ Ð¼Ñ–Ð¶ Ð¿Ð¾Ð·Ð¸Ñ†Ñ–ÑÐ¼Ð¸)
	IF NOT "DB_Mechs".Gate2P[#idx].DO_Pos0 AND "DB_SimMechs".Gate2P[#idx].LastDO_Pos0
	    AND "DB_SimMechs".Gate2P[#idx].IsMovingToPos0 THEN
	    "DB_SimMechs".Gate2P[#idx].IsMovingToPos0 := FALSE;
	    // IsAtPos0=FALSE, IsAtPos1=FALSE â†’ Ð½ÐµÐ²Ð¸Ð·Ð½Ð°Ñ‡ÐµÐ½Ð° Ð¿Ð¾Ð·Ð¸Ñ†Ñ–Ñ
	END_IF;
	
	// Ð¤Ñ€Ð¾Ð½Ñ‚ 1â†’0 DO_Pos1 Ð¿Ñ–Ð´ Ñ‡Ð°Ñ Ñ€ÑƒÑ…Ñƒ
	IF NOT "DB_Mechs".Gate2P[#idx].DO_Pos1 AND "DB_SimMechs".Gate2P[#idx].LastDO_Pos1
	    AND "DB_SimMechs".Gate2P[#idx].IsMovingToPos1 THEN
	    "DB_SimMechs".Gate2P[#idx].IsMovingToPos1 := FALSE;
	    // IsAtPos0=FALSE, IsAtPos1=FALSE â†’ Ð½ÐµÐ²Ð¸Ð·Ð½Ð°Ñ‡ÐµÐ½Ð° Ð¿Ð¾Ð·Ð¸Ñ†Ñ–Ñ
	END_IF;
	
	"DB_SimMechs".Gate2P[#idx].LastDO_Pos0 := "DB_Mechs".Gate2P[#idx].DO_Pos0;
	"DB_SimMechs".Gate2P[#idx].LastDO_Pos1 := "DB_Mechs".Gate2P[#idx].DO_Pos1;
	
	// =========================================================
	// PHASE 2: Ð¡Ð¸Ð¼ÑƒÐ»ÑÑ†Ñ–Ñ Ð¿ÐµÑ€ÐµÐ¼Ñ–Ñ‰ÐµÐ½Ð½Ñ (Ñ‚Ð°Ð¹Ð¼ÐµÑ€ â†’ Ð¿Ñ€Ð¸Ð±ÑƒÑ‚Ñ‚Ñ)
	// =========================================================
	
	IF "DB_SimMechs".Gate2P[#idx].IsMovingToPos0 THEN
	    #travelDone := "FC_TimeElapsedMs"(
	                                      StartTck := "DB_SimMechs".Gate2P[#idx].MoveStartTck,
	                                      TimeoutMs := #TravelTime_ms,
	                                      ElapsedMs => #elapsedMs,
	                                      NowTck => #nowTck
	    );
	    IF #travelDone THEN
	        "DB_SimMechs".Gate2P[#idx].IsAtPos0 := TRUE;
	        "DB_SimMechs".Gate2P[#idx].IsMovingToPos0 := FALSE;
	    END_IF;
	END_IF;
	
	IF "DB_SimMechs".Gate2P[#idx].IsMovingToPos1 THEN
	    #travelDone := "FC_TimeElapsedMs"(
	                                      StartTck := "DB_SimMechs".Gate2P[#idx].MoveStartTck,
	                                      TimeoutMs := #TravelTime_ms,
	                                      ElapsedMs => #elapsedMs,
	                                      NowTck => #nowTck
	    );
	    IF #travelDone THEN
	        "DB_SimMechs".Gate2P[#idx].IsAtPos1 := TRUE;
	        "DB_SimMechs".Gate2P[#idx].IsMovingToPos1 := FALSE;
	    END_IF;
	END_IF;
	
	// =========================================================
	// PHASE 3: Ð¡Ð¸Ð¼ÑƒÐ»ÑÑ†Ñ–Ñ Ð°Ð²Ð°Ñ€Ñ–Ñ— BREAKER
	// =========================================================
	
	IF #SimFault_Breaker
	    AND ("DB_SimMechs".Gate2P[#idx].IsMovingToPos0 OR "DB_SimMechs".Gate2P[#idx].IsMovingToPos1)
	    AND NOT "DB_SimMechs".Gate2P[#idx].Breaker_Tripped THEN
	    #breakerTimeout := "FC_TimeElapsedMs"(
	                                          StartTck := "DB_SimMechs".Gate2P[#idx].FaultStartTck,
	                                          TimeoutMs := #FaultTime_Breaker_ms,
	                                          ElapsedMs => #elapsedMs,
	                                          NowTck => #nowTck
	    );
	    IF #breakerTimeout THEN
	        "DB_SimMechs".Gate2P[#idx].Breaker_Tripped := TRUE;
	    END_IF;
	END_IF;
	
	// =========================================================
	// PHASE 4: Ð—Ð°Ð¿Ð¸Ñ DI ÑÐ¸Ð³Ð½Ð°Ð»Ñ–Ð²
	// =========================================================
	
	"DB_Mechs".Gate2P[#idx].DI_Pos0_OK := "DB_SimMechs".Gate2P[#idx].IsAtPos0;
	"DB_Mechs".Gate2P[#idx].DI_Pos1_OK := "DB_SimMechs".Gate2P[#idx].IsAtPos1;
	"DB_Mechs".Gate2P[#idx].DI_Breaker_OK := NOT "DB_SimMechs".Gate2P[#idx].Breaker_Tripped;
	
	
END_FUNCTION

