FUNCTION "FC_SimRedler" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 2.1
// ==============================================================================
// FC_SimRedler - Ñèìóëÿòîð ô³çèêè òà íåñïðàâíîñòåé ðåäëåðà
// ==============================================================================
// Âåðñ³ÿ: 2.1.0
// Äàòà: 2026-04-10
// ==============================================================================
// Çì³íè v2.1:
//   + Äîäàíî ñèìóëÿö³þ DI_Speed_OK (PHASE 2) — òàõî
//   + Äîäàíî ñèìóëÿö³þ SimFault_Breaker òà SimFault_Overflow
// ==============================================================================
// Êîìóí³êàö³ÿ ç FC_Redler Ò²ËÜÊÈ ÷åðåç ñèãíàëè:
//   - ×èòàº:  DB_Mechs.Redler[RedlerIdx].DO_Run
//   - Ïèøå:   DB_Mechs.Redler[RedlerIdx].DI_Speed_OK
//             DB_Mechs.Redler[RedlerIdx].DI_Breaker_OK
//             DB_Mechs.Redler[RedlerIdx].DI_Overflow_OK
// ==============================================================================
   VAR_INPUT 
      RedlerIdx : Int;
      StartupTime_ms : DInt;
      StopTime_ms : DInt;
      SimFault_Breaker : Bool;
      FaultTime_Breaker_ms : DInt;
      SimFault_Overflow : Bool;
      FaultTime_Overflow_ms : DInt;
      ManualReset : Bool;
   END_VAR

   VAR_TEMP 
      idx : Int;
      elapsedMs : DInt;
      nowTck : DInt;
      startupTimeout : Bool;
      stopTimeout : Bool;
      breakerTimeout : Bool;
      overflowTimeout : Bool;
   END_VAR


BEGIN
	    // =========================================================
	    // VALIDATE INDEX
	    // =========================================================
	    IF #RedlerIdx >= "REDLERS_COUNT" + 1 THEN
	        RETURN;
	    END_IF;
	    
	    #idx := #RedlerIdx;
	    
	    // =========================================================
	    // PHASE 0: Ðó÷íèé ñêèä àâàð³é
	    // =========================================================
	    IF #ManualReset THEN
	        "DB_SimMechs".Redler[#idx].Breaker_Tripped := FALSE;
	        "DB_SimMechs".Redler[#idx].Overflow_Tripped := FALSE;
	    END_IF;
	    IF "DB_Mechs".Redler[#idx].DO_Run AND NOT "DB_SimMechs".Redler[#idx].LastDO_Run THEN
	        "DB_SimMechs".Redler[#idx].MotorStartTck := TIME_TCK();
	        "DB_SimMechs".Redler[#idx].FaultStartTck := TIME_TCK();
	        "DB_SimMechs".Redler[#idx].IsMotorRunning := TRUE;
	        "DB_SimMechs".Redler[#idx].IsSpinningUp := TRUE;
	        "DB_SimMechs".Redler[#idx].IsSpinningDown := FALSE;
	    END_IF;
	    
	    IF NOT "DB_Mechs".Redler[#idx].DO_Run AND "DB_SimMechs".Redler[#idx].LastDO_Run THEN
	        "DB_SimMechs".Redler[#idx].MotorStopTck := TIME_TCK();
	        "DB_SimMechs".Redler[#idx].IsMotorRunning := FALSE;
	        "DB_SimMechs".Redler[#idx].IsSpinningUp := FALSE;
	        "DB_SimMechs".Redler[#idx].IsSpinningDown := TRUE;
	    END_IF;
	    
	    "DB_SimMechs".Redler[#idx].LastDO_Run := "DB_Mechs".Redler[#idx].DO_Run;
	    
	    // =========================================================
	    // PHASE 2: Ñèìóëÿö³ÿ DI_Speed_OK (òàõî)
	    // =========================================================
	    IF "DB_SimMechs".Redler[#idx].IsSpinningUp THEN
	        #startupTimeout := "FC_TimeElapsedMs"(
	                                              StartTck := "DB_SimMechs".Redler[#idx].MotorStartTck,
	                                              TimeoutMs := #StartupTime_ms,
	                                              ElapsedMs => #elapsedMs,
	                                              NowTck => #nowTck
	        );
	        IF #startupTimeout THEN
	            "DB_Mechs".Redler[#idx].DI_Speed_OK := TRUE;
	            "DB_SimMechs".Redler[#idx].IsSpinningUp := FALSE;
	        ELSE
	            "DB_Mechs".Redler[#idx].DI_Speed_OK := FALSE;
	        END_IF;
	    ELSIF "DB_SimMechs".Redler[#idx].IsSpinningDown THEN
	        #stopTimeout := "FC_TimeElapsedMs"(
	                                           StartTck := "DB_SimMechs".Redler[#idx].MotorStopTck,
	                                           TimeoutMs := #StopTime_ms,
	                                           ElapsedMs => #elapsedMs,
	                                           NowTck => #nowTck
	        );
	        IF #stopTimeout THEN
	            "DB_Mechs".Redler[#idx].DI_Speed_OK := FALSE;
	            "DB_SimMechs".Redler[#idx].IsSpinningDown := FALSE;
	        ELSE
	            "DB_Mechs".Redler[#idx].DI_Speed_OK := TRUE;
	        END_IF;
	    ELSIF "DB_SimMechs".Redler[#idx].IsMotorRunning THEN
	        "DB_Mechs".Redler[#idx].DI_Speed_OK := TRUE;
	    ELSE
	        "DB_Mechs".Redler[#idx].DI_Speed_OK := FALSE;
	    END_IF;
	    
	    // =========================================================
	    // PHASE 4: Ñèìóëÿö³ÿ àâàð³¿ BREAKER
	    // =========================================================
	    IF #SimFault_Breaker AND "DB_SimMechs".Redler[#idx].IsMotorRunning AND NOT "DB_SimMechs".Redler[#idx].Breaker_Tripped THEN
	        #breakerTimeout := "FC_TimeElapsedMs"(
	                                              StartTck := "DB_SimMechs".Redler[#idx].FaultStartTck,
	                                              TimeoutMs := #FaultTime_Breaker_ms,
	                                              ElapsedMs => #elapsedMs,
	                                              NowTck => #nowTck
	        );
	        IF #breakerTimeout THEN
	            "DB_SimMechs".Redler[#idx].Breaker_Tripped := TRUE;
	        END_IF;
	    END_IF;
	    "DB_Mechs".Redler[#idx].DI_Breaker_OK := NOT "DB_SimMechs".Redler[#idx].Breaker_Tripped;
	    
	    // =========================================================
	    // PHASE 5: Ñèìóëÿö³ÿ àâàð³¿ OVERFLOW
	    // =========================================================
	    IF #SimFault_Overflow AND "DB_SimMechs".Redler[#idx].IsMotorRunning AND NOT "DB_SimMechs".Redler[#idx].Overflow_Tripped THEN
	        #overflowTimeout := "FC_TimeElapsedMs"(
	                                               StartTck := "DB_SimMechs".Redler[#idx].FaultStartTck,
	                                               TimeoutMs := #FaultTime_Overflow_ms,
	                                               ElapsedMs => #elapsedMs,
	                                               NowTck => #nowTck
	        );
	        IF #overflowTimeout THEN
	            "DB_SimMechs".Redler[#idx].Overflow_Tripped := TRUE;
	        END_IF;
	    END_IF;
	    "DB_Mechs".Redler[#idx].DI_Overflow_OK := NOT "DB_SimMechs".Redler[#idx].Overflow_Tripped;
	    
	    // =========================================================
	    
END_FUNCTION

